{
  "ConnectionStrings": {
    "DefaultConnection": "server=YOUR_DB_HOST;port=3306;database=ipro_crm;user=ipro_user;password=YOUR_DB_PASSWORD;SslMode=Required;"
  },
  "App": {
    "AdminDomain": "admin.yourdomain.com",
    "BaseUrl": "https://yourdomain.com"
  },
  "Admin": {
    "Username": "superadmin",
    "Password": "CHANGE_THIS_STRONG_PASSWORD"
  },
  "Email": {
    "SendGridApiKey": "SG.YOUR_SENDGRID_KEY",
    "FromEmail": "no-reply@iproadvisers.com",
    "FromName": "IPRO Advisers",
    "ReplyToEmail": "support@iproadvisers.com"
  },
  "PayPal": {
    "ClientId": "YOUR_PAYPAL_CLIENT_ID",
    "ClientSecret": "YOUR_PAYPAL_CLIENT_SECRET",
    "IsSandbox": true,
    "WebhookId": "YOUR_WEBHOOK_ID",
    "ReturnUrl": "https://yourdomain.com/billing/success",
    "CancelUrl": "https://yourdomain.com/billing/cancel"
  },
  "Azure": {
    "StorageConnectionString": "YOUR_AZURE_STORAGE_CONNECTION_STRING",
    "StorageAccountName": "YOUR_STORAGE_ACCOUNT_NAME"
  },
  "Plesk": {
    "ApiUrl": "https://YOUR_PLESK_SERVER:8443",
    "ApiKey": "YOUR_PLESK_API_KEY"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      { "Endpoint": "POST:/Account/Login",   "Period": "5m",  "Limit": 10  },
      { "Endpoint": "POST:/Account/Register","Period": "1h",  "Limit": 5   },
      { "Endpoint": "*",                      "Period": "1m",  "Limit": 120 }
    ]
  },
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*"
}
