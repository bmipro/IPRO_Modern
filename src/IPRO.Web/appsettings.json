{
  "ConnectionStrings": {
    "DefaultConnection": "server=YOUR_DB_HOST;port=3306;database=ipro_crm;user=ipro_user;password=YOUR_DB_PASSWORD;SslMode=Required;"
  },
  "App": {
    "AdminDomain": "admin.yourdomain.com",
    "BaseUrl": "https://yourdomain.com",
    "TemporarySiteRootDomain": "247advisers.com",
    "WebsiteDnsTarget": "ipro-prod-web.azurewebsites.net",
    "PlatformDomains": "ipro-prod-web.azurewebsites.net,app.iproadvisers.com,www.iproadvisers.com,iproadvisers.com"
  },
  "Admin": {
    "Username": "superadmin",
    "Password": "CHANGE_THIS_STRONG_PASSWORD"
  },
  "AdminPreview": {
    "SharedSecret": "CHANGE_THIS_SHARED_SECRET"
  },
  "Support": {
    "NotificationEmail": "CHANGE_THIS_SUPPORT_EMAIL"
  },
  "Email": {
    "SendGridApiKey": "SG.YOUR_SENDGRID_KEY",
    "FromEmail": "no-reply@iproadvisers.com",
    "FromName": "IPRO Advisers",
    "ReplyToEmail": "support@iproadvisers.com"
  },
  "PayPal": {
    "ClientId": "YOUR_PAYPAL_CLIENT_ID",
    "ClientSecret": "YOUR_PAYPAL_CLIENT_SECRET",
    "IsSandbox": true,
    "WebhookId": "YOUR_WEBHOOK_ID",
    "ReturnUrl": "https://yourdomain.com/billing/success",
    "CancelUrl": "https://yourdomain.com/billing/cancel"
  },
  "BillingCompany": {
    "Name": "IPRO Advisers",
    "Email": "billing@iproadvisers.com",
    "Website": "www.iProAdvisers.com",
    "TaxRegistrationNumber": ""
  },
  "Azure": {
    "StorageConnectionString": "YOUR_AZURE_STORAGE_CONNECTION_STRING",
    "StorageAccountName": "YOUR_STORAGE_ACCOUNT_NAME"
  },
  "AzureDomainAutomation": {
    "Enabled": false,
    "TenantId": "YOUR_AZURE_TENANT_ID",
    "ClientId": "YOUR_AZURE_APP_CLIENT_ID",
    "ClientSecret": "YOUR_AZURE_APP_CLIENT_SECRET",
    "SubscriptionId": "YOUR_AZURE_SUBSCRIPTION_ID",
    "ResourceGroup": "YOUR_RESOURCE_GROUP",
    "WebAppName": "ipro-prod-web",
    "AppServicePlanResourceId": "/subscriptions/YOUR_AZURE_SUBSCRIPTION_ID/resourceGroups/YOUR_RESOURCE_GROUP/providers/Microsoft.Web/serverfarms/YOUR_APP_SERVICE_PLAN",
    "Location": "Canada East",
    "CreateManagedCertificate": true
  },
  "Plesk": {
    "ApiUrl": "https://YOUR_PLESK_SERVER:8443",
    "ApiKey": "YOUR_PLESK_API_KEY"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      { "Endpoint": "POST:/Account/Login",   "Period": "5m",  "Limit": 10  },
      { "Endpoint": "POST:/Account/Register","Period": "1h",  "Limit": 5   },
      { "Endpoint": "POST:/Account/ForgotPassword", "Period": "5m", "Limit": 5 },
      { "Endpoint": "POST:/Account/ResetPassword", "Period": "5m", "Limit": 5 },
      { "Endpoint": "POST:/PublicWebsite/SubmitLead", "Period": "5m", "Limit": 10 },
      { "Endpoint": "POST:/PublicWebsite/SubmitTestimonial", "Period": "5m", "Limit": 10 },
      { "Endpoint": "POST:/Website/RetryDomain", "Period": "1m", "Limit": 5 },
      { "Endpoint": "*",                      "Period": "1m",  "Limit": 120 }
    ]
  },
  "Logging": {
    "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning" }
  },
  "AllowedHosts": "*"
}
