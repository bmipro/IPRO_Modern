@model IPRO.Web.Models.CampaignIndexViewModel
@{
    ViewData["Title"] = "Campaigns";
}

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2 class="fw-bold mb-1"><i class="fas fa-bullhorn me-2 text-success"></i>Campaigns</h2>
    <p class="text-muted mb-0">Use account types as practical groups, then build reusable drip campaigns for follow-up sequences.</p>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 p-4 pb-0">
        <h5 class="fw-bold mb-1"><i class="fas fa-layer-group me-2 text-primary"></i>Account Type Groups</h5>
        <div class="text-muted small">These groups come from client account types, such as seminar attendees or insurance prospects.</div>
      </div>
      <div class="card-body p-4">
        @if (!Model.Groups.Any())
        {
          <div class="text-center text-muted py-4">No account types yet. Create them from the Clients area.</div>
        }
        else
        {
          <div class="row g-3">
          @foreach (var group in Model.Groups)
          {
            <div class="col-md-6">
              <div class="border rounded-3 p-3 h-100">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <h6 class="fw-bold mb-1">@group.Name</h6>
                    <div class="small text-muted">@(!string.IsNullOrWhiteSpace(group.Description) ? group.Description : "Client group")</div>
                  </div>
                  <span class="badge bg-primary-subtle text-primary">@group.ClientCount clients</span>
                </div>
                <div class="small text-muted mt-3"><i class="fas fa-envelope me-1"></i>@group.SubscriberCount newsletter subscribers</div>
              </div>
            </div>
          }
          </div>
        }
      </div>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 p-4 pb-0">
        <h5 class="fw-bold mb-1"><i class="fas fa-plus-circle me-2 text-success"></i>Create Drip Campaign</h5>
        <div class="text-muted small">Create the reusable sequence first, then enroll a group or individual client.</div>
      </div>
      <div class="card-body p-4">
        <form asp-action="Create" method="post">
          @Html.AntiForgeryToken()
          <div class="mb-3">
            <label class="form-label fw-semibold">Campaign name</label>
            <input name="name" class="form-control" placeholder="Example: New prospect follow-up" required />
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea name="description" class="form-control" rows="3" placeholder="Who this sequence is for and when to use it"></textarea>
          </div>
          <button class="btn btn-success w-100" type="submit"><i class="fas fa-plus me-1"></i>Create Campaign</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm mt-4">
  <div class="card-header bg-white border-0 p-4 pb-0">
    <h5 class="fw-bold mb-1"><i class="fas fa-stream me-2 text-info"></i>Drip Campaigns</h5>
    <div class="text-muted small">Sequences can be reused for different clients or account-type groups.</div>
  </div>
  <div class="card-body p-4">
    @if (!Model.Campaigns.Any())
    {
      <div class="text-center text-muted py-5">
        <i class="fas fa-paper-plane fa-3x opacity-25 mb-3 d-block"></i>
        <h5 class="fw-bold">No campaigns yet</h5>
        <p>Create your first campaign above, then add its email steps.</p>
      </div>
    }
    else
    {
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Campaign</th>
              <th>Steps</th>
              <th>Active clients</th>
              <th>Status</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
          @foreach (var campaign in Model.Campaigns)
          {
            <tr>
              <td>
                <div class="fw-bold">@campaign.Name</div>
                <div class="small text-muted">@campaign.Description</div>
              </td>
              <td>@campaign.Steps.Count</td>
              <td>@campaign.Enrollments.Count(e => e.Status == IPRO.Entities.DripCampaignEnrollmentStatus.Active)</td>
              <td><span class="badge @(campaign.IsActive ? "bg-success" : "bg-secondary")">@(campaign.IsActive ? "Active" : "Paused")</span></td>
              <td class="text-end"><a href="/Campaigns/Details/@campaign.Id" class="btn btn-sm btn-primary"><i class="fas fa-edit me-1"></i>Manage</a></td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>
