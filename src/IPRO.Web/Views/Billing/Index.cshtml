@{
    ViewData["Title"] = "Billing & Subscription";
    var packageList = ((ViewBag.Packages as IEnumerable<IPRO.Entities.BillingRule>) ?? Enumerable.Empty<IPRO.Entities.BillingRule>())
        .OrderBy(GetPackageRank)
        .ThenBy(p => p.MonthlyPrice <= 0 ? decimal.MaxValue : p.MonthlyPrice)
        .ToList();
    var subscription = ViewBag.Subscription as IPRO.Entities.Billing;
    var pendingChange = ViewBag.PendingChange as IPRO.Entities.SubscriptionChange;
    var invoices = ViewBag.Invoices as IEnumerable<IPRO.Entities.Invoice>;
    var allFeatures = ((ViewBag.PackageFeatures as IEnumerable<IPRO.Entities.PackageFeature>) ?? Enumerable.Empty<IPRO.Entities.PackageFeature>()).ToList();
    var featureRows = allFeatures
        .GroupBy(f => f.FeatureCode)
        .Select(g => g.OrderBy(f => f.SortOrder).First())
        .OrderBy(f => f.SortOrder)
        .ThenBy(f => f.FeatureName)
        .ToList();
    var currentPackage = subscription == null ? null : packageList.FirstOrDefault(p => p.Id == subscription.BillingRuleId);
    var pendingPackage = pendingChange == null ? null : packageList.FirstOrDefault(p => p.Id == pendingChange.RequestedBillingRuleId);
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <h2 class="fw-bold mb-1"><i class="fas fa-credit-card me-2 text-primary"></i>Billing &amp; Subscription</h2>
    <p class="text-muted mb-0">Choose your package, compare included functions, and upgrade or downgrade when your needs change.</p>
  </div>
</div>

@if (subscription != null && currentPackage != null)
{
  <div class="alert alert-success border-0 shadow-sm mb-4 d-flex align-items-center gap-3">
    <i class="fas fa-check-circle fa-2x"></i>
    <div class="flex-grow-1">
      <div class="fw-bold">Current package: @currentPackage.PackageName</div>
      <small>Next billing: @(subscription.NextBillingDate?.ToString("MMMM d, yyyy") ?? "-") - $@subscription.Amount.ToString("N2") @subscription.Currency</small>
    </div>
    <form asp-action="CancelSubscription" method="post">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-outline-danger btn-sm" data-confirm="Cancel your subscription? Your site will go offline at the end of the billing period.">Cancel Subscription</button>
    </form>
  </div>
}

@if (pendingChange != null && pendingPackage != null)
{
  <div class="alert alert-info border-0 shadow-sm mb-4 d-flex align-items-center gap-3">
    <i class="fas fa-calendar-check fa-2x"></i>
    <div>
      <div class="fw-bold">Scheduled package change</div>
      <small>Your @pendingChange.ChangeType.ToString().ToLowerInvariant() to @pendingPackage.PackageName will take effect on @pendingChange.EffectiveDate.ToString("MMMM d, yyyy").</small>
    </div>
  </div>
}
else
{
  <div class="alert alert-warning border-0 shadow-sm mb-4">
    <i class="fas fa-exclamation-triangle me-2"></i>
    <strong>No active subscription.</strong> Choose a package below to activate your website.
  </div>
}

@if (packageList.Any())
{
  <div class="card border-0 shadow-sm mb-5">
    <div class="table-responsive">
      <table class="table package-comparison align-middle mb-0">
        <thead>
          <tr>
            <th class="feature-col">
              <div class="fs-5 fw-bold">Compare packages</div>
              <div class="text-muted fw-normal small">Functions included by plan</div>
            </th>
            @foreach (var pkg in packageList)
            {
              var isCurrent = subscription?.BillingRuleId == pkg.Id;
              var isPending = pendingChange?.RequestedBillingRuleId == pkg.Id;
              var isContactPackage = pkg.MonthlyPrice <= 0;
              <th class="text-center package-col @(isCurrent ? "current-package" : "")">
                @if (isCurrent)
                {
                  <span class="badge bg-primary mb-2">Current Plan</span>
                }
                @if (isPending)
                {
                  <span class="badge bg-info text-dark mb-2 ms-1">Scheduled</span>
                }
                <div class="h5 fw-bold mb-1">@pkg.PackageName</div>
                @if (isContactPackage)
                {
                  <div class="h4 text-primary fw-bold my-2">Contact Us</div>
                }
                else
                {
                  <div class="display-6 text-primary fw-bold my-2">$@pkg.MonthlyPrice.ToString("N0")<span class="fs-6 text-muted fw-normal">/mo</span></div>
                  <div class="small text-muted">@(pkg.AnnualPrice > 0 ? $"${pkg.AnnualPrice:N0} annually" : "Annual billing not set")</div>
                }
                <div class="mt-3">
                  @{
                    var actionText = GetActionText(pkg, currentPackage, subscription);
                  }
                  @if (isCurrent)
                  {
                    <button class="btn btn-outline-secondary btn-sm w-100" disabled>Current Plan</button>
                  }
                  else if (isPending)
                  {
                    <button class="btn btn-outline-secondary btn-sm w-100" disabled>Scheduled</button>
                  }
                  else if (isContactPackage)
                  {
                    <a href="mailto:support@iproadvisers.com?subject=Broker%20Package%20Inquiry" class="btn btn-outline-primary btn-sm w-100">Contact Us</a>
                  }
                  else
                  {
                    <form asp-action="Subscribe" method="post" class="d-grid gap-2">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="billingRuleId" value="@pkg.Id"/>
                      <button type="submit" name="period" value="Monthly" class="btn btn-primary btn-sm w-100">@actionText Monthly</button>
                      @if (pkg.AnnualPrice > 0)
                      {
                        <button type="submit" name="period" value="Annually" class="btn btn-outline-primary btn-sm w-100">@actionText Annually</button>
                      }
                    </form>
                  }
                </div>
              </th>
            }
          </tr>
        </thead>
        <tbody>
          @foreach (var feature in featureRows)
          {
            <tr>
              <td class="feature-name">@feature.FeatureName</td>
              @foreach (var pkg in packageList)
              {
                var packageFeature = allFeatures.FirstOrDefault(f => f.BillingRuleId == pkg.Id && f.FeatureCode == feature.FeatureCode);
                <td class="text-center">
                  @RenderFeatureValue(packageFeature)
                </td>
              }
            </tr>
          }
        </tbody>
      </table>
    </div>
  </div>
}
else
{
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5 text-muted">
      No active billing packages are available yet.
    </div>
  </div>
}

@if (invoices != null && invoices.Any())
{
  <h5 class="fw-bold mb-3">Invoice History</h5>
  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead><tr><th>Invoice #</th><th>Date</th><th>Subtotal</th><th>Tax (HST)</th><th>Total</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (var inv in invoices)
        {
          <tr>
            <td class="fw-semibold small">@inv.InvoiceNumber</td>
            <td><small class="text-muted">@inv.IssuedAt.ToString("MMM d, yyyy")</small></td>
            <td>$@inv.SubTotal.ToString("N2")</td>
            <td>$@inv.TaxAmount.ToString("N2")</td>
            <td class="fw-bold">$@inv.Total.ToString("N2") <small class="text-muted">@inv.Currency</small></td>
            <td><span class="badge @(inv.IsPaid ? "bg-success" : "bg-warning text-dark")">@(inv.IsPaid ? "Paid" : "Unpaid")</span></td>
          </tr>
        }
        </tbody>
      </table>
    </div>
  </div>
}

<style>
  .package-comparison th,
  .package-comparison td { border-color: #e5e7eb; }
  .package-comparison thead th { background: #f8fafc; vertical-align: top; }
  .package-comparison tbody tr:nth-child(odd) td { background: #f9fafb; }
  .package-comparison .feature-col { min-width: 280px; width: 30%; }
  .package-comparison .package-col { min-width: 220px; }
  .package-comparison .feature-name { font-weight: 600; color: #1f2937; }
  .package-comparison .current-package { background: #eff6ff !important; box-shadow: inset 0 3px 0 #2563eb; }
  .package-comparison .feature-check { color: #16a34a; font-size: 1.15rem; }
  .package-comparison .feature-miss { color: #dc2626; font-size: 1.15rem; }
</style>

@functions {
    private static int GetPackageRank(IPRO.Entities.BillingRule package) => package.PackageName switch
    {
        "IPro Silver" => 1,
        "IPro Gold" => 2,
        "IPro Platinum" => 3,
        "Broker Package" => 4,
        _ => 50
    };

    private static string GetActionText(IPRO.Entities.BillingRule package, IPRO.Entities.BillingRule? currentPackage, IPRO.Entities.Billing? subscription)
    {
        if (subscription == null || currentPackage == null)
        {
            return "Subscribe";
        }

        if (package.Id == currentPackage.Id)
        {
            return "Current Plan";
        }

        if (package.MonthlyPrice > currentPackage.MonthlyPrice)
        {
            return "Upgrade";
        }

        return "Downgrade";
    }

    private Microsoft.AspNetCore.Html.IHtmlContent RenderFeatureValue(IPRO.Entities.PackageFeature? feature)
    {
        if (feature?.IsIncluded != true)
        {
            return new Microsoft.AspNetCore.Html.HtmlString("<i class=\"fas fa-times feature-miss\"></i>");
        }

        if (!string.IsNullOrWhiteSpace(feature.LimitLabel))
        {
            return new Microsoft.AspNetCore.Html.HtmlString(System.Net.WebUtility.HtmlEncode(feature.LimitLabel));
        }

        if (feature.LimitValue == -1)
        {
            return new Microsoft.AspNetCore.Html.HtmlString("Unlimited");
        }

        if (feature.LimitValue.HasValue)
        {
            return new Microsoft.AspNetCore.Html.HtmlString(feature.LimitValue.Value.ToString("N0"));
        }

        return new Microsoft.AspNetCore.Html.HtmlString("<i class=\"fas fa-check feature-check\"></i>");
    }

}
