@{
    ViewData["Title"] = "Check Your Email";
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Check Your Email - IPRO Advisers</title>
<style>
body{margin:0;min-height:100vh;background:linear-gradient(135deg,#193f82,#1f6bf2);font-family:Arial,Helvetica,sans-serif;display:flex;align-items:center;justify-content:center;color:#111827;}
.card{width:420px;background:#fff;border-radius:12px;padding:34px;box-shadow:0 20px 48px rgba(0,0,0,.24);}
h1{font-size:24px;margin:0 0 8px;text-align:center;}
p{text-align:center;color:#4b5563;margin:0 0 8px;}
.back{display:block;text-align:center;margin-top:22px;color:#0d6efd;text-decoration:none;font-size:14px;}
</style>
</head>
<body>
<main class="card">
  <h1>Check Your Email</h1>
  <p>If that email is registered with us, we've sent a link to reset your password.</p>
  <p>The link expires in 1 hour.</p>
  <a class="back" href="/Account/Login">Back to Sign In</a>
</main>
</body>
</html>
