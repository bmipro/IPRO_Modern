@model IPRO.Web.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = null;
    var tokenValid = ViewBag.TokenValid is bool b && b;
}
<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Reset Password - IPRO Advisers</title>
<style>
body{margin:0;min-height:100vh;background:linear-gradient(135deg,#193f82,#1f6bf2);font-family:Arial,Helvetica,sans-serif;display:flex;align-items:center;justify-content:center;color:#111827;}
.card{width:420px;background:#fff;border-radius:12px;padding:34px;box-shadow:0 20px 48px rgba(0,0,0,.24);}
h1{font-size:24px;margin:0 0 8px;text-align:center;}
p{text-align:center;color:#4b5563;margin:0 0 24px;}
.validation{background:#fff1f1;border:1px solid #f3b2b2;color:#8a0000;padding:10px;margin-bottom:16px;border-radius:6px;}
label{display:block;font-weight:bold;margin:14px 0 6px;}
input{box-sizing:border-box;width:100%;height:42px;border:1px solid #cbd5e1;border-radius:6px;padding:8px 10px;font-size:15px;}
button{width:100%;margin-top:22px;height:44px;border:0;border-radius:6px;background:#0d6efd;color:#fff;font-size:16px;font-weight:bold;cursor:pointer;}
.back{display:block;text-align:center;margin-top:18px;color:#0d6efd;text-decoration:none;font-size:14px;}
</style>
</head>
<body>
<main class="card">
@if (!tokenValid)
{
  <h1>Link Invalid or Expired</h1>
  <p>This password reset link is no longer valid. Request a new one below.</p>
  <a class="back" href="/Account/ForgotPassword">Request a New Link</a>
}
else
{
  <h1>Reset Your Password</h1>
  <p>Choose a new password for your account.</p>
  @if (!ViewData.ModelState.IsValid)
  {
    <div class="validation">@Html.ValidationSummary()</div>
  }
  <form method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="token" value="@Model.Token" />
    <label>New Password</label>
    <input type="password" name="newPassword" minlength="8" required autofocus/>
    <label>Confirm Password</label>
    <input type="password" name="confirmPassword" minlength="8" required/>
    <button type="submit">Update Password</button>
  </form>
}
</main>
</body>
</html>
