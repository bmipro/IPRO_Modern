@model IPRO.Entities.AgentWebsite?
@{
    ViewData["Title"] = "My Website";
    var templates = (ViewBag.Templates as IEnumerable<IPRO.Entities.WebsiteTemplate> ?? Enumerable.Empty<IPRO.Entities.WebsiteTemplate>()).ToList();
    var temporaryDomain = ViewBag.TemporaryDomain as string ?? "";
    var dnsTarget = ViewBag.WebsiteDnsTarget as string ?? "ipro-prod-web.azurewebsites.net";
    var siteTitle = Model?.SiteTitle ?? "";
    var tagLine = Model?.TagLine ?? "";
    var customDomain = Model?.CustomDomain ?? "";
    var themeColor = string.IsNullOrWhiteSpace(Model?.ThemeColor) ? "#1457d9" : Model!.ThemeColor;
    var selectedTemplateId = Model?.TemplateId ?? templates.FirstOrDefault()?.Id ?? 0;
    var selectedTemplate = templates.FirstOrDefault(t => t.Id == selectedTemplateId);
    var fontFamilyOverride = Model?.FontFamilyOverride ?? "";
    var headingFontSizeOverride = Model?.HeadingFontSizeOverride ?? 0;
    var bodyFontSizeOverride = Model?.BodyFontSizeOverride ?? 0;
    var backgroundColorOverride = Model?.BackgroundColorOverride ?? "";
    var buttonStyleOverride = Model?.ButtonStyleOverride ?? "";
    var sectionSpacingOverride = Model?.SectionSpacingOverride ?? "";
    var heroStyleOverride = Model?.HeroStyleOverride ?? "";
    var selectedDesign = IPRO.Entities.WebsiteTemplateDesign.FromTemplate(selectedTemplate, new IPRO.Entities.AgentDesignOverrides
    {
        ThemeColor = themeColor,
        FontFamily = fontFamilyOverride,
        HeadingFontSize = headingFontSizeOverride,
        BodyFontSize = bodyFontSizeOverride,
        BackgroundColor = backgroundColorOverride,
        ButtonStyle = buttonStyleOverride,
        SectionSpacing = sectionSpacingOverride,
        HeroStyle = heroStyleOverride
    });
    var isPublished = Model?.IsPublished == true;
    var liveDomain = string.IsNullOrWhiteSpace(customDomain) ? temporaryDomain : customDomain;
    var templateDesigns = templates.ToDictionary(t => t.Id, t => IPRO.Entities.WebsiteTemplateDesign.FromTemplate(t));
    var primaryDomain = ViewBag.PrimaryDomain as IPRO.Entities.AgentDomain;
    var agentDomains = (ViewBag.AgentDomains as IEnumerable<IPRO.Entities.AgentDomain> ?? Enumerable.Empty<IPRO.Entities.AgentDomain>()).ToList();
    var domainAccess = ViewBag.DomainAccess as IPRO.Business.Interfaces.PackageFeatureAccess;
    var domainLimit = domainAccess?.LimitValue;
    var domainLimitText = domainLimit == -1 ? "Unlimited" : (domainLimit?.ToString() ?? "Not available");
    var canAddDomain = domainAccess?.IsIncluded == true && (domainLimit == -1 || agentDomains.Count < (domainLimit ?? 0));
    var hasCustomDomain = !string.IsNullOrWhiteSpace(customDomain);
    var dnsReady = primaryDomain?.DnsStatus == IPRO.Entities.AgentDomainStatus.DnsReady || primaryDomain?.DnsStatus == IPRO.Entities.AgentDomainStatus.Bound;
    var bindingReady = primaryDomain?.AzureBindingStatus == IPRO.Entities.AgentDomainStatus.Bound;
    var sslReady = primaryDomain?.SslStatus == IPRO.Entities.AgentDomainStatus.Bound;
    var templateRetired = ViewBag.TemplateRetired == true;
}

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2 class="fw-bold mb-1"><i class="fas fa-globe me-2 text-primary"></i>My Website</h2>
    <div class="text-muted">Manage your website design, publishing, and custom domain setup.</div>
  </div>
  <div class="d-flex gap-2">
    <a href="/WebsitePages/Navigation" class="btn btn-outline-primary"><i class="fas fa-bars-staggered me-1"></i>Header & Menu</a>
    <a href="/WebsitePages/Footer" class="btn btn-outline-primary"><i class="fas fa-shoe-prints me-1"></i>Footer</a>
    <a href="/WebsitePages" class="btn btn-primary"><i class="fas fa-file-lines me-1"></i>Manage Pages</a>
    @if (!string.IsNullOrWhiteSpace(liveDomain))
    {
      <a href="https://@liveDomain" target="_blank" class="btn btn-outline-primary"><i class="fas fa-up-right-from-square me-1"></i>Open Website</a>
    }
    @if (isPublished)
    {
      <form asp-action="Unpublish" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-outline-warning"><i class="fas fa-pause me-1"></i>Take Offline</button>
      </form>
    }
    else
    {
      <form asp-action="Publish" method="post">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-success"><i class="fas fa-rocket me-1"></i>Publish</button>
      </form>
    }
  </div>
</div>

<div class="alert @(isPublished ? "alert-success" : "alert-warning") border-0 shadow-sm mb-4">
  <div class="d-flex align-items-start gap-3">
    <i class="fas @(isPublished ? "fa-circle-check" : "fa-circle-info") fs-4 mt-1"></i>
    <div>
      <strong>@(isPublished ? "Your website is published." : "Your website is not published yet.")</strong>
      <div class="small mt-1">
        Temporary domain:
        @if (!string.IsNullOrWhiteSpace(temporaryDomain))
        {
          <a href="https://@temporaryDomain" target="_blank" class="alert-link">@temporaryDomain</a>
        }
        else
        {
          <span class="text-muted">not assigned</span>
        }
      </div>
    </div>
  </div>
</div>

@if (templateRetired)
{
  <div class="alert alert-warning border-0 shadow-sm mb-4">
    <div class="d-flex gap-3 align-items-start">
      <i class="fas fa-triangle-exclamation fs-4 mt-1"></i>
      <div><strong>Your current template has been retired.</strong><div class="small mt-1">Your website remains online and unchanged. Preview and select an active template when you are ready to move.</div></div>
    </div>
  </div>
}

<div class="row g-4">
  <div class="col-xl-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0"><i class="fas fa-paintbrush me-2 text-primary"></i>Website Settings</h5>
      </div>
      <div class="card-body p-4">
        <form asp-action="Save" method="post" enctype="multipart/form-data">
          @Html.AntiForgeryToken()
          @if (Model != null)
          {
            <input type="hidden" name="Id" value="@Model.Id" />
          }

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label fw-semibold">Site Title</label>
              <input name="SiteTitle" class="form-control" value="@siteTitle" placeholder="John Smith Insurance Adviser" required />
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Color Palettes</label>
              <div class="palette-picker" role="group" aria-label="Color palettes">
                <button type="button" class="palette-swatch" data-accent="#1457d9" data-background="#f4f7fb" style="--swatch-accent:#1457d9;--swatch-bg:#f4f7fb" title="Ocean Blue" aria-label="Ocean Blue"></button>
                <button type="button" class="palette-swatch" data-accent="#d9541f" data-background="#fdf6f0" style="--swatch-accent:#d9541f;--swatch-bg:#fdf6f0" title="Sunset Orange" aria-label="Sunset Orange"></button>
                <button type="button" class="palette-swatch" data-accent="#1f7a4d" data-background="#f2f8f4" style="--swatch-accent:#1f7a4d;--swatch-bg:#f2f8f4" title="Forest Green" aria-label="Forest Green"></button>
                <button type="button" class="palette-swatch" data-accent="#4b5563" data-background="#f5f6f7" style="--swatch-accent:#4b5563;--swatch-bg:#f5f6f7" title="Slate Gray" aria-label="Slate Gray"></button>
                <button type="button" class="palette-swatch" data-accent="#7a1f3d" data-background="#faf3f5" style="--swatch-accent:#7a1f3d;--swatch-bg:#faf3f5" title="Burgundy" aria-label="Burgundy"></button>
                <button type="button" class="palette-swatch" data-accent="#5b2f9e" data-background="#f6f3fb" style="--swatch-accent:#5b2f9e;--swatch-bg:#f6f3fb" title="Royal Purple" aria-label="Royal Purple"></button>
                <button type="button" class="palette-swatch" data-accent="#b8892b" data-background="#f8f6f0" style="--swatch-accent:#b8892b;--swatch-bg:#f8f6f0" title="Amber Gold" aria-label="Amber Gold"></button>
                <button type="button" class="palette-swatch" data-accent="#0f8c8c" data-background="#f0f9f9" style="--swatch-accent:#0f8c8c;--swatch-bg:#f0f9f9" title="Teal" aria-label="Teal"></button>
              </div>
              <div class="form-text">Click a palette to set both colors at once, then fine-tune below if needed.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Theme Color</label>
              <div class="input-group">
                <input name="ThemeColor" id="ThemeColor" type="color" class="form-control form-control-color" value="@themeColor" style="width:64px" />
                <input id="themeHex" type="text" class="form-control" value="@themeColor" readonly />
              </div>
              <div class="form-text">Your color and style choices stay in place when you switch templates. Use <strong>Reset to Template Defaults</strong> below if you want this template's suggested look instead.</div>
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Tagline</label>
              <input name="TagLine" class="form-control" value="@tagLine" placeholder="Helping families and businesses plan with confidence" />
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Font Family</label>
              <select name="FontFamilyOverride" class="form-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(fontFamilyOverride) ? "selected" : null)">Match template default</option>
                <option value="Arial, Helvetica, sans-serif" selected="@(fontFamilyOverride.Contains("Arial") ? "selected" : null)">Clean Sans</option>
                <option value="Georgia, 'Times New Roman', serif" selected="@(fontFamilyOverride.Contains("Georgia") ? "selected" : null)">Editorial Serif</option>
                <option value="'Segoe UI', Arial, Helvetica, sans-serif" selected="@(fontFamilyOverride.Contains("Segoe") ? "selected" : null)">Modern UI</option>
                <option value="'Times New Roman', Times, serif" selected="@(fontFamilyOverride.Contains("Times New Roman") ? "selected" : null)">Times New Roman</option>
              </select>
              <div class="form-text">Applies to section headings and body text, not the hero banner title.</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Heading Font Size (px)</label>
              <input name="HeadingFontSizeOverride" type="number" min="14" max="40" class="form-control" value="@(headingFontSizeOverride > 0 ? headingFontSizeOverride : selectedDesign.HeadingFontSize)" />
            </div>
            <div class="col-md-4">
              <label class="form-label fw-semibold">Body Font Size (px)</label>
              <input name="BodyFontSizeOverride" type="number" min="12" max="24" class="form-control" value="@(bodyFontSizeOverride > 0 ? bodyFontSizeOverride : selectedDesign.BodyFontSize)" />
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold">Background Color</label>
              <div class="input-group">
                <input name="BackgroundColorOverride" id="BackgroundColorOverride" type="color" class="form-control form-control-color" value="@(string.IsNullOrWhiteSpace(backgroundColorOverride) ? selectedDesign.BackgroundColor : backgroundColorOverride)" style="width:64px" />
              </div>
              <div class="form-text">Page background behind your content.</div>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold">Button Style</label>
              <select name="ButtonStyleOverride" class="form-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(buttonStyleOverride) ? "selected" : null)">Match template default</option>
                <option value="square" selected="@(buttonStyleOverride == "square" ? "selected" : null)">Square</option>
                <option value="soft" selected="@(buttonStyleOverride == "soft" ? "selected" : null)">Soft corners</option>
                <option value="pill" selected="@(buttonStyleOverride == "pill" ? "selected" : null)">Pill</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold">Section Spacing</label>
              <select name="SectionSpacingOverride" class="form-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(sectionSpacingOverride) ? "selected" : null)">Match template default</option>
                <option value="compact" selected="@(sectionSpacingOverride == "compact" ? "selected" : null)">Compact</option>
                <option value="comfortable" selected="@(sectionSpacingOverride == "comfortable" ? "selected" : null)">Comfortable</option>
                <option value="spacious" selected="@(sectionSpacingOverride == "spacious" ? "selected" : null)">Spacious</option>
              </select>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold">Hero Style</label>
              <select name="HeroStyleOverride" class="form-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(heroStyleOverride) ? "selected" : null)">Match template default</option>
                <option value="gradient" selected="@(heroStyleOverride == "gradient" ? "selected" : null)">Gradient</option>
                <option value="clean" selected="@(heroStyleOverride == "clean" ? "selected" : null)">Clean</option>
                <option value="classic" selected="@(heroStyleOverride == "classic" ? "selected" : null)">Classic</option>
              </select>
              <div class="form-text">Background treatment behind your hero banner.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Temporary Website Domain</label>
              <input class="form-control" value="@temporaryDomain" readonly />
              <div class="form-text">This domain is assigned automatically at registration.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Custom Domain</label>
              <input name="CustomDomain" class="form-control" value="@customDomain" placeholder="yourdomain.com or www.yourdomain.com" />
              <div class="form-text">This is your primary custom domain. Add extra domains from the domain manager below.</div>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-semibold">Logo</label>
              <input type="file" name="logo" class="form-control" accept="image/png,image/jpeg,image/svg+xml" />
              @if (!string.IsNullOrWhiteSpace(Model?.LogoUrl))
              {
                <div class="mt-2 d-flex align-items-center gap-2">
                  <img src="@Model.LogoUrl" style="height:42px;max-width:180px;object-fit:contain" alt="Current logo" />
                  <span class="small text-muted">Current logo</span>
                </div>
              }
            </div>
            <div class="col-12">
              <label class="form-label fw-semibold">Template</label>
              <select name="TemplateId" id="TemplateId" class="d-none" aria-hidden="true">
                @foreach (var template in templates)
                {
                  var design = templateDesigns[template.Id];
                  <option value="@template.Id"
                          data-accent="@design.AccentColor"
                          data-background="@design.BackgroundColor"
                          data-font="@design.FontFamily"
                          data-hero="@design.HeroStyle"
                          data-renderer="@design.Renderer"
                          data-header="@design.HeaderStyle"
                          data-layout="@design.HeroLayout"
                          data-spacing="@design.SectionSpacing"
                          data-button="@design.ButtonStyle"
                          data-description="@template.Description"
                          selected="@(template.Id == selectedTemplateId)">
                    @template.Name
                  </option>
                }
              </select>
              <div class="template-gallery mt-2" role="radiogroup" aria-label="Website design">
                @foreach (var template in templates)
                {
                  var design = templateDesigns[template.Id];
                  var familyName = design.Renderer == "classic-sidebar" ? "Classic Sidebar" : design.Renderer == "editorial-visual" ? "Editorial Visual" : "Modern Professional";
                  var familyCopy = design.Renderer == "classic-sidebar"
                    ? "Traditional adviser layout with a persistent profile, practical navigation, and an easy reading column."
                    : design.Renderer == "editorial-visual"
                      ? "Image-led storytelling, expressive typography, and spacious asymmetric sections."
                      : "Confident split hero, clear service cards, and conversion-focused calls to action.";
                  <article class="template-choice @(template.Id == selectedTemplateId ? "is-selected" : "")"
                           data-template-card="@template.Id"
                           style="--choice-accent:@design.AccentColor;--choice-bg:@design.BackgroundColor"
                           role="radio" aria-checked="@(template.Id == selectedTemplateId ? "true" : "false")" tabindex="0">
                    <div class="template-choice__visual family-@design.Renderer">
                      @if (!string.IsNullOrWhiteSpace(template.PreviewImageUrl))
                      {
                        <img src="@template.PreviewImageUrl" alt="@template.Name preview" />
                      }
                      else
                      {
                        <div class="template-choice__mini-nav"><span></span><i></i><i></i><i></i></div>
                        <div class="template-choice__mini-body"><strong>A better digital presence</strong><span></span><span></span><b></b></div>
                      }
                      <span class="template-choice__selected"><i class="fas fa-check me-1"></i>Selected</span>
                    </div>
                    <div class="template-choice__body">
                      <div class="template-choice__family">@familyName</div>
                      <h6>@template.Name</h6>
                      <p>@familyCopy</p>
                      <div class="d-flex gap-2 mt-auto">
                        <a href="/Website/PreviewTemplate?templateId=@template.Id&useDefaults=true" target="_blank" class="btn btn-sm btn-outline-primary template-preview-action"><i class="fas fa-eye me-1"></i>Preview</a>
                        <button type="button" class="btn btn-sm @(template.Id == selectedTemplateId ? "btn-primary" : "btn-outline-secondary") template-select-action" data-select-template="@template.Id">@(template.Id == selectedTemplateId ? "Current design" : "Choose design")</button>
                      </div>
                    </div>
                  </article>
                }
              </div>
              <div class="template-selection-bar mt-3">
                <div><span class="text-muted small">Chosen design</span><strong id="selectedTemplateName">@(selectedTemplate?.Name ?? "Choose a design")</strong><span class="small text-muted" id="selectedTemplateDescription">@(selectedTemplate?.Description ?? "")</span></div>
                <div class="template-color-note"><i class="fas fa-palette me-2"></i>Your current colors and styles stay in place when you choose a different design. Use <strong>Reset to Template Defaults</strong> below to apply this design's suggested look instead.</div>
              </div>
            </div>
            <div class="col-12">
              <div class="website-template-preview" id="websiteTemplatePreview"
                   style="--preview-accent:@themeColor;--preview-bg:@selectedDesign.BackgroundColor;--preview-font:@selectedDesign.FontFamily">
                <div class="website-template-preview__nav">
                  <strong id="previewSiteTitle">@(string.IsNullOrWhiteSpace(siteTitle) ? "Your Business" : siteTitle)</strong>
                  <span>About</span><span>Services</span><span>Contact</span>
                </div>
                <div class="website-template-preview__hero">
                  <div>
                    <span class="website-template-preview__eyebrow">Professional service</span>
                    <h3 id="previewHeadline">@(string.IsNullOrWhiteSpace(siteTitle) ? "Welcome to your website" : siteTitle)</h3>
                    <p id="previewTagline">@(string.IsNullOrWhiteSpace(tagLine) ? "Helping clients move forward with confidence." : tagLine)</p>
                    <span class="website-template-preview__button">Get in touch</span>
                  </div>
                  <div class="website-template-preview__services" aria-hidden="true">
                    <span></span><span></span><span></span>
                  </div>
                </div>
              </div>
              <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mt-2">
                <div class="form-text mt-0">Quick style preview. Use the full preview above to see your real pages and content.</div>
                <a id="previewSelectedTemplate" href="/Website/PreviewTemplate?templateId=@selectedTemplateId" target="_blank" class="btn btn-sm btn-outline-primary"><i class="fas fa-up-right-from-square me-1"></i>Open full preview</a>
              </div>
            </div>
          </div>

          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary btn-lg"><i class="fas fa-save me-2"></i>Save Website Settings</button>
            <button type="submit" name="applyTemplateDefaults" value="true" class="btn btn-outline-secondary btn-lg" onclick="return confirm('Replace your theme color, font, background, button style, section spacing, and hero style with this template\'s suggested defaults?');"><i class="fas fa-rotate-left me-2"></i>Reset to Template Defaults</button>
            @if (!isPublished)
            {
              <button type="submit" formaction="/Website/Publish" formmethod="post" class="btn btn-success btn-lg"><i class="fas fa-rocket me-2"></i>Publish</button>
            }
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-xl-4">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="fas fa-route me-2 text-primary"></i>Custom Domain Setup</h5>
        <div class="small text-muted mb-3">For GoDaddy or another registrar, keep nameservers as-is and add DNS for the www host. Root domains can forward to www.</div>

        <div class="border rounded-3 p-3">
          <div class="fw-bold mb-2">Custom agent domain</div>
          <div class="small text-muted mb-2">For a domain like www.mragent.com:</div>
          <div class="bg-light rounded p-3 font-monospace small">
            CNAME&nbsp;&nbsp;www&nbsp;&nbsp;@dnsTarget
          </div>
          <div class="small text-muted mt-2">If the agent enters mragent.com, we will save it as www.mragent.com. Forward the root domain to www when the registrar supports forwarding.</div>
        </div>
        <div class="border rounded-3 p-3 mt-3">
          <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
            <div>
              <div class="fw-bold">Domain manager</div>
              <div class="small text-muted">Package allowance: @domainLimitText domain(s)</div>
            </div>
            <span class="badge bg-light text-dark">@agentDomains.Count used</span>
          </div>

          <form method="post" action="/Website/AddDomain" class="mb-3">
            @Html.AntiForgeryToken()
            <label class="form-label small fw-semibold">Add another domain</label>
            <div class="input-group">
              <input name="domainName" class="form-control" placeholder="example.com or www.example.com" @(canAddDomain ? "" : "disabled") />
              <button class="btn btn-outline-primary" type="submit" @(canAddDomain ? "" : "disabled")>Add</button>
            </div>
            @if (domainAccess?.IsIncluded != true)
            {
              <div class="form-text text-danger">@domainAccess?.UpgradeMessage</div>
            }
            else if (!canAddDomain)
            {
              <div class="form-text text-danger">Your package domain limit has been reached.</div>
            }
          </form>

          @if (!agentDomains.Any())
          {
            <div class="text-muted small">No custom domains have been added yet.</div>
          }
          @foreach (var domain in agentDomains)
          {
            var domainDnsReady = domain.DnsStatus == IPRO.Entities.AgentDomainStatus.DnsReady || domain.DnsStatus == IPRO.Entities.AgentDomainStatus.Bound;
            var domainBindingReady = domain.AzureBindingStatus == IPRO.Entities.AgentDomainStatus.Bound;
            var domainDnsLabel = domainDnsReady ? "Ready" : "Waiting for DNS propagation";
            <div class="border rounded-3 p-2 mb-2">
              <div class="d-flex justify-content-between gap-2">
                <div>
                  <div class="fw-semibold">@domain.DomainName @(domain.IsPrimary ? Html.Raw("<span class=\"badge bg-primary ms-1\">Primary</span>") : "")</div>
                  <div class="small text-muted">DNS: <span class="@(domainDnsReady ? "text-success" : "text-warning")">@domainDnsLabel</span> &middot; Azure: <span class="@(domainBindingReady ? "text-success" : "text-muted")">@domain.AzureBindingStatus</span></div>
                  @if (!string.IsNullOrWhiteSpace(domain.LastError))
                  {
                    <div class="small @(domainDnsReady ? "text-danger" : "text-muted")">@IPRO.Utility.DomainErrorTranslator.ToAgentMessage(domain.LastError)</div>
                  }
                  @if (!string.IsNullOrWhiteSpace(domain.RootDomain) && !string.Equals(domain.RootDomain, domain.DomainName, StringComparison.OrdinalIgnoreCase))
                  {
                    <div class="small mt-1">Root domain (@domain.RootDomain): <span class="badge @(domain.RootRedirectsToWww ? "bg-success" : "bg-light text-dark")">@(domain.RootRedirectsToWww ? "Forwarding OK" : "Not forwarding")</span></div>
                  }
                </div>
                <div class="d-flex gap-1 align-items-start">
                  @if (!domain.IsPrimary)
                  {
                    <form method="post" action="/Website/SetPrimaryDomain/@domain.Id">
                      @Html.AntiForgeryToken()
                      <button class="btn btn-sm btn-outline-primary" type="submit">Primary</button>
                    </form>
                  }
                  <form method="post" action="/Website/RetryDomain/@domain.Id">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-outline-secondary" type="submit" title="Recheck this domain now">Retry</button>
                  </form>
                  <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#removeDomainModal-@domain.Id">Remove</button>
                </div>
              </div>
            </div>
            <div class="modal fade" id="removeDomainModal-@domain.Id" tabindex="-1" aria-hidden="true">
              <div class="modal-dialog">
                <div class="modal-content">
                  <form method="post" action="/Website/RemoveDomain/@domain.Id">
                    @Html.AntiForgeryToken()
                    <div class="modal-header"><h5 class="modal-title">Remove @domain.DomainName?</h5></div>
                    <div class="modal-body">
                      <p class="text-danger small">This cannot be undone. Type <strong>@domain.DomainName</strong> to confirm.</p>
                      <input type="text" name="confirmDomainName" class="form-control" required autocomplete="off" />
                    </div>
                    <div class="modal-footer">
                      <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                      <button type="submit" class="btn btn-danger">Remove Domain</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          }
        </div>
        @if (primaryDomain != null)
        {
          <div class="border rounded-3 p-3 mt-3">
            <div class="fw-bold mb-2">Domain automation status</div>
            <div class="d-flex justify-content-between small mb-2">
              <span>DNS check</span>
              <span class="badge @(dnsReady ? "bg-success" : "bg-warning text-dark")">@(dnsReady ? "Ready" : "Waiting for DNS")</span>
            </div>
            <div class="d-flex justify-content-between small mb-2">
              <span>Azure binding</span>
              <span class="badge @(bindingReady ? "bg-success" : "bg-secondary")">@primaryDomain.AzureBindingStatus</span>
            </div>
            <div class="d-flex justify-content-between small mb-2">
              <span>SSL</span>
              <span class="badge @(sslReady ? "bg-success" : "bg-secondary")">@primaryDomain.SslStatus</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(primaryDomain.RootDomain) && !string.Equals(primaryDomain.RootDomain, primaryDomain.DomainName, StringComparison.OrdinalIgnoreCase))
            {
              <div class="d-flex justify-content-between small mb-2">
                <span>Root domain (@primaryDomain.RootDomain)</span>
                <span class="badge @(primaryDomain.RootRedirectsToWww ? "bg-success" : "bg-light text-dark")">@(primaryDomain.RootRedirectsToWww ? "Forwarding OK" : "Not forwarding")</span>
              </div>
              @if (!string.IsNullOrWhiteSpace(primaryDomain.RootLastError))
              {
                <div class="small text-muted mb-2">@primaryDomain.RootLastError</div>
              }
            }
            @if (primaryDomain.LastCheckedAt.HasValue)
            {
              <div class="small text-muted">Last checked: @primaryDomain.LastCheckedAt.Value.ToLocalTime().ToString("MMM d, h:mm tt")</div>
            }
            @if (!string.IsNullOrWhiteSpace(primaryDomain.LastError))
            {
              <div class="small @(dnsReady ? "text-danger" : "text-muted") mt-2">@IPRO.Utility.DomainErrorTranslator.ToAgentMessage(primaryDomain.LastError)</div>
            }
          </div>
        }
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="fas fa-list-check me-2 text-success"></i>Checklist</h5>
        <ul class="list-unstyled small mb-0">
          <li class="mb-2 @(string.IsNullOrWhiteSpace(siteTitle) ? "text-muted" : "text-success")"><i class="fas @(string.IsNullOrWhiteSpace(siteTitle) ? "fa-circle" : "fa-circle-check") me-2"></i>Site title set</li>
          <li class="mb-2 @(selectedTemplateId <= 0 ? "text-muted" : "text-success")"><i class="fas @(selectedTemplateId <= 0 ? "fa-circle" : "fa-circle-check") me-2"></i>Template selected</li>
          <li class="mb-2 @(string.IsNullOrWhiteSpace(temporaryDomain) ? "text-muted" : "text-success")"><i class="fas @(string.IsNullOrWhiteSpace(temporaryDomain) ? "fa-circle" : "fa-circle-check") me-2"></i>Temporary domain assigned</li>
          <li class="mb-2 @(isPublished ? "text-success" : "text-muted")"><i class="fas @(isPublished ? "fa-circle-check" : "fa-circle") me-2"></i>Website published</li>
          <li class="mb-2 @(hasCustomDomain ? "text-success" : "text-muted")"><i class="fas @(hasCustomDomain ? "fa-circle-check" : "fa-circle") me-2"></i>Custom domain requested</li>
          <li class="mb-2 @(dnsReady ? "text-success" : "text-muted")"><i class="fas @(dnsReady ? "fa-circle-check" : "fa-circle") me-2"></i>DNS detected</li>
          <li class="@(bindingReady ? "text-success" : "text-muted")"><i class="fas @(bindingReady ? "fa-circle-check" : "fa-circle") me-2"></i>Azure domain binding complete</li>
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
.palette-picker { display:flex; flex-wrap:wrap; gap:10px; margin-bottom:4px; }
.palette-swatch { width:34px; height:34px; padding:0; border-radius:50%; border:2px solid #fff; box-shadow:0 0 0 1px #d6deea; cursor:pointer; background:linear-gradient(135deg, var(--swatch-accent) 50%, var(--swatch-bg) 50%); }
.palette-swatch:hover, .palette-swatch:focus-visible { box-shadow:0 0 0 2px var(--swatch-accent); outline:0; }
.template-gallery { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; }
.template-choice { display:flex; flex-direction:column; min-width:0; overflow:hidden; border:2px solid #dbe3ed; border-radius:8px; background:#fff; cursor:pointer; transition:border-color .15s ease,box-shadow .15s ease; }
.template-choice:hover { border-color:#9cb8e8; box-shadow:0 10px 26px rgba(18,48,92,.1); }
.template-choice.is-selected { border-color:#1769e8; box-shadow:0 0 0 3px rgba(23,105,232,.12); }
.template-choice__visual { position:relative; height:176px; overflow:hidden; background:var(--choice-bg); border-bottom:1px solid #e1e7ef; }
.template-choice__visual img { width:100%; height:100%; object-fit:cover; }
.template-choice__mini-nav { display:flex; align-items:center; gap:8px; height:34px; padding:0 13px; background:#fff; border-bottom:1px solid #e5eaf0; }
.template-choice__mini-nav span { width:42px; height:7px; margin-right:auto; border-radius:3px; background:var(--choice-accent); }
.template-choice__mini-nav i { width:20px; height:4px; background:#29364b; }
.template-choice__mini-body { height:142px; padding:26px 20px; background:linear-gradient(120deg,#fff 0 58%,var(--choice-accent) 58% 100%); }
.template-choice__mini-body strong { display:block; max-width:150px; color:#172033; font-size:16px; line-height:1.15; }
.template-choice__mini-body span { display:block; width:42%; height:5px; margin-top:9px; background:#bec8d6; }
.template-choice__mini-body b { display:block; width:54px; height:18px; margin-top:16px; border-radius:3px; background:var(--choice-accent); }
.template-choice__visual.family-classic-sidebar .template-choice__mini-nav { width:34%; height:100%; float:left; flex-direction:column; align-items:stretch; padding:18px 11px; background:#17243b; }
.template-choice__visual.family-classic-sidebar .template-choice__mini-nav span { width:100%; margin:0 0 16px; }
.template-choice__visual.family-classic-sidebar .template-choice__mini-nav i { width:100%; background:#fff; opacity:.65; }
.template-choice__visual.family-classic-sidebar .template-choice__mini-body { margin-left:34%; height:100%; background:#f6f8fb; padding-top:34px; }
.template-choice__visual.family-editorial-visual .template-choice__mini-body { background:linear-gradient(90deg,#fff 0 48%,var(--choice-accent) 48% 100%); padding:32px 18px; }
.template-choice__visual.family-editorial-visual .template-choice__mini-body strong { font-family:Georgia,serif; font-size:20px; }
.template-choice__selected { display:none; position:absolute; top:10px; right:10px; padding:5px 8px; border-radius:4px; background:#1769e8; color:#fff; font-size:11px; font-weight:800; }
.template-choice.is-selected .template-choice__selected { display:block; }
.template-choice__body { display:flex; flex:1; flex-direction:column; padding:16px; }
.template-choice__family { color:#1769e8; font-size:11px; font-weight:800; text-transform:uppercase; }
.template-choice__body h6 { margin:5px 0 7px; font-weight:800; }
.template-choice__body p { color:#637188; font-size:13px; line-height:1.45; }
.template-selection-bar { display:flex; align-items:center; justify-content:space-between; gap:18px; padding:13px 15px; border:1px solid #dbe3ed; border-radius:8px; background:#f7f9fc; }
.template-selection-bar strong,.template-selection-bar span { display:block; }
.template-color-note { max-width:330px; color:#52627a; font-size:12px; line-height:1.45; }
.website-template-preview {
  overflow: hidden;
  min-height: 250px;
  border: 1px solid #dce3ec;
  border-radius: 8px;
  background: var(--preview-bg);
  color: #172033;
  font-family: var(--preview-font);
}
.website-template-preview__nav {
  display: flex;
  align-items: center;
  gap: 18px;
  min-height: 54px;
  padding: 12px 20px;
  background: #fff;
  border-bottom: 1px solid #e8edf3;
  font-size: 13px;
}
.website-template-preview__nav strong { margin-right: auto; color: var(--preview-accent); font-size: 16px; }
.website-template-preview__hero {
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(180px, .65fr);
  gap: 28px;
  align-items: center;
  min-height: 196px;
  padding: 28px;
  background: linear-gradient(135deg, #fff, var(--preview-bg));
}
.website-template-preview__hero h3 { margin: 7px 0; font-size: 27px; }
.website-template-preview__hero p { margin: 0 0 17px; color: #536078; }
.website-template-preview__eyebrow { color: var(--preview-accent); font-size: 12px; font-weight: 700; text-transform: uppercase; }
.website-template-preview__button { display: inline-block; padding: 8px 14px; border-radius: 5px; background: var(--preview-accent); color: #fff; font-size: 13px; font-weight: 700; }
.website-template-preview__services { display: grid; gap: 10px; }
.website-template-preview__services span { display: block; height: 42px; border-left: 4px solid var(--preview-accent); border-radius: 5px; background: #fff; box-shadow: 0 5px 16px rgba(30, 45, 70, .08); }
.website-template-preview.is-classic .website-template-preview__nav { background: var(--preview-accent); color: #fff; }
.website-template-preview.is-classic .website-template-preview__nav strong { color: #fff; }
.website-template-preview.is-editorial .website-template-preview__hero { grid-template-columns: .9fr 1.1fr; background: linear-gradient(135deg, #211d19 0 42%, #fff 42% 100%); }
.website-template-preview.is-editorial .website-template-preview__hero > div:first-child { grid-column: 2; }
.website-template-preview.is-centered .website-template-preview__hero { grid-template-columns: 1fr; text-align: center; }
.website-template-preview.is-centered .website-template-preview__services { display: none; }
.website-template-preview.buttons-square .website-template-preview__button { border-radius: 2px; }
.website-template-preview.buttons-pill .website-template-preview__button { border-radius: 999px; }
@@media (max-width: 767px) {
  .template-gallery { grid-template-columns:1fr; }
  .template-selection-bar { align-items:flex-start; flex-direction:column; }
  .website-template-preview__nav span { display: none; }
  .website-template-preview__hero { grid-template-columns: 1fr; }
  .website-template-preview__services { display: none; }
}
</style>

@section Scripts {
<script>
function updateWebsitePreview() {
  const preview = document.getElementById('websiteTemplatePreview');
  const color = document.getElementById('ThemeColor');
  const background = document.getElementById('BackgroundColorOverride');
  const title = document.querySelector('[name="SiteTitle"]');
  const tagline = document.querySelector('[name="TagLine"]');
  if (!preview || !color) return;
  preview.style.setProperty('--preview-accent', color.value);
  if (background?.value) preview.style.setProperty('--preview-bg', background.value);
  document.getElementById('previewSiteTitle').textContent = title?.value || 'Your Business';
  document.getElementById('previewHeadline').textContent = title?.value || 'Welcome to your website';
  document.getElementById('previewTagline').textContent = tagline?.value || 'Helping clients move forward with confidence.';
}
function updateTemplatePreviewLink() {
  const select = document.getElementById('TemplateId');
  const link = document.getElementById('previewSelectedTemplate');
  if (!select || !link) return;
  link.href = `/Website/PreviewTemplate?templateId=${encodeURIComponent(select.value)}&useDefaults=true`;
}
document.getElementById('ThemeColor')?.addEventListener('input', function () {
  document.getElementById('themeHex').value = this.value;
  updateWebsitePreview();
});
document.getElementById('BackgroundColorOverride')?.addEventListener('input', updateWebsitePreview);
document.querySelectorAll('.palette-swatch').forEach(swatch => {
  swatch.addEventListener('click', () => {
    const color = document.getElementById('ThemeColor');
    const hex = document.getElementById('themeHex');
    const background = document.getElementById('BackgroundColorOverride');
    if (color) color.value = swatch.dataset.accent;
    if (hex) hex.value = swatch.dataset.accent;
    if (background) background.value = swatch.dataset.background;
    updateWebsitePreview();
  });
});
document.querySelector('[name="SiteTitle"]')?.addEventListener('input', updateWebsitePreview);
document.querySelector('[name="TagLine"]')?.addEventListener('input', updateWebsitePreview);
document.getElementById('TemplateId')?.addEventListener('change', function () {
  const selected = this.options[this.selectedIndex];
  const preview = document.getElementById('websiteTemplatePreview');
  if (preview) {
    preview.style.setProperty('--preview-bg', selected?.dataset?.background || '#f4f7fb');
    preview.style.setProperty('--preview-font', selected?.dataset?.font || 'Arial, Helvetica, sans-serif');
    preview.classList.toggle('is-classic', selected?.dataset?.renderer === 'classic-sidebar');
    preview.classList.toggle('is-editorial', selected?.dataset?.renderer === 'editorial-visual');
    preview.classList.toggle('is-centered', selected?.dataset?.layout === 'centered');
    preview.classList.toggle('buttons-square', selected?.dataset?.button === 'square');
    preview.classList.toggle('buttons-pill', selected?.dataset?.button === 'pill');
  }
  const description = document.getElementById('selectedTemplateDescription');
  const name = document.getElementById('selectedTemplateName');
  if (description) description.textContent = selected?.dataset?.description || '';
  if (name) name.textContent = selected?.textContent?.trim() || 'Choose a design';
  document.querySelectorAll('[data-template-card]').forEach(card => {
    const active = card.dataset.templateCard === this.value;
    card.classList.toggle('is-selected', active);
    card.setAttribute('aria-checked', active ? 'true' : 'false');
    const button = card.querySelector('.template-select-action');
    if (button) {
      button.textContent = active ? 'Current design' : 'Choose design';
      button.classList.toggle('btn-primary', active);
      button.classList.toggle('btn-outline-secondary', !active);
    }
  });
  updateWebsitePreview();
  updateTemplatePreviewLink();
});
function chooseTemplate(id) {
  const select = document.getElementById('TemplateId');
  if (!select) return;
  select.value = String(id);
  const selected = select.options[select.selectedIndex];
  const accent = selected?.dataset?.accent;
  const color = document.getElementById('ThemeColor');
  const hex = document.getElementById('themeHex');
  if (accent && color && hex) {
    color.value = accent;
    hex.value = accent;
  }
  select.dispatchEvent(new Event('change'));
  document.getElementById('selectedTemplateName')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}
document.querySelectorAll('[data-select-template]').forEach(button => button.addEventListener('click', event => {
  event.stopPropagation();
  chooseTemplate(button.dataset.selectTemplate);
}));
document.querySelectorAll('[data-template-card]').forEach(card => {
  card.addEventListener('click', event => {
    if (event.target.closest('.template-preview-action')) return;
    chooseTemplate(card.dataset.templateCard);
  });
  card.addEventListener('keydown', event => {
    if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); chooseTemplate(card.dataset.templateCard); }
  });
});
updateWebsitePreview();
document.getElementById('TemplateId')?.dispatchEvent(new Event('change'));
</script>
}
