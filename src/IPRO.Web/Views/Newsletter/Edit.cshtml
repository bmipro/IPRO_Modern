@model IPRO.Entities.NewsLetter
@{ ViewData["Title"] = "Edit Newsletter"; var articles = ViewBag.Articles as IEnumerable<IPRO.Entities.NewsLetterArticle>; }

<div class="row mb-4">
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Newsletter">Newsletters</a></li><li class="breadcrumb-item active">Edit</li></ol>
    </nav>
    <div class="d-flex align-items-center gap-3">
      <h2 class="fw-bold mb-0"><i class="fas fa-edit me-2 text-primary"></i>Edit Newsletter</h2>
      <span class="badge bg-@(Model.Status == IPRO.Entities.NewsLetterStatus.Sent ? "success" : Model.Status == IPRO.Entities.NewsLetterStatus.Scheduled ? "warning" : "secondary") fs-6">@Model.Status</span>
      <a href="/Newsletter/Preview/@Model.Id" class="btn btn-outline-primary btn-sm"><i class="fas fa-eye me-1"></i>Preview</a>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-4 px-4"><h5 class="fw-bold">Newsletter Content</h5></div>
      <div class="card-body px-4 pb-4">
        <form asp-action="Edit" method="post">
          @Html.AntiForgeryToken()
          <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
          <input type="hidden" asp-for="Id"/>
          <input type="hidden" asp-for="AgentUserId"/>
          <div class="mb-3">
            <label class="form-label fw-semibold">Subject</label>
            <input asp-for="Subject" class="form-control" required/>
            <span asp-validation-for="Subject" class="text-danger small"></span>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Edition</label>
            <input asp-for="Edition" class="form-control" placeholder="@DateTime.UtcNow.ToString("MMMM yyyy") Newsletter" />
            <div class="form-text">Shown in the colored title bar at the top of the email. Leave blank to use the current month automatically.</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Banner Image</label>
            <input type="hidden" asp-for="BannerUrl" id="bannerUrlInput" />
            <div id="bannerPreview" class="mb-2 @(string.IsNullOrWhiteSpace(Model.BannerUrl) ? "d-none" : "")">
              <img src="@Model.BannerUrl" alt="" style="max-width:100%;max-height:120px;border-radius:6px;" />
            </div>
            <details class="starter-banner-library">
              <summary><i class="fas fa-wand-magic-sparkles me-2 text-primary"></i><strong>Choose a banner</strong><span class="text-muted ms-2">optional</span></summary>
              <div class="starter-banner-grid mt-3">
                @foreach (var banner in IPRO.Entities.WebsiteStarterBannerCatalog.All)
                {
                  <button type="button" class="starter-banner-choice @(Model.BannerUrl == banner.Url ? "is-selected" : "")" data-banner-url="@banner.Url" data-banner-name="@banner.Name">
                    <img src="@banner.Url" alt="@banner.Name" loading="lazy" />
                    <span class="starter-banner-caption"><strong>@banner.Name</strong><span>@banner.Category</span></span>
                    <span class="starter-banner-use"><i class="fas fa-check me-1"></i>Use this banner</span>
                  </button>
                }
              </div>
            </details>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Newsletter Body</label>
            @await Html.PartialAsync("_RichEditor", Model.HtmlBody, new ViewDataDictionary(ViewData) {
                { "EditorId", "nlBody" }, { "FieldName", "HtmlBody" }, { "Height", "450" }, { "Toolbar", "full" }
            })
            <span asp-validation-for="HtmlBody" class="text-danger small"></span>
            <div class="form-text">If this is blank, the plain text version below will be converted automatically.</div>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Plain Text Version</label>
            <textarea asp-for="TextBody" class="form-control" rows="3"></textarea>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary"><i class="fas fa-eye me-1"></i>Save and Preview</button>
            <a href="/Newsletter/Preview/@Model.Id" class="btn btn-outline-secondary">Preview without saving</a>
          </div>
        </form>
      </div>
    </div>

    <!-- Articles Section -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0">Articles</h5>
      </div>
      <div class="card-body px-4 pb-4">
        @if (articles != null && articles.Any())
        {
          @foreach (var a in articles.OrderBy(x => x.SortOrder))
          {
            <div class="border rounded p-3 mb-2 d-flex align-items-center gap-3">
              @if (!string.IsNullOrEmpty(a.ImageUrl))
              { <img src="@a.ImageUrl" class="rounded" style="width:60px;height:60px;object-fit:cover;"/> }
              <div class="flex-grow-1">
                <div class="fw-semibold">@a.Title</div>
                <small class="text-muted">@(a.Content.Length > 80 ? a.Content[..80] + "..." : a.Content)</small>
              </div>
            </div>
          }
        }
        else { <p class="text-muted">No articles added yet.</p> }

        <hr/>
        <h6 class="fw-bold">Add Article</h6>
        <form asp-action="AddArticle" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="NewsLetterId" value="@Model.Id"/>
          <div class="mb-2"><input name="Title" class="form-control" placeholder="Article title" required/></div>
          <div class="mb-2">
            @await Html.PartialAsync("_RichEditor", string.Empty, new ViewDataDictionary(ViewData) {
                { "EditorId", "articleBody" }, { "FieldName", "Content" }, { "Height", "250" }, { "Toolbar", "simple" }
            })
          </div>
          <button type="submit" class="btn btn-outline-primary btn-sm"><i class="fas fa-plus me-1"></i>Add Article</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-2"><i class="fas fa-eye me-2 text-primary"></i>Preview before sending</h6>
        <p class="small text-muted mb-3">Review the finished newsletter and schedule it from the preview page.</p>
        <a href="/Newsletter/Preview/@Model.Id" class="btn btn-primary w-100"><i class="fas fa-eye me-1"></i>Preview Newsletter</a>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4 text-center">
        <div class="text-muted small mb-1">Total Sent</div>
        <div class="display-6 fw-bold text-success">@Model.TotalSent</div>
        <div class="text-muted small mt-1">of @Model.TotalRecipients recipients</div>
        @if (Model.SentAt.HasValue)
        { <div class="text-muted small mt-2">Sent @Model.SentAt.Value.ToString("MMM d, yyyy h:mm tt")</div> }
      </div>
    </div>
  </div>
</div>

<style>
.starter-banner-library summary{cursor:pointer;list-style:none}
.starter-banner-library summary::-webkit-details-marker{display:none}
.starter-banner-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.starter-banner-choice{position:relative;overflow:hidden;margin:0;padding:0;border:2px solid transparent;border-radius:7px;background:#fff;text-align:left;box-shadow:0 4px 14px rgba(27,45,75,.08);transition:border-color .15s ease,transform .15s ease,box-shadow .15s ease}
.starter-banner-choice:hover,.starter-banner-choice:focus-visible{border-color:#0d6efd;transform:translateY(-1px);box-shadow:0 8px 22px rgba(13,110,253,.16);outline:0}
.starter-banner-choice.is-selected{border-color:#198754;box-shadow:0 0 0 3px rgba(25,135,84,.14)}
.starter-banner-choice img{display:block;width:100%;aspect-ratio:3.6/1;object-fit:cover}
.starter-banner-caption{display:flex;justify-content:space-between;gap:8px;padding:9px 10px 30px;font-size:12px}
.starter-banner-caption span{color:#64748b}
.starter-banner-use{position:absolute;right:8px;bottom:7px;color:#0d6efd;font-size:11px;font-weight:700}
.starter-banner-choice.is-selected .starter-banner-use{color:#198754}
@@media(max-width:800px){.starter-banner-grid{grid-template-columns:1fr}.starter-banner-caption{font-size:11px}}
</style>

@section Scripts {
<script>
document.querySelectorAll('.starter-banner-choice').forEach(button => {
  button.addEventListener('click', event => {
    event.preventDefault();
    const url = button.dataset.bannerUrl || '';
    document.getElementById('bannerUrlInput').value = url;
    document.querySelectorAll('.starter-banner-choice').forEach(choice => choice.classList.remove('is-selected'));
    button.classList.add('is-selected');
    const preview = document.getElementById('bannerPreview');
    preview.querySelector('img').src = url;
    preview.classList.remove('d-none');
  });
});
</script>
}
