@model IEnumerable<IPRO.Entities.NewsLetter>
@{
    ViewData["Title"] = "Newsletters";
    var agentTimeZone = ViewBag.AgentTimeZone as string ?? IPRO.Web.Infrastructure.AgentTimeZoneHelper.DefaultTimeZone;
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="fw-bold mb-0"><i class="fas fa-envelope me-2 text-success"></i>Newsletters</h2>
    <small class="text-muted">@Model.Count() reusable newsletter@(Model.Count() == 1 ? "" : "s")</small>
  </div>
  <a href="/Newsletter/Create" class="btn btn-success"><i class="fas fa-plus me-1"></i>Create Newsletter</a>
</div>

@if (!Model.Any())
{
  <div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
      <i class="fas fa-envelope-open fa-3x text-muted opacity-25 mb-3 d-block"></i>
      <h5 class="fw-bold">No newsletters yet</h5>
      <p class="text-muted">Create reusable newsletter content, then send it to subscribers, groups, or individual clients.</p>
      <a href="/Newsletter/Create" class="btn btn-success"><i class="fas fa-plus me-1"></i>Create Newsletter</a>
    </div>
  </div>
}
else
{
  <div class="row g-3">
  @foreach (var nl in Model.OrderByDescending(n => n.CreatedAt))
  {
    <div class="col-md-6 col-xl-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-start mb-2">
            <span class="badge rounded-pill bg-primary">Reusable</span>
            <small class="text-muted">Created @IPRO.Web.Infrastructure.AgentTimeZoneHelper.FromUtc(nl.CreatedAt, agentTimeZone).ToString("MMM d, yyyy")</small>
          </div>
          <h6 class="fw-bold mb-1">@nl.Subject</h6>
          <small class="text-muted"><i class="fas fa-repeat me-1"></i>Use this newsletter again whenever the audience or timing changes.</small>
        </div>
        <div class="card-footer bg-white border-0 px-4 pb-3 d-flex flex-wrap gap-2">
          <a href="/Newsletter/Preview/@nl.Id" class="btn btn-sm btn-primary flex-grow-1"><i class="fas fa-eye me-1"></i>Preview</a>
          <a href="/Newsletter/Edit/@nl.Id" class="btn btn-sm btn-outline-primary flex-grow-1"><i class="fas fa-edit me-1"></i>Edit</a>
          <a href="/Newsletter/Send/@nl.Id" class="btn btn-sm btn-success flex-grow-1"><i class="fas fa-paper-plane me-1"></i>Send</a>
          <form asp-action="Duplicate" asp-route-id="@nl.Id" method="post" class="flex-grow-1">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-secondary w-100"><i class="fas fa-copy me-1"></i>Duplicate</button>
          </form>
        </div>
      </div>
    </div>
  }
  </div>
}
