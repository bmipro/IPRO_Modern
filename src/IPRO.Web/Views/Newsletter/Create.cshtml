@model IPRO.Entities.NewsLetter
@{ ViewData["Title"] = "Create Newsletter"; }

<div class="row mb-4">
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Newsletter">Newsletters</a></li><li class="breadcrumb-item active">Create</li></ol>
    </nav>
    <h2 class="fw-bold"><i class="fas fa-paper-plane me-2 text-success"></i>Create Newsletter</h2>
  </div>
</div>

@{
    var templates = (ViewBag.NewsletterTemplates as IEnumerable<IPRO.Entities.NewsLetterTemplate>) ?? Enumerable.Empty<IPRO.Entities.NewsLetterTemplate>();
}
@if (templates.Any() && string.IsNullOrWhiteSpace(Model.Subject) && string.IsNullOrWhiteSpace(Model.HtmlBody))
{
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <h6 class="fw-bold mb-3"><i class="fas fa-wand-magic-sparkles me-2 text-primary"></i>Start from a template</h6>
      <div class="row g-3">
        @foreach (var template in templates)
        {
          <div class="col-md-6 col-lg-4">
            <div class="border rounded-3 p-3 h-100 d-flex flex-column">
              <div class="fw-semibold">@template.Name</div>
              <div class="small text-muted flex-grow-1">@template.Description</div>
              <a href="/Newsletter/CreateFromTemplate/@template.Id" class="btn btn-sm btn-outline-primary mt-2 align-self-start">Use this template</a>
            </div>
          </div>
        }
        <div class="col-md-6 col-lg-4">
          <div class="border rounded-3 p-3 h-100 d-flex flex-column justify-content-center align-items-center text-center text-muted">
            <i class="fas fa-file mb-2"></i>
            <div class="small">Or start blank using the form below</div>
          </div>
        </div>
      </div>
    </div>
  </div>
}

<div class="row">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <form asp-action="Create" method="post">
          @Html.AntiForgeryToken()
          <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
          <div class="mb-4">
            <label class="form-label fw-semibold">Subject Line <span class="text-danger">*</span></label>
            <input asp-for="Subject" class="form-control form-control-lg" placeholder="Enter a compelling subject line..." required/>
            <span asp-validation-for="Subject" class="text-danger small"></span>
            <div class="form-text">This is what your subscribers will see in their inbox.</div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Edition</label>
            <input asp-for="Edition" class="form-control" placeholder="@DateTime.UtcNow.ToString("MMMM yyyy") Newsletter" />
            <div class="form-text">Shown in the colored title bar at the top of the email. Leave blank to use the current month automatically.</div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Banner Image</label>
            <input type="hidden" asp-for="BannerUrl" id="bannerUrlInput" />
            <div id="bannerPreview" class="mb-2 @(string.IsNullOrWhiteSpace(Model.BannerUrl) ? "d-none" : "")">
              <img src="@Model.BannerUrl" alt="" style="max-width:100%;max-height:120px;border-radius:6px;" />
            </div>
            <details class="starter-banner-library">
              <summary><i class="fas fa-wand-magic-sparkles me-2 text-primary"></i><strong>Choose a banner</strong><span class="text-muted ms-2">optional</span></summary>
              <div class="starter-banner-grid mt-3">
                @foreach (var banner in IPRO.Entities.WebsiteStarterBannerCatalog.All)
                {
                  <button type="button" class="starter-banner-choice @(Model.BannerUrl == banner.Url ? "is-selected" : "")" data-banner-url="@banner.Url" data-banner-name="@banner.Name">
                    <img src="@banner.Url" alt="@banner.Name" loading="lazy" />
                    <span class="starter-banner-caption"><strong>@banner.Name</strong><span>@banner.Category</span></span>
                    <span class="starter-banner-use"><i class="fas fa-check me-1"></i>Use this banner</span>
                  </button>
                }
              </div>
            </details>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Newsletter Body</label>
            @await Html.PartialAsync("_RichEditor", Model.HtmlBody ?? string.Empty, new ViewDataDictionary(ViewData) {
                { "EditorId", "nlBody" }, { "FieldName", "HtmlBody" }, { "Height", "500" }, { "Toolbar", "full" }
            })
            <span asp-validation-for="HtmlBody" class="text-danger small"></span>
            <div class="form-text">Use this rich editor for formatted newsletters. If left blank, the plain text version below will be converted automatically.</div>
          </div>

          <div class="mb-4">
            <label class="form-label fw-semibold">Plain Text Version <span class="text-danger">*</span></label>
            <textarea asp-for="TextBody" class="form-control" rows="4" placeholder="Plain text fallback for email clients that don't support HTML..."></textarea>
            <div class="form-text">Required if the rich newsletter body is blank. Also used by email clients that don't render HTML.</div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-success btn-lg px-4"><i class="fas fa-eye me-2"></i>Save and Preview</button>
            <a href="/Newsletter" class="btn btn-outline-secondary btn-lg">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="fas fa-lightbulb me-2 text-warning"></i>Tips</h6>
        <ul class="small text-muted ps-3">
          <li class="mb-2">Keep subject lines under 50 characters</li>
          <li class="mb-2">Personalise with the agent's name</li>
          <li class="mb-2">Include a clear call-to-action button</li>
          <li class="mb-2">Save the draft, preview it, then schedule when it looks right</li>
        </ul>
      </div>
    </div>
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="fas fa-users me-2 text-info"></i>Subscribers</h6>
        <p class="small text-muted">After preview, this newsletter can be scheduled for @((int)(ViewBag.SubscriberCount ?? 0)) subscribed clients.</p>
        <a href="/Newsletter/Subscribers" class="btn btn-sm btn-outline-info w-100">View Subscriber List</a>
      </div>
    </div>
  </div>
</div>

<style>
.starter-banner-library summary{cursor:pointer;list-style:none}
.starter-banner-library summary::-webkit-details-marker{display:none}
.starter-banner-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.starter-banner-choice{position:relative;overflow:hidden;margin:0;padding:0;border:2px solid transparent;border-radius:7px;background:#fff;text-align:left;box-shadow:0 4px 14px rgba(27,45,75,.08);transition:border-color .15s ease,transform .15s ease,box-shadow .15s ease}
.starter-banner-choice:hover,.starter-banner-choice:focus-visible{border-color:#0d6efd;transform:translateY(-1px);box-shadow:0 8px 22px rgba(13,110,253,.16);outline:0}
.starter-banner-choice.is-selected{border-color:#198754;box-shadow:0 0 0 3px rgba(25,135,84,.14)}
.starter-banner-choice img{display:block;width:100%;aspect-ratio:3.6/1;object-fit:cover}
.starter-banner-caption{display:flex;justify-content:space-between;gap:8px;padding:9px 10px 30px;font-size:12px}
.starter-banner-caption span{color:#64748b}
.starter-banner-use{position:absolute;right:8px;bottom:7px;color:#0d6efd;font-size:11px;font-weight:700}
.starter-banner-choice.is-selected .starter-banner-use{color:#198754}
@@media(max-width:800px){.starter-banner-grid{grid-template-columns:1fr}.starter-banner-caption{font-size:11px}}
</style>

@section Scripts {
<script>
document.querySelectorAll('.starter-banner-choice').forEach(button => {
  button.addEventListener('click', event => {
    event.preventDefault();
    const url = button.dataset.bannerUrl || '';
    document.getElementById('bannerUrlInput').value = url;
    document.querySelectorAll('.starter-banner-choice').forEach(choice => choice.classList.remove('is-selected'));
    button.classList.add('is-selected');
    const preview = document.getElementById('bannerPreview');
    preview.querySelector('img').src = url;
    preview.classList.remove('d-none');
  });
});
</script>
}
