@model IPRO.Entities.NewsLetter
@{
    ViewData["Title"] = "Preview Newsletter";
    var articles = ViewBag.Articles as IEnumerable<IPRO.Entities.NewsLetterArticle>;
    var sends = (ViewBag.Sends as IEnumerable<IPRO.Entities.NewsLetterSend> ?? Enumerable.Empty<IPRO.Entities.NewsLetterSend>()).OrderByDescending(s => s.ScheduledAt).ToList();
    var latestSend = sends.FirstOrDefault();
    var recipients = (ViewBag.Recipients as IEnumerable<IPRO.Entities.NewsLetterRecipient> ?? Enumerable.Empty<IPRO.Entities.NewsLetterRecipient>()).ToList();
    var subscriberCount = (int)(ViewBag.SubscriberCount ?? 0);
    var sentCount = recipients.Count(r => r.SentAt.HasValue || r.DeliveredAt.HasValue || r.OpenedAt.HasValue || r.ClickedAt.HasValue);
    var deliveredCount = recipients.Count(r => r.DeliveredAt.HasValue || r.OpenedAt.HasValue || r.ClickedAt.HasValue);
    var openedCount = recipients.Count(r => r.OpenedAt.HasValue || r.ClickedAt.HasValue);
    var failedCount = recipients.Count(r =>
        r.Status is IPRO.Entities.NewsLetterRecipientStatus.Bounced or IPRO.Entities.NewsLetterRecipientStatus.Failed or IPRO.Entities.NewsLetterRecipientStatus.Dropped ||
        (!string.IsNullOrWhiteSpace(r.FailureReason) &&
         r.Status == IPRO.Entities.NewsLetterRecipientStatus.Sent &&
         !r.DeliveredAt.HasValue &&
         !r.OpenedAt.HasValue &&
         !r.ClickedAt.HasValue));
    var agentTimeZone = ViewBag.AgentTimeZone as string ?? IPRO.Web.Infrastructure.AgentTimeZoneHelper.DefaultTimeZone;
    var agentTimeZoneLabel = ViewBag.AgentTimeZoneLabel as string ?? "Eastern";
    var agentNow = ViewBag.AgentNow as DateTime? ?? IPRO.Web.Infrastructure.AgentTimeZoneHelper.FromUtc(DateTime.UtcNow, agentTimeZone);
}

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-2">
        <li class="breadcrumb-item"><a href="/Newsletter">Newsletters</a></li>
        <li class="breadcrumb-item active">Preview</li>
      </ol>
    </nav>
    <div class="d-flex align-items-center gap-3">
      <h2 class="fw-bold mb-0"><i class="fas fa-eye me-2 text-primary"></i>Preview Newsletter</h2>
      <span class="badge bg-primary fs-6">Reusable Content</span>
    </div>
  </div>
  <div class="d-flex gap-2">
    <a href="/Newsletter/Send/@Model.Id" class="btn btn-success"><i class="fas fa-paper-plane me-1"></i>Send</a>
    <form asp-action="SendTest" asp-route-id="@Model.Id" method="post">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-outline-success"><i class="fas fa-vial me-1"></i>Test Send</button>
    </form>
    <a href="/Newsletter/Edit/@Model.Id" class="btn btn-outline-primary"><i class="fas fa-edit me-1"></i>Edit</a>
    <form asp-action="Duplicate" asp-route-id="@Model.Id" method="post">
      @Html.AntiForgeryToken()
      <button type="submit" class="btn btn-outline-secondary"><i class="fas fa-copy me-1"></i>Duplicate</button>
    </form>
    <a href="/Newsletter" class="btn btn-outline-secondary">Back</a>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 p-4 pb-0">
        <div class="small text-uppercase text-muted fw-bold mb-2">Reusable email preview</div>
        <h4 class="fw-bold mb-1">@Model.Subject</h4>
        <div class="text-muted small">Ready to send to @subscriberCount newsletter subscriber@(subscriberCount == 1 ? "" : "s"), groups, or selected clients as we expand targeting.</div>
      </div>
      <div class="card-body p-4">
        <div class="newsletter-preview-shell">
          <div class="newsletter-preview-meta">
            <div><strong>Subject:</strong> @Model.Subject</div>
            <div><strong>From:</strong> IPRO Advisers</div>
          </div>
          <div class="newsletter-preview-wrapped">
            @Html.Raw(ViewBag.WrappedHtmlBody as string ?? Model.HtmlBody)
          </div>
          @if (articles != null && articles.Any())
          {
            <hr />
            <div class="small text-uppercase text-muted fw-bold mb-3">Articles</div>
            @foreach (var article in articles.OrderBy(a => a.SortOrder))
            {
              <article class="newsletter-preview-article">
                <h5>@article.Title</h5>
                @if (!string.IsNullOrWhiteSpace(article.ImageUrl))
                {
                  <img src="@article.ImageUrl" alt="" />
                }
                <div>@Html.Raw(article.Content)</div>
              </article>
            }
          }
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.TextBody))
        {
          <details class="mt-4">
            <summary class="fw-semibold">Plain text version</summary>
            <pre class="plain-text-preview mt-3">@Model.TextBody</pre>
          </details>
        }
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3"><i class="fas fa-clipboard-check me-2 text-success"></i>Review checklist</h5>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Subscribers</span>
          <strong>@subscriberCount</strong>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Sent</span>
          <strong>@sentCount</strong>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Delivered</span>
          <strong>@deliveredCount</strong>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Opened / read</span>
          <strong>@openedCount</strong>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Failed</span>
          <strong>@failedCount</strong>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Send runs</span>
          <strong>@sends.Count</strong>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom">
          <span class="text-muted">Latest send</span>
          <strong>@(latestSend == null ? "-" : latestSend.Status.ToString())</strong>
        </div>
        <div class="d-flex justify-content-between py-2">
          <span class="text-muted">Created</span>
          <strong>@IPRO.Web.Infrastructure.AgentTimeZoneHelper.FromUtc(Model.CreatedAt, agentTimeZone).ToString("MMM d, yyyy")</strong>
        </div>
        <a href="/Newsletter/Edit/@Model.Id" class="btn btn-outline-primary w-100 mt-3"><i class="fas fa-edit me-1"></i>Make Changes</a>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0"><i class="fas fa-paper-plane me-2 text-success"></i>Send this newsletter</h5>
      </div>
      <div class="card-body px-4 pb-4">
        <p class="text-muted small">Choose subscribers, an account type, or an individual client, then send now or schedule later.</p>
        <a href="/Newsletter/Send/@Model.Id" class="btn btn-success w-100"><i class="fas fa-paper-plane me-1"></i>Choose Audience and Send</a>
      </div>
    </div>
  </div>
</div>

@if (sends.Any())
{
  <div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white border-0 p-4 pb-0">
      <h5 class="fw-bold mb-1"><i class="fas fa-history me-2 text-primary"></i>Send History</h5>
      <div class="text-muted small">The same newsletter content can be reused; each send run keeps its own schedule, audience, and tracking.</div>
    </div>
    <div class="card-body p-4">
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Scheduled</th>
              <th>Audience</th>
              <th>Status</th>
              <th>Recipients</th>
              <th>Sent</th>
              <th>Opened</th>
              <th>Open Rate</th>
              <th>Clicked</th>
              <th>Click Rate</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
          @foreach (var send in sends)
          {
            var sendStatusClass = send.Status switch
            {
                IPRO.Entities.NewsLetterSendStatus.Sent => "bg-success",
                IPRO.Entities.NewsLetterSendStatus.Sending => "bg-info",
                IPRO.Entities.NewsLetterSendStatus.Scheduled => "bg-warning text-dark",
                IPRO.Entities.NewsLetterSendStatus.Failed => "bg-danger",
                _ => "bg-secondary"
            };
            var openRate = send.TotalSent == 0 ? 0 : Math.Round((double)send.TotalOpened / send.TotalSent * 100, 1);
            var clickRate = send.TotalSent == 0 ? 0 : Math.Round((double)send.TotalClicked / send.TotalSent * 100, 1);
            <tr>
              <td class="fw-semibold">@IPRO.Web.Infrastructure.AgentTimeZoneHelper.FromUtc(send.ScheduledAt, agentTimeZone).ToString("MMM d, yyyy h:mm tt")</td>
              <td>@send.AudienceLabel</td>
              <td><span class="badge @sendStatusClass">@send.Status</span></td>
              <td>@send.TotalRecipients</td>
              <td>@send.TotalSent</td>
              <td>@send.TotalOpened</td>
              <td>@openRate%</td>
              <td>@send.TotalClicked</td>
              <td>@clickRate%</td>
              <td class="text-end">
                @if (send.Status == IPRO.Entities.NewsLetterSendStatus.Scheduled)
                {
                  <form asp-action="CancelSend" asp-route-id="@send.Id" asp-route-newsletterId="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-ban me-1"></i>Cancel</button>
                  </form>
                }
              </td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    </div>
  </div>
}

@if (recipients.Any())
{
  <div class="card border-0 shadow-sm mt-4">
    <div class="card-header bg-white border-0 p-4 pb-0">
      <h5 class="fw-bold mb-1"><i class="fas fa-chart-line me-2 text-info"></i>Latest Send Delivery Tracking</h5>
      <div class="text-muted small">Recipient-level sent, delivered, read, and failure status for the most recent send run.</div>
    </div>
    <div class="card-body p-4">
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th>Recipient</th>
              <th>Email</th>
              <th>Status</th>
              <th>Sent</th>
              <th>Delivered</th>
              <th>Opened</th>
              <th>Issue</th>
            </tr>
          </thead>
          <tbody>
          @foreach (var recipient in recipients.OrderBy(r => r.RecipientName).ThenBy(r => r.Email))
          {
            var effectiveStatus = recipient.Status;
            if (!string.IsNullOrWhiteSpace(recipient.FailureReason) &&
                recipient.Status == IPRO.Entities.NewsLetterRecipientStatus.Sent &&
                !recipient.DeliveredAt.HasValue &&
                !recipient.OpenedAt.HasValue &&
                !recipient.ClickedAt.HasValue)
            {
                effectiveStatus = IPRO.Entities.NewsLetterRecipientStatus.Failed;
            }

            var statusClass = effectiveStatus switch
            {
                IPRO.Entities.NewsLetterRecipientStatus.Opened or IPRO.Entities.NewsLetterRecipientStatus.Clicked => "bg-success",
                IPRO.Entities.NewsLetterRecipientStatus.Delivered or IPRO.Entities.NewsLetterRecipientStatus.Sent => "bg-primary",
                IPRO.Entities.NewsLetterRecipientStatus.Deferred => "bg-warning text-dark",
                IPRO.Entities.NewsLetterRecipientStatus.Bounced or IPRO.Entities.NewsLetterRecipientStatus.Failed or IPRO.Entities.NewsLetterRecipientStatus.Dropped => "bg-danger",
                _ => "bg-secondary"
            };
            <tr>
              <td class="fw-semibold">@(string.IsNullOrWhiteSpace(recipient.RecipientName) ? "-" : recipient.RecipientName)</td>
              <td><a href="mailto:@recipient.Email">@recipient.Email</a></td>
              <td><span class="badge @statusClass">@effectiveStatus</span></td>
              <td class="small text-muted">@(IPRO.Web.Infrastructure.AgentTimeZoneHelper.FromUtc(recipient.SentAt, agentTimeZone)?.ToString("MMM d, h:mm tt") ?? "-")</td>
              <td class="small text-muted">@(IPRO.Web.Infrastructure.AgentTimeZoneHelper.FromUtc(recipient.DeliveredAt, agentTimeZone)?.ToString("MMM d, h:mm tt") ?? "-")</td>
              <td class="small text-muted">@(IPRO.Web.Infrastructure.AgentTimeZoneHelper.FromUtc(recipient.OpenedAt, agentTimeZone)?.ToString("MMM d, h:mm tt") ?? "-")</td>
              <td class="small text-muted tracking-issue">@(string.IsNullOrWhiteSpace(recipient.FailureReason) ? "-" : recipient.FailureReason)</td>
            </tr>
          }
          </tbody>
        </table>
      </div>
    </div>
  </div>
}

<style>
  .newsletter-preview-shell {
    border: 1px solid #dce5f2;
    border-radius: 14px;
    background: #fff;
    overflow: hidden;
  }

  .newsletter-preview-meta {
    padding: 14px 18px;
    background: #f6f9fd;
    border-bottom: 1px solid #dce5f2;
    color: #475569;
    font-size: .92rem;
  }

  .newsletter-preview-wrapped {
    overflow-x: auto;
    min-height: 240px;
  }

  .newsletter-preview-article img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .newsletter-preview-article {
    padding: 0 24px 20px;
  }

  .plain-text-preview {
    white-space: pre-wrap;
    background: #f8fafc;
    border: 1px solid #dce5f2;
    border-radius: 10px;
    padding: 16px;
    color: #334155;
  }

  .tracking-issue {
    max-width: 280px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>
