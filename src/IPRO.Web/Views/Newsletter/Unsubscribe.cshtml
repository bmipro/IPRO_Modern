@{
    Layout = null;
    var success = ViewBag.Success as bool? == true;
    var email = ViewBag.Email as string ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Newsletter Preferences - IPRO Advisers</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <style>
    body {
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, #eef4ff, #ffffff);
      color: #172033;
    }
    .preference-card {
      width: min(560px, calc(100vw - 32px));
      border: 0;
      border-radius: 18px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, .12);
    }
  </style>
</head>
<body>
  <main class="card preference-card">
    <div class="card-body p-5 text-center">
      @if (success)
      {
        <div class="display-6 text-success mb-3"><i class="fas fa-circle-check"></i></div>
        <h1 class="h3 fw-bold">You have been unsubscribed</h1>
        <p class="text-muted mb-0">@email will no longer receive newsletter emails from this IPRO adviser.</p>
      }
      else
      {
        <div class="display-6 text-warning mb-3"><i class="fas fa-triangle-exclamation"></i></div>
        <h1 class="h3 fw-bold">This unsubscribe link is not valid</h1>
        <p class="text-muted mb-0">The link may have been copied incorrectly or may no longer exist.</p>
      }
    </div>
  </main>
</body>
</html>
