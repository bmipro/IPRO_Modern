@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    var agent = Model.Website.AgentUser;
    var blocks = Model.CurrentPage?.Blocks.Where(b => b.IsVisible).OrderBy(b => b.SortOrder).ToList() ?? new();
}
<style>
  .modern-page { background:#fff; }
  .modern-page .mp-section { padding:var(--section-space) 24px; border-bottom:1px solid #e3eaf3; }
  .modern-page .mp-inner { width:min(1120px, 100%); margin:0 auto; }
  .modern-page .mp-kicker { color:var(--site-theme); font:800 12px/1.3 Arial,sans-serif; text-transform:uppercase; letter-spacing:.1em; margin-bottom:12px; }
  .modern-page h1,.modern-page h2 { color:#0c1933; font-weight:850; letter-spacing:0; }
  .modern-page h2.display-6 { font-size:var(--heading-font-size, 22px); }
  .modern-page .mp-lead { max-width:720px; color:#5b6b82; font-size:var(--body-font-size, 18px); line-height:1.65; }
  .modern-page .mp-hero { min-height:630px; display:flex; align-items:center; color:#fff; border:0; background:linear-gradient(115deg,#07142f 0%,#07142f 48%,var(--site-theme) 100%); }
  body.hero-style-clean .modern-page .mp-hero { background:var(--site-theme-deep); }
  body.hero-style-classic .modern-page .mp-hero { background:var(--site-theme-deep); border-bottom:6px solid var(--site-theme); }
  .modern-page .mp-hero-grid { display:grid; grid-template-columns:minmax(0,1.05fr) minmax(320px,.95fr); gap:64px; align-items:center; }
  .modern-page .mp-hero h1 { color:#fff; font-size:64px; line-height:1.02; max-width:760px; }
  .modern-page .mp-hero .mp-lead { color:#dbe6fb; font-size:calc(var(--body-font-size, 18px) + 3px); }
  .modern-page .mp-hero-media { min-height:390px; border-radius:8px; overflow:hidden; background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.2); display:flex; align-items:flex-end; }
  .modern-page .mp-hero-media img { width:100%; height:100%; min-height:390px; object-fit:cover; }
  .modern-page .mp-hero.layout-image-left .mp-hero-media { order:-1; }
  .modern-page .mp-hero.layout-centered .mp-hero-grid { grid-template-columns:1fr; text-align:center; }
  .modern-page .mp-hero.layout-centered .mp-lead { margin-left:auto; margin-right:auto; }
  .modern-page .mp-hero.layout-centered .mp-hero-media { width:min(780px,100%); margin:0 auto; }
  .modern-page .mp-hero.align-center .mp-hero-copy { text-align:center; }
  .modern-page .mp-hero.align-center .mp-lead { margin-left:auto; margin-right:auto; }
  .modern-page .mp-hero.height-compact { min-height:430px; }
  .modern-page .mp-hero.height-tall { min-height:780px; }
  .modern-page .mp-hero.layout-compact { min-height:380px; }
  .modern-page .mp-hero.layout-compact .mp-hero-grid { grid-template-columns:1fr; }
  .modern-page .mp-hero.layout-compact .mp-hero-media { display:none; }
  .modern-page .mp-hero.layout-full-image { position:relative; isolation:isolate; }
  .modern-page .mp-hero.layout-full-image .mp-hero-grid { grid-template-columns:1fr; }
  .modern-page .mp-hero.layout-full-image .mp-hero-copy { position:relative; z-index:2; width:min(760px,100%); }
  .modern-page .mp-hero.layout-full-image .mp-hero-media { position:absolute; inset:0; z-index:-1; min-height:0; border:0; border-radius:0; opacity:var(--hero-image-opacity,.5); }
  .modern-page .mp-hero.layout-full-image .mp-hero-media img { min-height:100%; }
  .modern-page .mp-hero-mark { padding:30px; font-size:82px; color:rgba(255,255,255,.72); }
  .modern-page .mp-button { display:inline-flex; align-items:center; min-height:48px; margin-top:20px; padding:0 22px; border-radius:var(--button-radius); background:var(--site-theme); color:#fff; text-decoration:none; font-family:Arial,sans-serif; font-weight:800; }
  .modern-page .mp-hero .mp-button { background:#fff; color:#07142f; }
  .modern-page .mp-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; margin-top:30px; }
  .modern-page .mp-card { min-height:148px; padding:24px; border:1px solid #dce5f1; border-radius:8px; background:#fff; box-shadow:0 12px 30px rgba(15,35,70,.06); }
  .modern-page .mp-card i { color:var(--site-theme); margin-bottom:16px; }
  .modern-page .mp-alt { background:#f3f7fc; }
  .modern-page .mp-split { display:grid; grid-template-columns:minmax(0,1fr) minmax(300px,.8fr); gap:56px; align-items:center; }
  .modern-page .mp-split img { width:100%; max-height:460px; object-fit:cover; border-radius:8px; }
  .modern-page .mp-cta { background:var(--site-theme); color:#fff; border:0; }
  .modern-page .mp-cta h2,.modern-page .mp-cta .mp-lead { color:#fff; }
  .modern-page .mp-contact-card { padding:28px; border-radius:8px; background:#fff; color:#17223a; }
  .modern-page .mp-simple-list { list-style:none; padding:0; margin:24px 0 0; max-width:640px; }
  .modern-page .mp-simple-list li { display:flex; align-items:center; gap:12px; padding:14px 0; border-bottom:1px solid #dce5f1; font-weight:700; }
  .modern-page .mp-simple-list i { color:var(--site-theme); }
  .modern-page .mp-icon-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:24px; margin-top:30px; text-align:center; }
  .modern-page .mp-icon-grid i { font-size:34px; color:var(--site-theme); margin-bottom:14px; }
  .modern-page .mp-featured-quote { max-width:760px; margin:30px auto 0; text-align:center; font-size:24px; line-height:1.5; color:#17223a; }
  .modern-page .mp-featured-quote i { display:block; font-size:30px; color:var(--site-theme); margin-bottom:16px; }
  .modern-page .mp-quote-list { display:grid; gap:0; max-width:760px; margin-top:24px; }
  .modern-page .mp-quote-row { display:flex; gap:14px; padding:16px 0; border-bottom:1px solid #dce5f1; }
  .modern-page .mp-quote-row i { color:var(--site-theme); }
  .modern-page .mp-cta-banner .mp-inner { text-align:center; }
  .modern-page .mp-cta-banner .mp-lead { margin-left:auto; margin-right:auto; }
  .modern-page .mp-cta-card { max-width:820px; margin:0 auto; padding:44px; border-radius:12px; border:1px solid #dce5f1; box-shadow:0 12px 30px rgba(15,35,70,.06); text-align:center; }
  .modern-page .mp-cta-card .mp-lead { margin-left:auto; margin-right:auto; }
  @@media(max-width:820px){.modern-page .mp-hero-grid,.modern-page .mp-split{grid-template-columns:1fr;gap:32px}.modern-page .mp-hero{min-height:0}.modern-page .mp-hero h1{font-size:44px}.modern-page .mp-grid,.modern-page .mp-icon-grid{grid-template-columns:1fr}.modern-page .mp-hero-media{min-height:240px}.modern-page .mp-hero-media img{min-height:240px}}
</style>
<main class="modern-page">
@foreach (var block in blocks)
{
  if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.Hero)
  {
    var hero = IPRO.Entities.WebsiteHeroSettings.FromJson(block.SettingsJson);
    var imageOpacity = Math.Clamp((100 - hero.OverlayStrength) / 100.0, .15, .9).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    <section class="mp-section mp-hero layout-@hero.Layout align-@hero.TextAlignment height-@hero.Height" style="--hero-image-opacity:@imageOpacity">
      <div class="mp-inner mp-hero-grid">
        <div class="mp-hero-copy"><div class="mp-kicker" style="color:#cbd9f5">@agent.CompanyName</div><h1>@block.Heading</h1><p class="mp-lead">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="mp-lead">@block.Body</p>}@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="mp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl) ? "/contact" : block.ButtonUrl)">@block.ButtonText <i class="fas fa-arrow-right ms-2"></i></a>}</div>
        <div class="mp-hero-media">@if(!string.IsNullOrWhiteSpace(block.ImageUrl)){<img src="@block.ImageUrl" alt="" style="object-position:@hero.ImagePosition" />}else{<i class="fas fa-compass mp-hero-mark"></i>}</div>
      </div>
    </section>
  }
  else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.Services)
  {
    var items = block.Body.Split(new[]{'\r','\n'}, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    <section class="mp-section mp-alt"><div class="mp-inner"><div class="mp-kicker">Services</div><h2 class="display-6">@block.Heading</h2><p class="mp-lead">@block.Subheading</p>
      @if(block.LayoutVariant == "list")
      {
        <ul class="mp-simple-list">@foreach(var item in items){<li><i class="fas fa-circle-check"></i>@item</li>}</ul>
      }
      else if(block.LayoutVariant == "icons")
      {
        <div class="mp-icon-grid">@foreach(var item in items){<div><i class="fas fa-circle-check"></i><div class="fw-bold">@item</div></div>}</div>
      }
      else
      {
        <div class="mp-grid">@foreach(var item in items){<div class="mp-card"><i class="fas fa-circle-check"></i><div class="fw-bold">@item</div></div>}</div>
      }
    </div></section>
  }
  else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.CallToAction)
  {
    if(block.LayoutVariant == "banner")
    {
      <section class="mp-section mp-cta mp-cta-banner"><div class="mp-inner"><div class="mp-kicker" style="color:#fff">Take the next step</div><h2 class="display-6">@block.Heading</h2><p class="mp-lead">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p>@block.Body</p>}<a class="mp-button" style="background:#fff;color:#17223a" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl) ? "/contact" : block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText) ? "Get in touch" : block.ButtonText)</a></div></section>
    }
    else if(block.LayoutVariant == "card")
    {
      <section class="mp-section"><div class="mp-inner"><div class="mp-cta-card"><div class="mp-kicker">Take the next step</div><h2 class="display-6">@block.Heading</h2><p class="mp-lead">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p>@block.Body</p>}<a class="mp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl) ? "/contact" : block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText) ? "Get in touch" : block.ButtonText)</a></div></div></section>
    }
    else
    {
      <section class="mp-section mp-cta"><div class="mp-inner mp-split"><div><div class="mp-kicker" style="color:#fff">Take the next step</div><h2 class="display-6">@block.Heading</h2><p class="mp-lead">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p>@block.Body</p>}</div><div><a class="mp-button" style="background:#fff;color:#17223a" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl) ? "/contact" : block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText) ? "Get in touch" : block.ButtonText)</a></div></div></section>
    }
  }
  else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.NewsletterSignup)
  {
    <section class="mp-section mp-cta"><div class="mp-inner mp-split"><div><div class="mp-kicker" style="color:#fff">Take the next step</div><h2 class="display-6">@block.Heading</h2><p class="mp-lead">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p>@block.Body</p>}</div><div>@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Newsletter })</div></div></section>
  }
  else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.ContactForm)
  {
    <section class="mp-section mp-alt"><div class="mp-inner mp-split"><div><div class="mp-kicker">Contact</div><h2 class="display-6">@block.Heading</h2><p class="mp-lead">@block.Subheading</p><p>@block.Body</p><div class="mt-4"><strong>@($"{agent.FirstName} {agent.LastName}".Trim())</strong><div>@agent.CompanyName</div>@if(!string.IsNullOrWhiteSpace(agent.Phone)){<div><i class="fas fa-phone me-2"></i><a href="tel:@agent.Phone">@agent.Phone</a></div>}</div></div><div class="mp-contact-card">@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Contact })</div></div></section>
  }
  else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.TestimonialForm)
  {
    <section class="mp-section mp-alt"><div class="mp-inner"><div class="mp-kicker">@block.Subheading</div><h2 class="display-6">@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="mp-lead">@block.Body</p>}<div class="mp-contact-card" style="max-width:640px">@await Html.PartialAsync("_TestimonialForm", new IPRO.Web.Models.TestimonialFormViewModel { PageId = Model.CurrentPage?.Id })</div>@if(Model.ApprovedTestimonials.Any()){<div class="mp-quote-list">@foreach(var t in Model.ApprovedTestimonials){<div class="mp-quote-row"><i class="fas fa-quote-left"></i><div><div>@t.Body</div><div class="fw-bold mt-1">@($"{t.FirstName} {t.LastName}".Trim())</div></div></div>}</div>}</div></section>
  }
  else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.PollResults)
  {
    if (Model.PollResultsByBlockId.TryGetValue(block.Id, out var modernPollData))
    {
      <section class="mp-section mp-alt"><div class="mp-inner"><div class="mp-kicker">@block.Subheading</div><h2 class="display-6">@(string.IsNullOrWhiteSpace(block.Heading) ? modernPollData.Title : block.Heading)</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="mp-lead">@block.Body</p>}<div class="mp-contact-card" style="max-width:640px">@await Html.PartialAsync("_PollResults", modernPollData)</div></div></section>
    }
  }
  else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.LeadMagnet)
  {
    <section class="mp-section mp-alt"><div class="mp-inner"><div class="mp-kicker">@block.Subheading</div><h2 class="display-6">@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="mp-lead">@block.Body</p>}<div class="mp-contact-card" style="max-width:640px">@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.LeadMagnet, LeadMagnetBlockId = block.Id })</div></div></section>
  }
  else
  {
    var hasImage = !string.IsNullOrWhiteSpace(block.ImageUrl);
    if (hasImage)
    {
      <section class="mp-section"><div class="mp-inner mp-split"><div><div class="mp-kicker">@block.Subheading</div><h2 class="display-6">@block.Heading</h2><div class="mp-lead">@block.Body</div>@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="mp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl) ? "#" : block.ButtonUrl)">@block.ButtonText</a>}</div><img src="@block.ImageUrl" alt="" /></div></section>
    }
    else
    {
      <section class="mp-section"><div class="mp-inner"><div class="mp-kicker">@block.Subheading</div><h2 class="display-6">@block.Heading</h2><div class="mp-lead" style="max-width:820px">@block.Body</div>@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="mp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl) ? "#" : block.ButtonUrl)">@block.ButtonText</a>}</div></section>
    }
  }
}
</main>
