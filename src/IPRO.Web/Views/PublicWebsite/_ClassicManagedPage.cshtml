@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    var agent = Model.Website.AgentUser;
    var blocks = Model.CurrentPage?.Blocks.Where(b => b.IsVisible).OrderBy(b => b.SortOrder).ToList() ?? new();
    var fullName = $"{agent.FirstName} {agent.LastName}".Trim();
}
<style>
  .classic-managed { width:min(1160px,calc(100% - 32px)); margin:28px auto; border:1px solid var(--line); background:#fff; box-shadow:0 18px 44px rgba(14,33,66,.1); }
  .classic-managed__grid { display:grid; grid-template-columns:260px minmax(0,1fr); }
  .classic-managed__side { padding:32px 24px; background:var(--site-theme-deep); color:#fff; }
  .classic-managed__side h2 { font-size:24px; margin:0 0 6px; }
  .classic-managed__side p { color:#c7d2e5; }
  .classic-managed__side a { display:block; color:#fff; text-decoration:none; padding:11px 0; border-bottom:1px solid rgba(255,255,255,.16); }
  .classic-managed__content { min-width:0; }
  .classic-managed .cp-section { padding:var(--section-space, 54px) 48px; border-bottom:1px solid var(--line); }
  .classic-managed .cp-hero { background:var(--site-theme-soft); }
  .classic-managed .cp-hero { position:relative; overflow:hidden; min-height:430px; display:flex; flex-direction:column; justify-content:center; }
  body.hero-style-clean .classic-managed .cp-hero { background:#fff; }
  body.hero-style-classic .classic-managed .cp-hero { background:var(--site-theme-soft); border-top:6px solid var(--site-theme); }
  .classic-managed .cp-hero-copy { position:relative; z-index:2; }
  .classic-managed .cp-hero.align-center .cp-hero-copy { text-align:center; }
  .classic-managed .cp-hero.align-center .cp-copy { margin-left:auto; margin-right:auto; }
  .classic-managed .cp-hero.height-compact,.classic-managed .cp-hero.layout-compact { min-height:300px; }
  .classic-managed .cp-hero.height-tall { min-height:620px; }
  .classic-managed .cp-hero.layout-image-left,.classic-managed .cp-hero.layout-split { display:grid; grid-template-columns:minmax(240px,.8fr) minmax(0,1.2fr); gap:32px; align-items:center; }
  .classic-managed .cp-hero.layout-split .cp-hero-image { order:2; }
  .classic-managed .cp-hero.layout-image-left .cp-hero-image { order:-1; }
  .classic-managed .cp-hero.layout-centered .cp-hero-copy { text-align:center; }
  .classic-managed .cp-hero.layout-centered .cp-copy { margin-left:auto; margin-right:auto; }
  .classic-managed .cp-hero.layout-full-image { color:#fff; background:#17223a; }
  .classic-managed .cp-hero.layout-full-image h1,.classic-managed .cp-hero.layout-full-image .cp-copy { color:#fff; }
  .classic-managed .cp-hero.layout-full-image .cp-hero-image { position:absolute; inset:0; width:100%; height:100%; max-height:none; margin:0; border:0; opacity:var(--hero-image-opacity,.45); }
  .classic-managed .cp-hero.layout-compact .cp-hero-image { display:none; }
  .classic-managed .cp-hero h1 { font-size:52px; line-height:1.05; font-family:Georgia,serif; color:#17223a; }
  .classic-managed h2.fw-bold { font-size:var(--heading-font-size, 22px); }
  .classic-managed .cp-kicker { color:var(--site-theme); font-size:12px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; }
  .classic-managed .cp-copy { color:var(--muted); font-size:var(--body-font-size, 17px); line-height:1.7; max-width:720px; }
  .classic-managed .cp-button { display:inline-block; margin-top:18px; padding:12px 18px; border-radius:var(--button-radius); color:#fff; background:var(--site-theme); text-decoration:none; font-weight:800; }
  .classic-managed .cp-list { margin:24px 0 0; padding:0; list-style:none; display:grid; grid-template-columns:1fr 1fr; gap:0 28px; }
  .classic-managed .cp-list li { padding:13px 0; border-bottom:1px solid var(--line); font-weight:700; }
  .classic-managed .cp-list i { color:var(--site-theme); width:24px; }
  .classic-managed .cp-quote { border-left:4px solid var(--site-theme); padding:18px 20px; margin:18px 0; background:#f7f9fc; font-family:Georgia,serif; }
  .classic-managed .cp-image { width:100%; max-height:420px; object-fit:cover; margin-top:24px; border:1px solid var(--line); }
  .classic-managed .cp-cta-band { background:linear-gradient(120deg, var(--site-theme-deep), var(--site-theme)); color:#fff; text-align:center; }
  .classic-managed .cp-cta-band .cp-kicker { color:#fff; opacity:.85; }
  .classic-managed .cp-cta-band h2 { color:#fff; }
  .classic-managed .cp-cta-band .cp-copy { color:rgba(255,255,255,.86); margin-left:auto; margin-right:auto; }
  .classic-managed .cp-cta-band .cp-button { background:#fff; color:var(--site-theme-deep); }
  .classic-managed .cp-contact-grid { display:grid; grid-template-columns:minmax(0,1fr) minmax(280px,.85fr); gap:36px; align-items:start; }
  .classic-managed .cp-agent { display:flex; align-items:center; gap:14px; margin-top:20px; }
  .classic-managed .cp-avatar { width:56px; height:56px; border-radius:50%; object-fit:cover; flex:none; }
  .classic-managed .cp-contact-mini { margin-top:20px; padding:16px 18px; border:1px solid var(--line); border-radius:8px; background:#f8fbff; }
  .classic-managed .cp-contact-mini a { display:block; color:var(--ink); text-decoration:none; padding:6px 0; font-weight:700; }
  .classic-managed .cp-contact-mini a i { color:var(--site-theme); width:20px; }
  .classic-managed .cp-contact-card { border:1px solid var(--line); border-radius:8px; background:#fff; box-shadow:0 12px 30px rgba(14,33,66,.08); padding:24px; }
  .classic-managed .cp-text-grid { display:grid; grid-template-columns:minmax(0,1.1fr) minmax(240px,.9fr); gap:32px; align-items:center; }
  .classic-managed .cp-text-grid .cp-image { margin-top:0; }
  .classic-managed .cp-card-grid { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; margin-top:24px; }
  .classic-managed .cp-service-card { padding:20px; border:1px solid var(--line); border-radius:8px; background:#f8fbff; }
  .classic-managed .cp-service-card i { color:var(--site-theme); margin-bottom:12px; display:block; font-size:20px; }
  .classic-managed .cp-icon-row { display:grid; grid-template-columns:repeat(3,minmax(0,1fr)); gap:16px; margin-top:24px; text-align:center; }
  .classic-managed .cp-icon-row i { font-size:30px; color:var(--site-theme); margin-bottom:10px; display:block; }
  .classic-managed .cp-featured-quote { border-left:4px solid var(--site-theme); padding:26px 30px; margin:24px 0; background:#f7f9fc; font:italic 22px/1.6 Georgia,serif; max-width:760px; }
  .classic-managed .cp-cta-card { max-width:760px; margin:0 auto; padding:36px; border:1px solid var(--line); border-radius:8px; box-shadow:0 12px 30px rgba(14,33,66,.08); text-align:center; }
  .classic-managed .cp-cta-band.cp-cta-split { text-align:left; }
  .classic-managed .cp-cta-split-grid { display:grid; grid-template-columns:minmax(0,1fr) auto; gap:24px; align-items:center; }
  .classic-managed .cp-cta-split-grid .cp-copy { margin-left:0; }
  @@media(max-width:800px){.classic-managed{width:100%;margin:0;border-left:0;border-right:0}.classic-managed__grid{grid-template-columns:1fr}.classic-managed__side{padding:24px}.classic-managed .cp-section{padding:42px 24px}.classic-managed .cp-hero h1{font-size:40px}.classic-managed .cp-list,.classic-managed .cp-card-grid,.classic-managed .cp-icon-row{grid-template-columns:1fr}.classic-managed .cp-contact-grid,.classic-managed .cp-text-grid,.classic-managed .cp-cta-split-grid{grid-template-columns:1fr}}
</style>
<main class="classic-managed"><div class="classic-managed__grid"><aside class="classic-managed__side"><h2>@fullName</h2><p>@agent.Designation</p><p>@agent.CompanyName</p>@if(!string.IsNullOrWhiteSpace(agent.Phone)){<a href="tel:@agent.Phone"><i class="fas fa-phone me-2"></i>@agent.Phone</a>}@if(!string.IsNullOrWhiteSpace(agent.Email)){<a href="mailto:@agent.Email"><i class="fas fa-envelope me-2"></i>Email me</a>}<div class="mt-4 small">Professional guidance and dependable client service.</div></aside><div class="classic-managed__content">
@foreach(var block in blocks)
{
  if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Hero)
  {
    var hero = IPRO.Entities.WebsiteHeroSettings.FromJson(block.SettingsJson);
    var imageOpacity = Math.Clamp((100 - hero.OverlayStrength) / 100.0, .15, .9).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    <section class="cp-section cp-hero layout-@hero.Layout align-@hero.TextAlignment height-@hero.Height" style="--hero-image-opacity:@imageOpacity">
      <div class="cp-hero-copy"><div class="cp-kicker">@agent.CompanyName</div><h1>@block.Heading</h1><p class="cp-copy">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="cp-copy">@block.Body</p>}@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="cp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl) ? "/contact" : block.ButtonUrl)">@block.ButtonText</a>}</div>
      @if(!string.IsNullOrWhiteSpace(block.ImageUrl)){<img class="cp-image cp-hero-image" src="@block.ImageUrl" alt="" style="object-position:@hero.ImagePosition" />}
    </section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Services)
  {
    var items=block.Body.Split(new[]{'\r','\n'},StringSplitOptions.RemoveEmptyEntries|StringSplitOptions.TrimEntries);
    <section class="cp-section"><div class="cp-kicker">Services</div><h2 class="h2 fw-bold">@block.Heading</h2><p class="cp-copy">@block.Subheading</p>
      @if(block.LayoutVariant == "cards")
      {
        <div class="cp-card-grid">@foreach(var item in items){<div class="cp-service-card"><i class="fas fa-check-circle"></i><div class="fw-bold">@item</div></div>}</div>
      }
      else if(block.LayoutVariant == "icons")
      {
        <div class="cp-icon-row">@foreach(var item in items){<div><i class="fas fa-check-circle"></i><div class="fw-bold">@item</div></div>}</div>
      }
      else
      {
        <ul class="cp-list">@foreach(var item in items){<li><i class="fas fa-check-circle"></i>@item</li>}</ul>
      }
    </section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.ContactForm){<section class="cp-section"><div class="cp-contact-grid"><div><div class="cp-kicker">Contact</div><h2 class="h2 fw-bold">@block.Heading</h2><p class="cp-copy">@block.Subheading</p><p class="cp-copy">@block.Body</p><div class="cp-agent">@if(!string.IsNullOrWhiteSpace(agent.PhotoUrl)){<img src="@agent.PhotoUrl" alt="" class="cp-avatar" />}<div><strong>@($"{agent.FirstName} {agent.LastName}".Trim())</strong><div class="text-muted">@agent.CompanyName</div></div></div><div class="cp-contact-mini">@if(!string.IsNullOrWhiteSpace(agent.Phone)){<a href="tel:@agent.Phone"><i class="fas fa-phone me-2"></i>@agent.Phone</a>}@if(!string.IsNullOrWhiteSpace(agent.Email)){<a href="mailto:@agent.Email"><i class="fas fa-envelope me-2"></i>@agent.Email</a>}</div></div><div class="cp-contact-card">@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Contact })</div></div></section>}
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.TestimonialForm)
  {
    <section class="cp-section"><div class="cp-kicker">@block.Subheading</div><h2 class="h2 fw-bold">@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="cp-copy">@block.Body</p>}<div class="cp-contact-card" style="max-width:640px">@await Html.PartialAsync("_TestimonialForm", new IPRO.Web.Models.TestimonialFormViewModel { PageId = Model.CurrentPage?.Id })</div>@if(Model.ApprovedTestimonials.Any()){@foreach(var t in Model.ApprovedTestimonials){<blockquote class="cp-quote">&ldquo;@t.Body&rdquo;<div class="fw-bold mt-1">@($"{t.FirstName} {t.LastName}".Trim())</div></blockquote>}}</section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.PollResults)
  {
    if(Model.PollResultsByBlockId.TryGetValue(block.Id, out var classicPollData))
    {
      <section class="cp-section"><div class="cp-kicker">@block.Subheading</div><h2 class="h2 fw-bold">@(string.IsNullOrWhiteSpace(block.Heading) ? classicPollData.Title : block.Heading)</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="cp-copy">@block.Body</p>}<div class="cp-contact-card" style="max-width:640px">@await Html.PartialAsync("_PollResults", classicPollData)</div></section>
    }
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.LeadMagnet)
  {
    <section class="cp-section"><div class="cp-kicker">@block.Subheading</div><h2 class="h2 fw-bold">@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="cp-copy">@block.Body</p>}<div class="cp-contact-card" style="max-width:640px">@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.LeadMagnet, LeadMagnetBlockId = block.Id })</div></section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Reviews)
  {
    var cpReview = IPRO.Entities.WebsiteReviewSettings.FromJson(block.SettingsJson);
    var cpFull = (int)Math.Floor(cpReview.Rating);
    var cpHalf = cpReview.Rating - cpFull >= 0.25m && cpReview.Rating - cpFull < 0.75m;
    if (cpReview.Rating - cpFull >= 0.75m) { cpFull++; cpHalf = false; }
    <section class="cp-section" style="text-align:center"><div class="cp-kicker">@block.Subheading</div><h2 class="h2 fw-bold">@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="cp-copy">@block.Body</p>}<div class="cp-contact-card" style="max-width:420px;margin:0 auto;text-align:center">
      <div style="font-size:1.6rem;color:#f59e0b">@for(var i=0;i<5;i++){if(i<cpFull){<i class="fas fa-star"></i>}else if(i==cpFull && cpHalf){<i class="fas fa-star-half-alt"></i>}else{<i class="far fa-star"></i>}}</div>
      <div class="fw-bold fs-4 mt-2">@cpReview.Rating.ToString("0.0") <span class="text-muted fs-6 fw-normal">(@cpReview.ReviewCount review@(cpReview.ReviewCount == 1 ? "" : "s") on @cpReview.Platform)</span></div>
      @if(!string.IsNullOrWhiteSpace(cpReview.ReviewUrl)){<a class="cp-button mt-3" href="@cpReview.ReviewUrl" target="_blank" rel="noopener">@(string.IsNullOrWhiteSpace(block.ButtonText) ? "Read Reviews" : block.ButtonText)</a>}
    </div></section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.CallToAction)
  {
    if(block.LayoutVariant == "card")
    {
      <section class="cp-section"><div class="cp-cta-card"><div class="cp-kicker">Stay connected</div><h2 class="h2 fw-bold">@block.Heading</h2><p class="cp-copy">@block.Subheading</p><a class="cp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText)?"Get in touch":block.ButtonText)</a></div></section>
    }
    else if(block.LayoutVariant == "split")
    {
      <section class="cp-section cp-cta-band cp-cta-split"><div class="cp-cta-split-grid"><div><div class="cp-kicker">Stay connected</div><h2 class="h2 fw-bold">@block.Heading</h2><p class="cp-copy">@block.Subheading</p></div><div><a class="cp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText)?"Get in touch":block.ButtonText)</a></div></div></section>
    }
    else
    {
      <section class="cp-section cp-cta-band"><div class="cp-kicker">Stay connected</div><h2 class="h2 fw-bold">@block.Heading</h2><p class="cp-copy">@block.Subheading</p><a class="cp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText)?"Get in touch":block.ButtonText)</a></section>
    }
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.NewsletterSignup){<section class="cp-section cp-cta-band"><div class="cp-kicker">Stay connected</div><h2 class="h2 fw-bold">@block.Heading</h2><p class="cp-copy">@block.Subheading</p>@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Newsletter })</section>}
  else
  {
    var hasImage = !string.IsNullOrWhiteSpace(block.ImageUrl);
    <section class="cp-section">
      @if (hasImage)
      {
        <div class="cp-text-grid">
          <div><div class="cp-kicker">@block.Subheading</div><h2 class="h2 fw-bold">@block.Heading</h2><div class="cp-copy">@block.Body</div>@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="cp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"#":block.ButtonUrl)">@block.ButtonText</a>}</div>
          <img class="cp-image" src="@block.ImageUrl" alt="" />
        </div>
      }
      else
      {
        <div class="cp-kicker">@block.Subheading</div><h2 class="h2 fw-bold">@block.Heading</h2><div class="cp-copy">@block.Body</div>
        @if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="cp-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"#":block.ButtonUrl)">@block.ButtonText</a>}
      }
    </section>
  }
}
</div></div></main>
