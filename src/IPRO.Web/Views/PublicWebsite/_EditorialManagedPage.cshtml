@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    var agent = Model.Website.AgentUser;
    var blocks = Model.CurrentPage?.Blocks.Where(b => b.IsVisible).OrderBy(b => b.SortOrder).ToList() ?? new();
    var index = 0;
}
<style>
  .editorial-page { background:#fbfaf7; color:#211e1a; }
  .editorial-page .ep-section { padding:96px 7%; }
  .editorial-page .ep-inner { width:min(1180px,100%); margin:0 auto; }
  .editorial-page .ep-kicker { color:var(--site-theme); font:800 12px/1.3 Arial,sans-serif; text-transform:uppercase; letter-spacing:.12em; }
  .editorial-page h1,.editorial-page h2 { font-family:Georgia,serif; letter-spacing:0; }
  .editorial-page .ep-copy { color:#696158; font-size:var(--body-font-size, 19px); line-height:1.8; }
  .editorial-page .ep-hero { min-height:720px; padding:0; display:grid; grid-template-columns:minmax(0,.92fr) minmax(0,1.08fr); background:#fff; }
  .editorial-page .ep-hero-copy { padding:100px 9%; display:flex; flex-direction:column; justify-content:center; }
  .editorial-page .ep-hero h1 { font-size:76px; line-height:.98; margin:18px 0 24px; }
  .editorial-page .ep-hero-visual { min-height:540px; background:var(--site-theme); overflow:hidden; display:flex; align-items:center; justify-content:center; }
  .editorial-page .ep-hero-visual img { width:100%; height:100%; object-fit:cover; }
  .editorial-page .ep-hero.layout-image-left .ep-hero-visual { order:-1; }
  .editorial-page .ep-hero.layout-centered { grid-template-columns:1fr; text-align:center; }
  .editorial-page .ep-hero.layout-centered .ep-hero-copy { align-items:center; }
  .editorial-page .ep-hero.layout-centered .ep-hero-visual { min-height:360px; }
  .editorial-page .ep-hero.align-center .ep-hero-copy { text-align:center; align-items:center; }
  .editorial-page .ep-hero.height-compact,.editorial-page .ep-hero.layout-compact { min-height:420px; }
  .editorial-page .ep-hero.height-tall { min-height:860px; }
  .editorial-page .ep-hero.layout-compact { grid-template-columns:1fr; }
  .editorial-page .ep-hero.layout-compact .ep-hero-visual { display:none; }
  .editorial-page .ep-hero.layout-full-image { position:relative; isolation:isolate; display:flex; align-items:center; color:#fff; background:#211e1a; }
  .editorial-page .ep-hero.layout-full-image .ep-hero-copy { position:relative; z-index:2; width:min(900px,100%); }
  .editorial-page .ep-hero.layout-full-image h1,.editorial-page .ep-hero.layout-full-image .ep-copy { color:#fff; }
  .editorial-page .ep-hero.layout-full-image .ep-hero-visual { position:absolute; inset:0; z-index:-1; width:100%; height:100%; min-height:0; opacity:var(--hero-image-opacity,.45); }
  .editorial-page .ep-hero-visual i { color:rgba(255,255,255,.72); font-size:120px; }
  .editorial-page .ep-button { display:inline-flex; align-self:flex-start; margin-top:22px; padding:13px 20px; border-radius:var(--button-radius); background:var(--site-theme); color:#fff; text-decoration:none; font-family:Arial,sans-serif; font-weight:800; }
  .editorial-page .ep-feature { display:grid; grid-template-columns:minmax(0,.8fr) minmax(0,1.2fr); gap:90px; align-items:start; border-top:1px solid #d9d3c9; }
  .editorial-page .ep-feature.reverse { grid-template-columns:minmax(0,1.2fr) minmax(0,.8fr); }
  .editorial-page .ep-feature.reverse .ep-heading { order:2; }
  .editorial-page .ep-heading h2 { font-size:var(--heading-font-size, 22px); line-height:1.05; margin-top:16px; }
  .editorial-page .ep-list { display:grid; gap:0; }
  .editorial-page .ep-list-item { padding:24px 0; border-bottom:1px solid #d9d3c9; font:700 20px/1.4 Georgia,serif; }
  .editorial-page .ep-list-item span { display:inline-flex; width:34px; color:var(--site-theme); font:800 12px Arial,sans-serif; }
  .editorial-page .ep-image { width:100%; max-height:540px; object-fit:cover; margin-top:26px; }
  .editorial-page .ep-quote { font:italic 27px/1.55 Georgia,serif; padding:26px 0; border-bottom:1px solid #d9d3c9; }
  .editorial-page .ep-cta { background:#241f1a; color:#fff; }
  .editorial-page .ep-cta .ep-copy { color:#d8d0c5; }
  .editorial-page .ep-contact { display:grid; grid-template-columns:1fr 1fr; gap:80px; }
  @@media(max-width:820px){.editorial-page .ep-section{padding:64px 24px}.editorial-page .ep-hero{grid-template-columns:1fr}.editorial-page .ep-hero-copy{padding:60px 24px}.editorial-page .ep-hero h1{font-size:48px}.editorial-page .ep-hero-visual{min-height:280px;order:-1}.editorial-page .ep-feature,.editorial-page .ep-feature.reverse,.editorial-page .ep-contact{grid-template-columns:1fr;gap:30px}.editorial-page .ep-feature.reverse .ep-heading{order:0}}
</style>
<main class="editorial-page">
@foreach(var block in blocks)
{
  index++;
  if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Hero)
  {
    var hero = IPRO.Entities.WebsiteHeroSettings.FromJson(block.SettingsJson);
    var imageOpacity = Math.Clamp((100 - hero.OverlayStrength) / 100.0, .15, .9).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    <section class="ep-hero layout-@hero.Layout align-@hero.TextAlignment height-@hero.Height" style="--hero-image-opacity:@imageOpacity">
      <div class="ep-hero-copy"><div class="ep-kicker">@agent.CompanyName</div><h1>@block.Heading</h1><p class="ep-copy">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy">@block.Body</p>}@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@block.ButtonText</a>}</div>
      <div class="ep-hero-visual">@if(!string.IsNullOrWhiteSpace(block.ImageUrl)){<img src="@block.ImageUrl" alt="" style="object-position:@hero.ImagePosition" />}else{<i class="fas fa-arrow-trend-up"></i>}</div>
    </section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Services){var items=block.Body.Split(new[]{'\r','\n'},StringSplitOptions.RemoveEmptyEntries|StringSplitOptions.TrimEntries);<section class="ep-section"><div class="ep-inner ep-feature @(index%2==0?"reverse":"")"><div class="ep-heading"><div class="ep-kicker">Services</div><h2>@block.Heading</h2><p class="ep-copy">@block.Subheading</p></div><div class="ep-list">@for(var i=0;i<items.Length;i++){<div class="ep-list-item"><span>@((i+1).ToString("00"))</span>@items[i]</div>}</div></div></section>}
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Testimonials){var items=block.Body.Split(new[]{'\r','\n'},StringSplitOptions.RemoveEmptyEntries|StringSplitOptions.TrimEntries);<section class="ep-section"><div class="ep-inner ep-feature"><div class="ep-heading"><div class="ep-kicker">Perspectives</div><h2>@block.Heading</h2></div><div>@foreach(var item in items){<blockquote class="ep-quote">&ldquo;@item&rdquo;</blockquote>}</div></div></section>}
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.CallToAction || block.BlockType == IPRO.Entities.WebsiteBlockTypes.NewsletterSignup){<section class="ep-section ep-cta"><div class="ep-inner ep-feature"><div class="ep-heading"><div class="ep-kicker" style="color:#fff">Continue the conversation</div><h2>@block.Heading</h2></div><div><p class="ep-copy">@block.Subheading</p><p class="ep-copy">@block.Body</p>@if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.NewsletterSignup){@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Newsletter })}else{<a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText)?"Connect":block.ButtonText)</a>}</div></div></section>}
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.ContactForm){<section class="ep-section"><div class="ep-inner ep-contact"><div class="ep-heading"><div class="ep-kicker">Contact</div><h2>@block.Heading</h2><p class="ep-copy">@block.Subheading</p><p class="ep-copy">@block.Body</p><h3>@($"{agent.FirstName} {agent.LastName}".Trim())</h3><p>@agent.CompanyName</p>@if(!string.IsNullOrWhiteSpace(agent.Phone)){<p><a href="tel:@agent.Phone">@agent.Phone</a></p>}</div><div>@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Contact })</div></div></section>}
  else{<section class="ep-section"><div class="ep-inner ep-feature @(index%2==0?"reverse":"")"><div class="ep-heading"><div class="ep-kicker">@block.Subheading</div><h2>@block.Heading</h2></div><div><div class="ep-copy">@block.Body</div>@if(!string.IsNullOrWhiteSpace(block.ImageUrl)){<img class="ep-image" src="@block.ImageUrl" alt="" />}@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"#":block.ButtonUrl)">@block.ButtonText</a>}</div></div></section>}
}
</main>
