@model IPRO.Web.Models.PublicWebsiteViewModel
@functions {
    private static string HeroMonogram(IPRO.Entities.AgentUser agent)
    {
        if (!string.IsNullOrWhiteSpace(agent.FirstName)) return agent.FirstName.Substring(0, 1).ToUpperInvariant();
        if (!string.IsNullOrWhiteSpace(agent.CompanyName)) return agent.CompanyName.Substring(0, 1).ToUpperInvariant();
        return "•";
    }
}
@{
    var agent = Model.Website.AgentUser;
    var blocks = Model.CurrentPage?.Blocks.Where(b => b.IsVisible).OrderBy(b => b.SortOrder).ToList() ?? new();
    var index = 0;
}
<style>
  .editorial-page { background:#fbfaf7; color:#211e1a; }
  .editorial-page .ep-section { padding:var(--section-space, 96px) 7%; }
  .editorial-page .ep-inner { width:min(1180px,100%); margin:0 auto; }
  .editorial-page .ep-kicker { color:var(--site-theme); font:800 12px/1.3 Arial,sans-serif; text-transform:uppercase; letter-spacing:.12em; }
  .editorial-page h1,.editorial-page h2 { font-family:Georgia,serif; letter-spacing:0; }
  .editorial-page .ep-copy { color:#696158; font-size:var(--body-font-size, 19px); line-height:1.8; }
  .editorial-page .ep-hero { min-height:720px; padding:0; display:grid; grid-template-columns:minmax(0,.92fr) minmax(0,1.08fr); background:#fff; }
  .editorial-page .ep-hero-copy { padding:100px 9%; display:flex; flex-direction:column; justify-content:center; }
  .editorial-page .ep-hero h1 { font-size:76px; line-height:.98; margin:18px 0 24px; }
  .editorial-page .ep-hero-visual { min-height:540px; position:relative; overflow:hidden; background:linear-gradient(155deg, var(--site-theme-deep), var(--site-theme)); display:flex; align-items:center; justify-content:center; }
  .editorial-page .ep-hero-visual::before { content:""; position:absolute; inset:0; background-image:repeating-linear-gradient(135deg, rgba(255,255,255,.05) 0 2px, transparent 2px 28px); }
  .editorial-page .ep-hero-mark { position:relative; z-index:1; font-family:Georgia,serif; font-weight:700; font-size:clamp(180px, 24vw, 340px); line-height:1; color:rgba(255,255,255,.16); user-select:none; }
  body.hero-style-clean .editorial-page .ep-hero-visual { background:#f4f2ef; }
  body.hero-style-clean .editorial-page .ep-hero-visual::before { background-image:repeating-linear-gradient(135deg, rgba(33,30,26,.04) 0 2px, transparent 2px 28px); }
  body.hero-style-clean .editorial-page .ep-hero-mark { color:rgba(33,30,26,.1); }
  body.hero-style-classic .editorial-page .ep-hero-visual { background:linear-gradient(155deg, var(--site-theme-deep), var(--site-theme)); border:8px solid var(--site-theme-soft); }
  .editorial-page .ep-hero-visual img { width:100%; height:100%; object-fit:cover; position:relative; z-index:1; }
  .editorial-page .ep-hero.layout-image-left .ep-hero-visual { order:-1; }
  .editorial-page .ep-hero.layout-centered { grid-template-columns:1fr; text-align:center; }
  .editorial-page .ep-hero.layout-centered .ep-hero-copy { align-items:center; }
  .editorial-page .ep-hero.layout-centered .ep-hero-visual { min-height:360px; }
  .editorial-page .ep-hero.align-center .ep-hero-copy { text-align:center; align-items:center; }
  .editorial-page .ep-hero.height-compact,.editorial-page .ep-hero.layout-compact { min-height:420px; }
  .editorial-page .ep-hero.height-tall { min-height:860px; }
  .editorial-page .ep-hero.layout-compact { grid-template-columns:1fr; }
  .editorial-page .ep-hero.layout-compact .ep-hero-visual { display:none; }
  .editorial-page .ep-hero.layout-full-image { position:relative; isolation:isolate; display:flex; align-items:center; color:#fff; background:#211e1a; }
  .editorial-page .ep-hero.layout-full-image .ep-hero-copy { position:relative; z-index:2; width:min(900px,100%); }
  .editorial-page .ep-hero.layout-full-image h1,.editorial-page .ep-hero.layout-full-image .ep-copy { color:#fff; }
  .editorial-page .ep-hero.layout-full-image .ep-hero-visual { position:absolute; inset:0; z-index:-1; width:100%; height:100%; min-height:0; opacity:var(--hero-image-opacity,.45); }
  .editorial-page .ep-button { display:inline-flex; align-self:flex-start; margin-top:22px; padding:13px 20px; border-radius:var(--button-radius); background:var(--site-theme); color:#fff; text-decoration:none; font-family:Arial,sans-serif; font-weight:800; }
  .editorial-page .ep-feature { display:grid; grid-template-columns:minmax(0,.8fr) minmax(0,1.2fr); gap:90px; align-items:start; border-top:1px solid #d9d3c9; }
  .editorial-page .ep-feature.reverse { grid-template-columns:minmax(0,1.2fr) minmax(0,.8fr); }
  .editorial-page .ep-feature.reverse .ep-heading { order:2; }
  .editorial-page .ep-heading h2 { font-size:var(--heading-font-size, 22px); line-height:1.05; margin-top:16px; }
  .editorial-page .ep-list { display:grid; gap:0; }
  .editorial-page .ep-list-item { padding:24px 0; border-bottom:1px solid #d9d3c9; font:700 20px/1.4 Georgia,serif; }
  .editorial-page .ep-list-item span { display:inline-flex; width:34px; color:var(--site-theme); font:800 12px Arial,sans-serif; }
  .editorial-page .ep-image { width:100%; max-height:540px; object-fit:cover; margin-top:26px; }
  .editorial-page .ep-quote { font:italic 27px/1.55 Georgia,serif; padding:26px 0; border-bottom:1px solid #d9d3c9; }
  .editorial-page .ep-quote-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:20px; }
  .editorial-page .ep-quote-grid .ep-quote { font-size:22px; border:1px solid #d9d3c9; border-bottom:1px solid #d9d3c9; padding:24px; }
  .editorial-page .ep-alt { background:var(--site-theme-soft); }
  .editorial-page .ep-cta { background:#241f1a; color:#fff; }
  .editorial-page .ep-cta .ep-copy { color:#d8d0c5; }
  .editorial-page .ep-contact { display:grid; grid-template-columns:1fr 1fr; gap:80px; }
  .editorial-page .ep-avatar { display:block; width:72px; height:72px; border-radius:50%; object-fit:cover; margin-bottom:16px; }
  .editorial-page .ep-agent-band { display:flex; gap:40px; align-items:flex-start; margin-top:28px; }
  .editorial-page .ep-agent-photo { width:140px; height:140px; border-radius:50%; object-fit:cover; flex:none; }
  .editorial-page .ep-agent-name { font-family:Georgia,serif; font-size:34px; }
  .editorial-page .ep-agent-role { color:var(--muted); font-size:17px; margin:4px 0 18px; }
  .editorial-page .ep-agent-detail { color:var(--ink); font-size:16px; line-height:1.7; }
  .editorial-page .ep-agent-detail a { color:var(--ink); text-decoration:none; }
  .editorial-page .ep-agent-detail a:hover { color:var(--site-theme); }
  .editorial-page .ep-card-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:20px; }
  .editorial-page .ep-service-card { padding:24px; border:1px solid #d9d3c9; }
  .editorial-page .ep-service-card i { color:var(--site-theme); margin-bottom:12px; display:block; font-size:20px; }
  .editorial-page .ep-icon-row { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:20px; }
  .editorial-page .ep-icon-row > div { text-align:center; }
  .editorial-page .ep-icon-row i { font-size:30px; color:var(--site-theme); margin-bottom:10px; display:block; }
  .editorial-page .ep-featured-quote { font:italic 32px/1.5 Georgia,serif; max-width:820px; border-bottom:0; }
  .editorial-page .ep-cta-banner .ep-inner { text-align:center; }
  .editorial-page .ep-cta-banner .ep-copy { margin-left:auto; margin-right:auto; }
  .editorial-page .ep-cta-card { max-width:760px; margin:0 auto; padding:44px; border:1px solid #3a342c; text-align:center; }
  @@media(max-width:820px){.editorial-page .ep-section{padding:64px 24px}.editorial-page .ep-hero{grid-template-columns:1fr}.editorial-page .ep-hero-copy{padding:60px 24px}.editorial-page .ep-hero h1{font-size:48px}.editorial-page .ep-hero-visual{min-height:280px;order:-1}.editorial-page .ep-feature,.editorial-page .ep-feature.reverse,.editorial-page .ep-contact,.editorial-page .ep-card-grid,.editorial-page .ep-icon-row,.editorial-page .ep-quote-grid{grid-template-columns:1fr;gap:30px}.editorial-page .ep-feature.reverse .ep-heading{order:0}.editorial-page .ep-agent-band{flex-direction:column;align-items:center;text-align:center;gap:20px}}
</style>
<main class="editorial-page">
@foreach(var block in blocks)
{
  index++;
  if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Hero)
  {
    var hero = IPRO.Entities.WebsiteHeroSettings.FromJson(block.SettingsJson);
    var imageOpacity = Math.Clamp((100 - hero.OverlayStrength) / 100.0, .15, .9).ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
    <section class="ep-hero layout-@hero.Layout align-@hero.TextAlignment height-@hero.Height" style="--hero-image-opacity:@imageOpacity">
      <div class="ep-hero-copy"><div class="ep-kicker">@agent.CompanyName</div><h1>@block.Heading</h1><p class="ep-copy">@block.Subheading</p>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy">@block.Body</p>}@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@block.ButtonText</a>}</div>
      <div class="ep-hero-visual">@if(!string.IsNullOrWhiteSpace(block.ImageUrl)){<img src="@block.ImageUrl" alt="" style="object-position:@hero.ImagePosition" />}else{<div class="ep-hero-mark" aria-hidden="true">@(HeroMonogram(agent))</div>}</div>
    </section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Services)
  {
    var items=block.Body.Split(new[]{'\r','\n'},StringSplitOptions.RemoveEmptyEntries|StringSplitOptions.TrimEntries);
    <section class="ep-section ep-alt"><div class="ep-inner ep-feature @(index%2==0?"reverse":"")"><div class="ep-heading"><div class="ep-kicker">Services</div><h2>@block.Heading</h2><p class="ep-copy">@block.Subheading</p></div>
      @if(block.LayoutVariant == "cards")
      {
        <div class="ep-card-grid">@foreach(var item in items){<div class="ep-service-card"><i class="fas fa-check"></i><div>@item</div></div>}</div>
      }
      else if(block.LayoutVariant == "icons")
      {
        <div class="ep-icon-row">@foreach(var item in items){<div><i class="fas fa-check"></i><div>@item</div></div>}</div>
      }
      else
      {
        <div class="ep-list">@for(var i=0;i<items.Length;i++){<div class="ep-list-item"><span>@((i+1).ToString("00"))</span>@items[i]</div>}</div>
      }
    </div></section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.CallToAction)
  {
    if(block.LayoutVariant == "banner")
    {
      <section class="ep-section ep-cta ep-cta-banner"><div class="ep-inner"><div class="ep-kicker" style="color:#fff">Continue the conversation</div><h2>@block.Heading</h2><p class="ep-copy">@block.Subheading</p><p class="ep-copy">@block.Body</p><a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText)?"Connect":block.ButtonText)</a></div></section>
    }
    else if(block.LayoutVariant == "card")
    {
      <section class="ep-section ep-cta"><div class="ep-inner"><div class="ep-cta-card"><div class="ep-kicker" style="color:#fff">Continue the conversation</div><h2>@block.Heading</h2><p class="ep-copy">@block.Subheading</p><a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText)?"Connect":block.ButtonText)</a></div></div></section>
    }
    else
    {
      <section class="ep-section ep-cta"><div class="ep-inner ep-feature"><div class="ep-heading"><div class="ep-kicker" style="color:#fff">Continue the conversation</div><h2>@block.Heading</h2></div><div><p class="ep-copy">@block.Subheading</p><p class="ep-copy">@block.Body</p><a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"/contact":block.ButtonUrl)">@(string.IsNullOrWhiteSpace(block.ButtonText)?"Connect":block.ButtonText)</a></div></div></section>
    }
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.NewsletterSignup){<section class="ep-section ep-cta"><div class="ep-inner ep-feature"><div class="ep-heading"><div class="ep-kicker" style="color:#fff">Continue the conversation</div><h2>@block.Heading</h2></div><div><p class="ep-copy">@block.Subheading</p><p class="ep-copy">@block.Body</p>@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Newsletter })</div></div></section>}
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.ContactForm){<section class="ep-section"><div class="ep-inner ep-contact"><div class="ep-heading"><div class="ep-kicker">Contact</div><h2>@block.Heading</h2><p class="ep-copy">@block.Subheading</p><p class="ep-copy">@block.Body</p>@if(!string.IsNullOrWhiteSpace(agent.PhotoUrl)){<img src="@agent.PhotoUrl" alt="" class="ep-avatar" />}<h3>@($"{agent.FirstName} {agent.LastName}".Trim())</h3><p>@agent.CompanyName</p>@if(!string.IsNullOrWhiteSpace(agent.Phone)){<p><a href="tel:@agent.Phone">@agent.Phone</a></p>}</div><div>@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.Contact })</div></div></section>}
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.TestimonialForm)
  {
    <section class="ep-section ep-alt"><div class="ep-inner"><div class="ep-kicker">@block.Subheading</div><h2>@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy">@block.Body</p>}<div style="max-width:640px">@await Html.PartialAsync("_TestimonialForm", new IPRO.Web.Models.TestimonialFormViewModel { PageId = Model.CurrentPage?.Id })</div>@if(Model.ApprovedTestimonials.Any()){if(block.LayoutVariant == "grid"){<div class="ep-quote-grid">@foreach(var t in Model.ApprovedTestimonials){<blockquote class="ep-quote">&ldquo;@t.Body&rdquo;<div class="fw-bold mt-1">@($"{t.FirstName} {t.LastName}".Trim())</div></blockquote>}</div>}else{<div>@foreach(var t in Model.ApprovedTestimonials){<blockquote class="ep-quote">&ldquo;@t.Body&rdquo;<div class="fw-bold mt-1">@($"{t.FirstName} {t.LastName}".Trim())</div></blockquote>}</div>}}</div></section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.PollResults)
  {
    if(Model.PollResultsByBlockId.TryGetValue(block.Id, out var editorialPollData))
    {
      <section class="ep-section"><div class="ep-inner"><div class="ep-kicker">@block.Subheading</div><h2>@(string.IsNullOrWhiteSpace(block.Heading) ? editorialPollData.Title : block.Heading)</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy">@block.Body</p>}<div style="max-width:640px">@await Html.PartialAsync("_PollResults", editorialPollData)</div></div></section>
    }
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.LeadMagnet)
  {
    <section class="ep-section"><div class="ep-inner"><div class="ep-kicker">@block.Subheading</div><h2>@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy">@block.Body</p>}<div style="max-width:640px">@await Html.PartialAsync("_WebsiteLeadForm", new IPRO.Web.Models.WebsiteLeadFormViewModel { PageId = Model.CurrentPage?.Id, SubmissionType = IPRO.Entities.WebsiteLeadTypes.LeadMagnet, LeadMagnetBlockId = block.Id })</div></div></section>
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Reviews)
  {
    var epReview = IPRO.Entities.WebsiteReviewSettings.FromJson(block.SettingsJson);
    var epFull = (int)Math.Floor(epReview.Rating);
    var epHalf = epReview.Rating - epFull >= 0.25m && epReview.Rating - epFull < 0.75m;
    if (epReview.Rating - epFull >= 0.75m) { epFull++; epHalf = false; }
    if (block.LayoutVariant == "banner")
    {
      <section class="ep-section ep-cta ep-cta-banner"><div class="ep-inner"><div class="ep-kicker" style="color:#fff">@(string.IsNullOrWhiteSpace(block.Subheading) ? "Trusted by clients" : block.Subheading)</div><h2>@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy">@block.Body</p>}
        <div style="font-size:1.6rem;color:#fff">@for(var i=0;i<5;i++){if(i<epFull){<i class="fas fa-star"></i>}else if(i==epFull && epHalf){<i class="fas fa-star-half-alt"></i>}else{<i class="far fa-star"></i>}}</div>
        <p class="ep-copy">@epReview.Rating.ToString("0.0") <span style="opacity:.85">(@epReview.ReviewCount review@(epReview.ReviewCount == 1 ? "" : "s") on @epReview.Platform)</span></p>
        @if(!string.IsNullOrWhiteSpace(epReview.ReviewUrl)){<a class="ep-button" href="@epReview.ReviewUrl" target="_blank" rel="noopener">@(string.IsNullOrWhiteSpace(block.ButtonText) ? "Read Reviews" : block.ButtonText)</a>}
      </div></section>
    }
    else
    {
      <section class="ep-section ep-alt"><div class="ep-inner" style="text-align:center;display:block"><div class="ep-kicker">@block.Subheading</div><h2>@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy">@block.Body</p>}<div style="max-width:420px;margin:0 auto;text-align:center">
        <div style="font-size:1.6rem;color:#f59e0b">@for(var i=0;i<5;i++){if(i<epFull){<i class="fas fa-star"></i>}else if(i==epFull && epHalf){<i class="fas fa-star-half-alt"></i>}else{<i class="far fa-star"></i>}}</div>
        <div class="fw-bold fs-4 mt-2">@epReview.Rating.ToString("0.0") <span class="text-muted fs-6 fw-normal">(@epReview.ReviewCount review@(epReview.ReviewCount == 1 ? "" : "s") on @epReview.Platform)</span></div>
        @if(!string.IsNullOrWhiteSpace(epReview.ReviewUrl)){<a class="ep-button mt-3" href="@epReview.ReviewUrl" target="_blank" rel="noopener">@(string.IsNullOrWhiteSpace(block.ButtonText) ? "Read Reviews" : block.ButtonText)</a>}
      </div></div></section>
    }
  }
  else if(block.BlockType == IPRO.Entities.WebsiteBlockTypes.AgentInfo)
  {
    var epAgentInfo = IPRO.Entities.WebsiteAgentInfoSettings.FromJson(block.SettingsJson);
    var epAddressLines = epAgentInfo.ShowAddress ? agent.GetFormattedAddressLines() : new List<string>();
    var epDesignationLine = string.Join(" · ", new[] { agent.Designation, agent.CompanyName }.Where(s => !string.IsNullOrWhiteSpace(s)));
    <section class="ep-section"><div class="ep-inner"><div class="ep-kicker">@block.Subheading</div><h2>@block.Heading</h2>@if(!string.IsNullOrWhiteSpace(block.Body)){<p class="ep-copy" style="max-width:720px">@block.Body</p>}
      <div class="ep-agent-band">
        @if(epAgentInfo.ShowPhoto && !string.IsNullOrWhiteSpace(agent.PhotoUrl)){<img src="@agent.PhotoUrl" alt="" class="ep-agent-photo" />}
        <div>
          <div class="ep-agent-name">@($"{agent.FirstName} {agent.LastName}".Trim())</div>
          @if(epAgentInfo.ShowDesignation && !string.IsNullOrWhiteSpace(epDesignationLine)){<div class="ep-agent-role">@epDesignationLine</div>}
          @if(epAddressLines.Any()){<div class="ep-agent-detail">@foreach(var line in epAddressLines){<div>@line</div>}</div>}
          @if(epAgentInfo.ShowPhone && !string.IsNullOrWhiteSpace(agent.Phone)){<div class="ep-agent-detail mt-2"><a href="tel:@agent.Phone">@agent.Phone</a></div>}
          @if(epAgentInfo.ShowEmail && !string.IsNullOrWhiteSpace(agent.Email)){<div class="ep-agent-detail"><a href="mailto:@agent.Email">@agent.Email</a></div>}
        </div>
      </div>
    </div></section>
  }
  else
  {
    var hasImage = !string.IsNullOrWhiteSpace(block.ImageUrl);
    if (hasImage)
    {
      var epReversed = block.LayoutVariant == "image-left" ? true : block.LayoutVariant == "image-right" ? false : index % 2 == 0;
      <section class="ep-section"><div class="ep-inner ep-feature @(epReversed?"reverse":"")"><div class="ep-heading"><div class="ep-kicker">@block.Subheading</div><h2>@block.Heading</h2></div><div><div class="ep-copy">@block.Body</div><img class="ep-image" src="@block.ImageUrl" alt="" />@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"#":block.ButtonUrl)">@block.ButtonText</a>}</div></div></section>
    }
    else
    {
      <section class="ep-section"><div class="ep-inner"><div class="ep-kicker">@block.Subheading</div><h2>@block.Heading</h2><div class="ep-copy" style="max-width:820px">@block.Body</div>@if(!string.IsNullOrWhiteSpace(block.ButtonText)){<a class="ep-button" href="@(string.IsNullOrWhiteSpace(block.ButtonUrl)?"#":block.ButtonUrl)">@block.ButtonText</a>}</div></section>
    }
  }
}
</main>
