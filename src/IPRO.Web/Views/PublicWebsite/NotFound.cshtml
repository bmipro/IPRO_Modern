@model string
@inject IConfiguration Configuration
@{
    Layout = null;
    var host = Model ?? "this domain";
    var loginUrl = $"{IPRO.Web.Infrastructure.PortalUrlHelper.GetAgentPortalBaseUrl(Configuration)}/Account/Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Website Not Published - IPRO Advisers</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body {
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: #eef4ff;
      color: #172033;
      font-family: Arial, Helvetica, sans-serif;
    }
    .notice {
      width: min(560px, calc(100vw - 32px));
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, .12);
      padding: 40px;
    }
  </style>
</head>
<body>
  <main class="notice text-center">
    <div class="text-primary fw-bold text-uppercase mb-2" style="letter-spacing:.08em;">IPRO Advisers</div>
    <h1 class="h3 fw-bold">Website not published yet</h1>
    <p class="text-muted mb-3">The domain <strong>@host</strong> is connected, but the agent website is not published or could not be found.</p>
    <p class="mb-0">If this is your website, <a href="@loginUrl">sign in to the agent portal</a> and click <strong>Publish</strong> under My Website to make it live.</p>
  </main>
</body>
</html>
