@model IPRO.Web.Models.PublicWebsiteViewModel
<footer class="modern-footer">
  <div class="modern-footer__inner">
    @await Html.PartialAsync("_PublicFooterContent", Model)
  </div>
</footer>
<style>
  .modern-footer { background: #fff; border-top: 1px solid #dbe4f0; padding: 28px 0; }
  .modern-footer__inner { max-width: 1140px; margin: 0 auto; padding: 0 24px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 14px 28px; color: #425066; font-size: 14px; }
  .modern-footer__inner .public-footer__copyright { font-weight: 700; color: #111827; }
  .modern-footer__inner .public-footer__contact { display: flex; flex-wrap: wrap; gap: 16px; }
  .modern-footer__inner .public-footer__contact a { color: #425066; text-decoration: none; }
  .modern-footer__inner .public-footer__contact a:hover { color: var(--site-theme, #1457d9); }
  .modern-footer__inner .public-footer__contact i { color: var(--site-theme, #1457d9); margin-right: 6px; }
  .modern-footer__inner .public-footer__social { display: flex; gap: 12px; }
  .modern-footer__inner .public-footer__social a { color: #425066; font-size: 16px; }
  .modern-footer__inner .public-footer__social a:hover { color: var(--site-theme, #1457d9); }
  .modern-footer__inner .public-footer__legal { display: flex; flex-wrap: wrap; gap: 14px; }
  .modern-footer__inner .public-footer__legal a { color: #425066; text-decoration: none; }
  .modern-footer__inner .public-footer__legal a:hover { text-decoration: underline; }
  .modern-footer__inner .public-footer__disclaimer { width: 100%; color: #8492a6; font-size: 12px; }
</style>
