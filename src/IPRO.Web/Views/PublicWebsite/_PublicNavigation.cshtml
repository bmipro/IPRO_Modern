@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    var website = Model.Website;
    var topPages = Model.Pages.Where(p => p.ShowInNavigation && p.ParentPageId == null).OrderBy(p => p.SortOrder).ToList();
}
<header class="public-site-header">
  <div class="public-site-header__inner">
    <a href="/" class="public-site-brand">
      @if (!string.IsNullOrWhiteSpace(website.LogoUrl))
      {
        <img src="@website.LogoUrl" alt="@website.AgentUser.CompanyName logo" />
      }
      else
      {
        @website.AgentUser.CompanyName
      }
    </a>
    <nav class="public-site-nav" aria-label="Main navigation">
      @foreach (var sitePage in topPages)
      {
        var children = Model.Pages.Where(p => p.ShowInNavigation && p.ParentPageId == sitePage.Id).OrderBy(p => p.SortOrder).ToList();
        <div class="public-site-nav__item">
          <a href="@(sitePage.IsHomePage ? "/" : "/" + sitePage.Slug)">@sitePage.NavigationLabel</a>
          @if (children.Any())
          {
            <div class="public-site-nav__children">
              @foreach (var child in children)
              {
                <a href="/@child.Slug">@child.NavigationLabel</a>
              }
            </div>
          }
        </div>
      }
    </nav>
  </div>
</header>
