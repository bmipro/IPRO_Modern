@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    var website = Model.Website;
    var topPages = Model.Pages.Where(p => p.ShowInNavigation && p.ParentPageId == null).OrderBy(p => p.SortOrder).ToList();
    var header = IPRO.Entities.WebsiteHeaderSettings.FromJson(website.HeaderSettingsJson);
    var headerClasses = $"public-site-header style-{header.Style} logo-{header.LogoPosition} logo-size-{header.LogoSize}" + (header.Sticky ? " is-sticky" : "");
}
<header class="@headerClasses">
  <div class="public-site-header__inner">
    <a href="/" class="public-site-brand">
      @if (!string.IsNullOrWhiteSpace(website.LogoUrl))
      {
        <img src="@website.LogoUrl" alt="@website.AgentUser.CompanyName logo" />
      }
      else
      {
        @website.AgentUser.CompanyName
      }
    </a>
    <nav class="public-site-nav" aria-label="Main navigation">
      @foreach (var sitePage in topPages)
      {
        var children = Model.Pages.Where(p => p.ShowInNavigation && p.ParentPageId == sitePage.Id).OrderBy(p => p.SortOrder).ToList();
        <div class="public-site-nav__item">
          <a href="@(sitePage.IsHomePage ? "/" : "/" + sitePage.Slug)">@sitePage.NavigationLabel</a>
          @if (children.Any())
          {
            <div class="public-site-nav__children">
              @foreach (var child in children)
              {
                <a href="/@child.Slug">@child.NavigationLabel</a>
              }
            </div>
          }
        </div>
      }
      @foreach (var link in header.CustomLinks.OrderBy(link => link.SortOrder))
      {
        <div class="public-site-nav__item"><a href="@link.Url">@link.Label</a></div>
      }
    </nav>
    <div class="public-site-actions">
      @if (header.ShowPhone && !string.IsNullOrWhiteSpace(website.AgentUser.Phone))
      {
        <a class="public-site-action" href="tel:@website.AgentUser.Phone" aria-label="Call @website.AgentUser.Phone"><i class="fas fa-phone"></i><span>@website.AgentUser.Phone</span></a>
      }
      @if (header.ShowEmail && !string.IsNullOrWhiteSpace(website.AgentUser.Email))
      {
        <a class="public-site-action" href="mailto:@website.AgentUser.Email" aria-label="Email @website.AgentUser.Email"><i class="fas fa-envelope"></i><span>Email</span></a>
      }
      @if (!string.IsNullOrWhiteSpace(header.ButtonText))
      {
        <a class="public-site-cta" href="@(string.IsNullOrWhiteSpace(header.ButtonUrl) ? "/contact" : header.ButtonUrl)">@header.ButtonText</a>
      }
    </div>
  </div>
</header>
