@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    var website = Model.Website;
    var agent = website.AgentUser;
    var title = string.IsNullOrWhiteSpace(website.SiteTitle)
        ? $"{agent.FirstName} {agent.LastName}".Trim()
        : website.SiteTitle;
    var tagline = string.IsNullOrWhiteSpace(website.TagLine)
        ? "Professional advice, practical service, and a better way to stay connected."
        : website.TagLine;
    var design = IPRO.Entities.WebsiteTemplateDesign.FromTemplate(website.Template, new IPRO.Entities.AgentDesignOverrides
    {
        ThemeColor = website.ThemeColor,
        FontFamily = website.FontFamilyOverride,
        HeadingFontSize = website.HeadingFontSizeOverride,
        BodyFontSize = website.BodyFontSizeOverride,
        BackgroundColor = website.BackgroundColorOverride,
        ButtonStyle = website.ButtonStyleOverride,
        SectionSpacing = website.SectionSpacingOverride,
        HeroStyle = website.HeroStyleOverride
    });
    var theme = design.AccentColor;
    var background = design.BackgroundColor;
    var fontFamily = design.FontFamily;
    var sectionSpace = design.SectionSpacing == "compact" ? "44px" : design.SectionSpacing == "comfortable" ? "62px" : "82px";
    var buttonRadius = design.ButtonStyle == "square" ? "2px" : design.ButtonStyle == "pill" ? "999px" : "7px";
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  @await Html.PartialAsync("_PublicSeoHead", Model)
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <style>
    :root {
      --site-theme: @theme;
      --site-theme-deep: #07142f;
      --site-theme-soft: #eef4ff;
      --section-space: @sectionSpace;
      --button-radius: @buttonRadius;
      --heading-font-size: @(design.HeadingFontSize)px;
      --body-font-size: @(design.BodyFontSize)px;
    }
    body {
      margin: 0;
      color: #111827;
      background: @background;
      font-family: @fontFamily;
    }
    .site-hero {
      min-height: 72vh;
      display: flex;
      align-items: center;
      background:
        linear-gradient(110deg, rgba(8, 21, 48, .94), rgba(8, 21, 48, .2)),
        radial-gradient(circle at 80% 20%, rgba(255,255,255,.18), transparent 28%),
        linear-gradient(135deg, var(--site-theme-deep), var(--site-theme, #1457d9));
      color: #fff;
    }
    .site-logo {
      max-height: 72px;
      max-width: min(280px, 100%);
      object-fit: contain;
      margin-bottom: 28px;
      display: block;
      background: transparent;
      padding: 0;
      border-radius: 0;
      filter: drop-shadow(0 10px 22px rgba(0,0,0,.22));
    }
    .hero-card {
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.2);
      border-radius: 8px;
      padding: 28px;
    }
    .section-band {
      background: #fff;
      border-top: 1px solid #dbe4f0;
    }
    .brand-eyebrow {
      color: #e5edff;
    }
    .btn-theme {
      background: var(--site-theme, #1457d9);
      border-color: var(--site-theme, #1457d9);
      color: #fff;
      box-shadow: 0 12px 26px rgba(0,0,0,.2);
    }
    .btn-theme:hover {
      background: var(--site-theme-deep);
      border-color: var(--site-theme-deep);
      color: #fff;
    }
    .btn-theme-outline {
      border-color: rgba(255,255,255,.8);
      color: #fff;
    }
    .btn-theme-outline:hover {
      background: #fff;
      color: var(--site-theme-deep);
    }
    .feature-check {
      color: #e5edff;
    }
    .section-band a {
      color: var(--site-theme, #1457d9);
    }
    .contact-link {
      color: #fff;
      text-decoration: none;
    }
    .contact-link:hover { color: #dbeafe; }
  </style>
  @await Html.PartialAsync("_ManagedPageStyles")
</head>
<body class="header-@design.HeaderStyle hero-@design.HeroLayout hero-style-@design.HeroStyle buttons-@design.ButtonStyle">
  @if (ViewBag.IsTemplatePreview == true)
  {
    <div class="template-preview-banner"><i class="fas fa-eye me-2"></i>Template preview using your current pages and content. Nothing has been changed.</div>
  }
  @if (Model.Pages.Any())
  {
    @await Html.PartialAsync("_PublicNavigation", Model)
  }
  @if (Model.CurrentPage != null)
  {
    @await Html.PartialAsync("_ModernManagedPage", Model)
  }
  else
  {
  <main class="site-hero">
    <div class="container py-5">
      <div class="row align-items-center g-5">
        <div class="col-lg-7">
          @if (!string.IsNullOrWhiteSpace(website.LogoUrl))
          {
            <img src="@website.LogoUrl" class="site-logo" alt="@title logo" />
          }
          <div class="text-uppercase fw-bold mb-3 brand-eyebrow" style="letter-spacing:.08em;">@agent.CompanyName</div>
          <h1 class="display-4 fw-bold mb-3">@title</h1>
          <p class="lead mb-4">@tagline</p>
          <div class="d-flex flex-wrap gap-3">
            @if (!string.IsNullOrWhiteSpace(agent.Phone))
            {
              <a class="btn btn-theme btn-lg fw-bold" href="tel:@agent.Phone"><i class="fas fa-phone me-2"></i>Call @agent.Phone</a>
            }
            @if (!string.IsNullOrWhiteSpace(agent.Email))
            {
              <a class="btn btn-theme-outline btn-lg fw-bold" href="mailto:@agent.Email"><i class="fas fa-envelope me-2"></i>Email</a>
            }
          </div>
        </div>
        <div class="col-lg-5">
          <div class="hero-card">
            <h2 class="h4 fw-bold mb-3">How we can help</h2>
            <p class="mb-4">Use this website to learn more, request information, and stay connected with your adviser.</p>
            <div class="d-grid gap-3">
              <div><i class="fas fa-circle-check me-2 feature-check"></i>Personalized service</div>
              <div><i class="fas fa-circle-check me-2 feature-check"></i>Helpful updates and reminders</div>
              <div><i class="fas fa-circle-check me-2 feature-check"></i>Secure client relationship management</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <section class="section-band py-5">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-4">
          <h2 class="h5 fw-bold">About</h2>
          <p class="text-muted mb-0">@agent.CompanyName helps clients stay organized, informed, and connected.</p>
        </div>
        <div class="col-md-4">
          <h2 class="h5 fw-bold">Contact</h2>
          <div class="text-muted">
            <div>@($"{agent.FirstName} {agent.LastName}".Trim())</div>
            @if (!string.IsNullOrWhiteSpace(agent.Designation))
            {
              <div>@agent.Designation</div>
            }
            @if (!string.IsNullOrWhiteSpace(agent.Email))
            {
              <div><a href="mailto:@agent.Email">@agent.Email</a></div>
            }
          </div>
        </div>
        <div class="col-md-4">
          <h2 class="h5 fw-bold">Location</h2>
          <p class="text-muted mb-0">@agent.City, @agent.Province @agent.Country</p>
        </div>
      </div>
    </div>
  </section>
  }
  @await Html.PartialAsync("_ModernFooter", Model)
</body>
</html>
