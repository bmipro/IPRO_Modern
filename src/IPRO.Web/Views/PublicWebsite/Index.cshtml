@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    Layout = null;
    var design = IPRO.Entities.WebsiteTemplateDesign.FromTemplate(Model.Website.Template);
}
@if (design.Renderer == "classic-sidebar")
{
    @await Html.PartialAsync("_ClassicSidebar", Model)
}
else if (design.Renderer == "editorial-visual")
{
    @await Html.PartialAsync("_EditorialVisual", Model)
}
else
{
    @await Html.PartialAsync("_ModernProfessional", Model)
}
