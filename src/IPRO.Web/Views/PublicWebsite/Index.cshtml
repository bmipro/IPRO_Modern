@model IPRO.Entities.AgentWebsite
@{
    Layout = null;
    var agent = Model.AgentUser;
    var title = string.IsNullOrWhiteSpace(Model.SiteTitle)
        ? $"{agent.FirstName} {agent.LastName}".Trim()
        : Model.SiteTitle;
    var tagline = string.IsNullOrWhiteSpace(Model.TagLine)
        ? "Professional advice, practical service, and a better way to stay connected."
        : Model.TagLine;
    var theme = string.IsNullOrWhiteSpace(Model.ThemeColor) ? "#1457d9" : Model.ThemeColor;
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@title</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <style>
    :root { --site-theme: @theme; }
    body {
      margin: 0;
      color: #111827;
      background: #f4f7fb;
      font-family: Arial, Helvetica, sans-serif;
    }
    .site-hero {
      min-height: 72vh;
      display: flex;
      align-items: center;
      background:
        linear-gradient(110deg, rgba(8, 21, 48, .92), rgba(20, 87, 217, .84)),
        radial-gradient(circle at 80% 20%, rgba(255,255,255,.18), transparent 28%),
        var(--site-theme);
      color: #fff;
    }
    .site-logo {
      max-height: 72px;
      max-width: 280px;
      object-fit: contain;
      margin-bottom: 28px;
      background: rgba(255,255,255,.92);
      padding: 12px 16px;
      border-radius: 8px;
    }
    .hero-card {
      background: rgba(255,255,255,.1);
      border: 1px solid rgba(255,255,255,.2);
      border-radius: 8px;
      padding: 28px;
    }
    .section-band {
      background: #fff;
      border-top: 1px solid #dbe4f0;
    }
    .contact-link {
      color: #fff;
      text-decoration: none;
    }
    .contact-link:hover { color: #dbeafe; }
  </style>
</head>
<body>
  <main class="site-hero">
    <div class="container py-5">
      <div class="row align-items-center g-5">
        <div class="col-lg-7">
          @if (!string.IsNullOrWhiteSpace(Model.LogoUrl))
          {
            <img src="@Model.LogoUrl" class="site-logo" alt="@title logo" />
          }
          <div class="text-uppercase fw-bold mb-3" style="letter-spacing:.08em;color:#bfdbfe;">@agent.CompanyName</div>
          <h1 class="display-4 fw-bold mb-3">@title</h1>
          <p class="lead mb-4">@tagline</p>
          <div class="d-flex flex-wrap gap-3">
            @if (!string.IsNullOrWhiteSpace(agent.Phone))
            {
              <a class="btn btn-light btn-lg fw-bold" href="tel:@agent.Phone"><i class="fas fa-phone me-2"></i>Call @agent.Phone</a>
            }
            @if (!string.IsNullOrWhiteSpace(agent.Email))
            {
              <a class="btn btn-outline-light btn-lg fw-bold" href="mailto:@agent.Email"><i class="fas fa-envelope me-2"></i>Email</a>
            }
          </div>
        </div>
        <div class="col-lg-5">
          <div class="hero-card">
            <h2 class="h4 fw-bold mb-3">How we can help</h2>
            <p class="mb-4">Use this website to learn more, request information, and stay connected with your adviser.</p>
            <div class="d-grid gap-3">
              <div><i class="fas fa-circle-check me-2 text-info"></i>Personalized service</div>
              <div><i class="fas fa-circle-check me-2 text-info"></i>Helpful updates and reminders</div>
              <div><i class="fas fa-circle-check me-2 text-info"></i>Secure client relationship management</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <section class="section-band py-5">
    <div class="container">
      <div class="row g-4">
        <div class="col-md-4">
          <h2 class="h5 fw-bold">About</h2>
          <p class="text-muted mb-0">@agent.CompanyName helps clients stay organized, informed, and connected.</p>
        </div>
        <div class="col-md-4">
          <h2 class="h5 fw-bold">Contact</h2>
          <div class="text-muted">
            <div>@($"{agent.FirstName} {agent.LastName}".Trim())</div>
            @if (!string.IsNullOrWhiteSpace(agent.Designation))
            {
              <div>@agent.Designation</div>
            }
            @if (!string.IsNullOrWhiteSpace(agent.Email))
            {
              <div><a href="mailto:@agent.Email">@agent.Email</a></div>
            }
          </div>
        </div>
        <div class="col-md-4">
          <h2 class="h5 fw-bold">Location</h2>
          <p class="text-muted mb-0">@agent.City, @agent.Province @agent.Country</p>
        </div>
      </div>
    </div>
  </section>
</body>
</html>
