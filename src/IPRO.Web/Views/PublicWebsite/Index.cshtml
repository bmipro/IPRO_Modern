@model IPRO.Web.Models.PublicWebsiteViewModel
@{
    Layout = null;
    var design = IPRO.Entities.WebsiteTemplateDesign.FromTemplate(Model.Website.Template, Model.Website.ThemeColor);
}
@if (design.Renderer == "classic-sidebar")
{
    @await Html.PartialAsync("_ClassicSidebar", Model)
}
else
{
    @await Html.PartialAsync("_ModernProfessional", Model)
}
