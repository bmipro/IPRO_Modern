@model IPRO.Entities.AgentWebsite
@{
    Layout = null;
    var templateKey = Model.Template?.TemplateKey?.Trim().ToLowerInvariant() ?? "modern-professional";
}
@if (templateKey == "classic-sidebar")
{
    @await Html.PartialAsync("_ClassicSidebar", Model)
}
else
{
    @await Html.PartialAsync("_ModernProfessional", Model)
}
