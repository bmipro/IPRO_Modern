@model IPRO.Entities.AgentWebsite
@{
    Layout = null;
    var design = IPRO.Entities.WebsiteTemplateDesign.FromTemplate(Model.Template, Model.ThemeColor);
}
@if (design.Renderer == "classic-sidebar")
{
    @await Html.PartialAsync("_ClassicSidebar", Model)
}
else
{
    @await Html.PartialAsync("_ModernProfessional", Model)
}
