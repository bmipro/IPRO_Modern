@model IReadOnlyCollection<IPRO.Entities.RecurringInvoiceSchedule>
@{
    ViewData["Title"] = "Recurring Invoices";
}

<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
  <div>
    <h2 class="fw-bold mb-1"><i class="fas fa-rotate me-2 text-primary"></i>Recurring Invoices</h2>
    <div class="text-muted">Automatically draft an invoice on a schedule for retainer or subscription clients. Generated invoices are saved as Draft for you to review before sending.</div>
  </div>
  <div class="d-flex gap-2">
    <a class="btn btn-outline-secondary" href="/ClientInvoices"><i class="fas fa-arrow-left me-1"></i>Back to Invoices</a>
    <a class="btn btn-primary" href="/RecurringInvoices/Create"><i class="fas fa-plus me-1"></i>New Schedule</a>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Client</th>
          <th>Frequency</th>
          <th>Next Run</th>
          <th>Status</th>
          <th class="text-end"></th>
        </tr>
      </thead>
      <tbody>
        @if (!Model.Any())
        {
          <tr><td colspan="5" class="text-center text-muted py-4">No recurring schedules yet.</td></tr>
        }
        @foreach (var schedule in Model)
        {
          <tr>
            <td>@schedule.Client?.FirstName @schedule.Client?.LastName</td>
            <td>@schedule.Frequency</td>
            <td>@schedule.NextRunDate.ToString("MMM d, yyyy")</td>
            <td>
              @if (schedule.IsActive)
              {
                <span class="badge bg-success-subtle text-success">Active</span>
              }
              else
              {
                <span class="badge bg-light text-muted">Paused</span>
              }
            </td>
            <td class="text-end">
              <a class="btn btn-sm btn-outline-primary" href="/RecurringInvoices/Edit/@schedule.Id">Edit</a>
              @if (schedule.IsActive)
              {
                <form method="post" action="/RecurringInvoices/Pause/@schedule.Id" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button class="btn btn-sm btn-outline-secondary">Pause</button>
                </form>
              }
              else
              {
                <form method="post" action="/RecurringInvoices/Resume/@schedule.Id" class="d-inline">
                  @Html.AntiForgeryToken()
                  <button class="btn btn-sm btn-outline-success">Resume</button>
                </form>
              }
              <form method="post" action="/RecurringInvoices/Delete/@schedule.Id" class="d-inline" onsubmit="return confirm('Delete this recurring schedule?');">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
</div>
