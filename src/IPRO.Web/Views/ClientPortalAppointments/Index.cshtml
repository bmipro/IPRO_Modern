@model List<IPRO.Entities.PortalAppointmentRequest>
@{
    Layout = "_ClientPortalLayout";
    ViewData["Title"] = "Appointments";
    var followUps = (ViewBag.UpcomingFollowUps as List<IPRO.Entities.ClientFollowUp>) ?? new List<IPRO.Entities.ClientFollowUp>();
    string StatusBadge(IPRO.Entities.PortalAppointmentRequestStatus s) => s switch
    {
        IPRO.Entities.PortalAppointmentRequestStatus.Scheduled => "bg-success-subtle text-success",
        IPRO.Entities.PortalAppointmentRequestStatus.Declined => "bg-danger-subtle text-danger",
        _ => "bg-warning-subtle text-warning-emphasis"
    };
}

<div class="mb-4">
  <h2 class="fw-bold mb-1"><i class="fas fa-calendar-alt me-2 text-success"></i>Appointments</h2>
  <div class="text-muted">See what's scheduled and request a new appointment.</div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <h5 class="fw-bold mb-3">Upcoming</h5>
    @if (!followUps.Any())
    {
      <div class="text-muted">Nothing scheduled yet.</div>
    }
    else
    {
      <ul class="list-group list-group-flush">
        @foreach (var f in followUps)
        {
          <li class="list-group-item d-flex justify-content-between">
            <span>@f.Title</span>
            <span class="text-muted">@f.DueAt.ToString("MMM d, yyyy h:mm tt")</span>
          </li>
        }
      </ul>
    }
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body">
    <h5 class="fw-bold mb-3">Request an Appointment</h5>
    <form asp-action="RequestAppointment" method="post">
      @Html.AntiForgeryToken()
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">Preferred Date (optional)</label>
          <input type="date" name="preferredDate" class="form-control" />
        </div>
        <div class="col-md-8">
          <label class="form-label">Notes</label>
          <input type="text" name="notes" class="form-control" placeholder="What would you like to discuss?" />
        </div>
      </div>
      <button type="submit" class="btn btn-success mt-3"><i class="fas fa-paper-plane me-1"></i>Send Request</button>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body">
    <h5 class="fw-bold mb-3">My Requests</h5>
    @if (!Model.Any())
    {
      <div class="text-muted">No requests yet.</div>
    }
    else
    {
      <ul class="list-group list-group-flush">
        @foreach (var r in Model)
        {
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
              <div>@r.Notes</div>
              <div class="small text-muted">Requested @r.CreatedAt.ToLocalTime().ToString("MMM d, yyyy") @(r.PreferredDate.HasValue ? $"— preferred {r.PreferredDate.Value:MMM d, yyyy}" : "")</div>
            </div>
            <span class="badge @StatusBadge(r.Status)">@r.Status</span>
          </li>
        }
      </ul>
    }
  </div>
</div>
