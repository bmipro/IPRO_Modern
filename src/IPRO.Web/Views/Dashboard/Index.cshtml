@{ ViewData["Title"] = "Dashboard"; }
<div class="row mb-4">
  <div class="col"><h2 class="fw-bold"><i class="fas fa-home me-2 text-primary"></i>Welcome back, @ViewBag.AgentName!</h2></div>
</div>
<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-4 fw-bold text-primary">@ViewBag.ClientCount</div>
        <div class="text-muted mt-1"><i class="fas fa-users me-1"></i>Total Clients</div>
        <a href="/Clients" class="btn btn-outline-primary btn-sm mt-3">Manage Clients</a>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-4 fw-bold text-success">@ViewBag.NewsletterCount</div>
        <div class="text-muted mt-1"><i class="fas fa-envelope me-1"></i>Newsletters</div>
        <a href="/Newsletter" class="btn btn-outline-success btn-sm mt-3">Manage Newsletters</a>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        @if (ViewBag.Website != null && ViewBag.Website.IsPublished)
        { <div class="display-4 fw-bold text-info"><i class="fas fa-check-circle"></i></div>
          <div class="text-muted mt-1">Website Live</div> }
        else
        { <div class="display-4 fw-bold text-warning"><i class="fas fa-clock"></i></div>
          <div class="text-muted mt-1">Website Offline</div> }
        <a href="/Website" class="btn btn-outline-info btn-sm mt-3">Manage Website</a>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        @if (ViewBag.Subscription != null)
        { <div class="display-4 fw-bold text-success"><i class="fas fa-check-circle"></i></div>
          <div class="text-muted mt-1">Subscription Active</div> }
        else
        { <div class="display-4 fw-bold text-danger"><i class="fas fa-times-circle"></i></div>
          <div class="text-muted mt-1">No Subscription</div> }
        <a href="/Billing" class="btn btn-outline-secondary btn-sm mt-3">Billing</a>
      </div>
    </div>
  </div>
</div>
<div class="row g-4">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4"><h5 class="fw-bold mb-0"><i class="fas fa-bolt me-2 text-warning"></i>Quick Actions</h5></div>
      <div class="card-body px-4 pb-4">
        <div class="d-grid gap-2">
          <a href="/Clients/Create" class="btn btn-light text-start"><i class="fas fa-user-plus me-2 text-primary"></i>Add New Client</a>
          <a href="/Newsletter/Create" class="btn btn-light text-start"><i class="fas fa-paper-plane me-2 text-success"></i>Create Newsletter</a>
          <a href="/Website" class="btn btn-light text-start"><i class="fas fa-paint-brush me-2 text-info"></i>Edit My Website</a>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4"><h5 class="fw-bold mb-0"><i class="fas fa-info-circle me-2 text-info"></i>Getting Started</h5></div>
      <div class="card-body px-4 pb-4">
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Add your first client</li>
          <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Customise your website</li>
          <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Set up your domain</li>
          <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Send your first newsletter</li>
        </ul>
      </div>
    </div>
  </div>
</div>
