@{
    ViewData["Title"] = "Dashboard";
    var followUps = (ViewBag.FollowUps as IEnumerable<IPRO.Entities.ClientFollowUp>) ?? Enumerable.Empty<IPRO.Entities.ClientFollowUp>();
    var overdueCount = (int)(ViewBag.OverdueFollowUpCount ?? 0);
    var todayCount = (int)(ViewBag.TodayFollowUpCount ?? 0);
    var upcomingCount = (int)(ViewBag.UpcomingFollowUpCount ?? 0);
    var featureAccess = ViewBag.FeatureAccess as IDictionary<string, IPRO.Business.Interfaces.PackageFeatureAccess>
        ?? new Dictionary<string, IPRO.Business.Interfaces.PackageFeatureAccess>();

    string DueBadgeClass(DateTime dueAt) => dueAt.Date < DateTime.Today ? "bg-danger-subtle text-danger" : dueAt.Date == DateTime.Today ? "bg-warning-subtle text-warning" : "bg-primary-subtle text-primary";
    string DueLabel(DateTime dueAt) => dueAt.Date < DateTime.Today ? "Overdue" : dueAt.Date == DateTime.Today ? "Today" : dueAt.ToString("MMM d");
    string LockedAttributes(string featureCode)
    {
        if (!featureAccess.TryGetValue(featureCode, out var access) || access.IsIncluded)
        {
            return "";
        }

        return $"data-upgrade-lock=\"true\" data-upgrade-title=\"{access.FeatureName}\" data-upgrade-message=\"{access.UpgradeMessage}\"";
    }
}

<div class="row mb-4">
  <div class="col">
    <h2 class="fw-bold mb-1"><i class="fas fa-home me-2 text-primary"></i>Welcome back, @ViewBag.AgentName!</h2>
    <div class="text-muted">Here is what needs attention today.</div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-4 fw-bold text-primary">@ViewBag.ClientCount</div>
        <div class="text-muted mt-1"><i class="fas fa-users me-1"></i>Total Clients</div>
        <a href="/Clients" class="btn btn-outline-primary btn-sm mt-3">Manage Clients</a>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-4 fw-bold @(overdueCount > 0 ? "text-danger" : "text-success")">@overdueCount</div>
        <div class="text-muted mt-1"><i class="fas fa-exclamation-circle me-1"></i>Overdue Follow-ups</div>
        <a href="/Clients/FollowUps?status=overdue" class="btn btn-outline-danger btn-sm mt-3">Review Overdue</a>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-4 fw-bold text-warning">@todayCount</div>
        <div class="text-muted mt-1"><i class="fas fa-calendar-day me-1"></i>Due Today</div>
        <a href="/Clients/FollowUps?status=today" class="btn btn-outline-warning btn-sm mt-3">See Today</a>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body text-center p-4">
        <div class="display-4 fw-bold text-info">@upcomingCount</div>
        <div class="text-muted mt-1"><i class="fas fa-clock me-1"></i>Upcoming</div>
        <a href="/Clients/FollowUps?status=upcoming" class="btn btn-outline-info btn-sm mt-3">View Upcoming</a>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div id="followups" class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h5 class="fw-bold mb-0"><i class="fas fa-calendar-check me-2 text-primary"></i>Next Follow-ups</h5>
          <span class="badge bg-light text-muted">@followUps.Count() shown</span>
        </div>
      </div>
      <div class="card-body px-4 pb-4">
        @if (followUps.Any())
        {
          <div class="vstack gap-2">
          @foreach (var item in followUps)
          {
            <div class="dashboard-followup d-flex justify-content-between align-items-start gap-3 border rounded-3 p-3">
              <div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <strong>@item.Title</strong>
                  <span class="badge rounded-pill @DueBadgeClass(item.DueAt)">@DueLabel(item.DueAt)</span>
                </div>
                <div class="small mt-1">
                  <a href="/Clients/Details/@item.ClientId" class="text-decoration-none">@item.Client.FirstName @item.Client.LastName</a>
                  @if (!string.IsNullOrWhiteSpace(item.Client.CompanyName))
                  {
                    <span class="text-muted"> - @item.Client.CompanyName</span>
                  }
                </div>
                @if (!string.IsNullOrWhiteSpace(item.Notes))
                {
                  <div class="text-muted small mt-1">@item.Notes</div>
                }
              </div>
              <div class="d-flex gap-1">
                <a href="/Clients/FollowUps/@item.ClientId" class="btn btn-sm btn-outline-primary" title="View follow-ups"><i class="fas fa-list"></i></a>
                <form asp-controller="Clients" asp-action="CompleteFollowUp" asp-route-id="@item.Id" method="post">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString"/>
                  <button type="submit" class="btn btn-sm btn-outline-success" title="Mark complete"><i class="fas fa-check"></i></button>
                </form>
              </div>
            </div>
          }
          </div>
        }
        else
        {
          <div class="text-center py-5 text-muted">
            <i class="fas fa-calendar-check fa-3x d-block mb-3 opacity-25"></i>
            No open follow-ups. A rare and beautiful calm.
          </div>
        }
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-4 px-4"><h5 class="fw-bold mb-0"><i class="fas fa-bolt me-2 text-warning"></i>Quick Actions</h5></div>
      <div class="card-body px-4 pb-4">
        <div class="d-grid gap-2">
          <a href="/Clients/Create" class="btn btn-light text-start"><i class="fas fa-user-plus me-2 text-primary"></i>Add New Client</a>
          <a href="/Clients" class="btn btn-light text-start"><i class="fas fa-search me-2 text-primary"></i>Search Clients</a>
          <a href="/Clients/FollowUps?status=open" class="btn btn-light text-start"><i class="fas fa-list-check me-2 text-primary"></i>Follow-up Queue</a>
          <a href="/Clients/Calendar" class="btn btn-light text-start" @Html.Raw(LockedAttributes(IPRO.Entities.PackageFeatureCodes.CalendarScheduler))><i class="fas fa-calendar-alt me-2 text-primary"></i>Follow-up Calendar</a>
          <a href="/Newsletter/Create" class="btn btn-light text-start" @Html.Raw(LockedAttributes(IPRO.Entities.PackageFeatureCodes.Newsletters))><i class="fas fa-paper-plane me-2 text-success"></i>Create Newsletter</a>
          <a href="/Billing" class="btn btn-light text-start"><i class="fas fa-credit-card me-2 text-secondary"></i>Billing</a>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4"><h5 class="fw-bold mb-0"><i class="fas fa-info-circle me-2 text-info"></i>Status</h5></div>
      <div class="card-body px-4 pb-4">
        <ul class="list-unstyled mb-0">
          <li class="mb-2"><i class="fas fa-envelope text-success me-2"></i>@ViewBag.NewsletterCount newsletters created</li>
          @if (ViewBag.Website != null && ViewBag.Website.IsPublished)
          {
            <li class="mb-2"><i class="fas fa-globe text-success me-2"></i>Website is live</li>
          }
          else
          {
            <li class="mb-2"><i class="fas fa-globe text-warning me-2"></i>Website is not published</li>
          }
          @if (ViewBag.Subscription != null)
          {
            <li class="mb-2"><i class="fas fa-check-circle text-success me-2"></i>Subscription active</li>
          }
          else
          {
            <li class="mb-2"><i class="fas fa-times-circle text-danger me-2"></i>No active subscription</li>
          }
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
  .dashboard-followup{background:#f8fafc;}
</style>
