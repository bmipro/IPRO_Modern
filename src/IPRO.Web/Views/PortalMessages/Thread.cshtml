@model List<IPRO.Entities.PortalMessage>
@{
    var client = ViewBag.Client as IPRO.Entities.Client;
    ViewData["Title"] = $"{client?.FirstName} {client?.LastName}";
}

<div class="d-flex justify-content-between align-items-start mb-4">
  <div>
    <h2 class="fw-bold mb-1"><i class="fas fa-comments me-2 text-primary"></i>@client?.FirstName @client?.LastName</h2>
    <div class="text-muted">Portal conversation</div>
  </div>
  <a class="btn btn-outline-secondary" href="/PortalMessages">Back to Inbox</a>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body" style="max-height:520px;overflow-y:auto;">
    @if (!Model.Any())
    {
      <div class="text-center text-muted py-4">No messages yet.</div>
    }
    @foreach (var message in Model)
    {
      <div class="mb-3 d-flex @(message.IsFromClient ? "justify-content-start" : "justify-content-end")">
        <div class="p-3 rounded-3" style="max-width:70%;background:@(message.IsFromClient ? "#f1f3f5" : "#1457d9");color:@(message.IsFromClient ? "#212529" : "#fff");">
          <div class="small fw-bold mb-1">@message.AuthorName</div>
          <div>@message.Body</div>
          <div class="small mt-1" style="opacity:.75">@message.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</div>
        </div>
      </div>
    }
  </div>
</div>

<form asp-action="Reply" method="post" class="d-flex gap-2">
  @Html.AntiForgeryToken()
  <input type="hidden" name="clientId" value="@client?.Id" />
  <textarea name="body" class="form-control" rows="2" placeholder="Type a reply..." required></textarea>
  <button type="submit" class="btn btn-primary align-self-end"><i class="fas fa-paper-plane"></i></button>
</form>
