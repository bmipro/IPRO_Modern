@{
    ViewData["Title"] = "Portal Messages";
    var rows = (ViewBag.Rows as List<IPRO.Web.Controllers.PortalMessageInboxRow>) ?? new List<IPRO.Web.Controllers.PortalMessageInboxRow>();
}

<div class="mb-4">
  <h2 class="fw-bold mb-1"><i class="fas fa-comments me-2 text-primary"></i>Portal Messages</h2>
  <div class="text-muted">Conversations from clients using your client portal.</div>
</div>

<div class="card border-0 shadow-sm">
  <div class="list-group list-group-flush">
    @if (!rows.Any())
    {
      <div class="text-center text-muted py-4">No portal conversations yet.</div>
    }
    @foreach (var row in rows)
    {
      <a href="/PortalMessages/Thread/@row.Client.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
        <div>
          <div class="fw-bold">@row.Client.FirstName @row.Client.LastName</div>
          <div class="small text-muted">@row.LastMessage.Body</div>
        </div>
        <div class="text-end">
          @if (row.UnreadCount > 0)
          {
            <span class="badge bg-primary rounded-pill mb-1">@row.UnreadCount new</span>
          }
          <div class="small text-muted">@row.LastMessage.CreatedAt.ToLocalTime().ToString("MMM d, h:mm tt")</div>
        </div>
      </a>
    }
  </div>
</div>
