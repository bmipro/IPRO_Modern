@model IPRO.Web.Models.WebsiteNavigationViewModel
@{
  ViewData["Title"] = "Header & Navigation";
  var topPages = Model.Pages.Where(p => p.ParentPageId == null).OrderBy(p => p.SortOrder).ToList();
}
<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div><div class="small text-muted mb-1"><a href="/Website">My Website</a> / Structure</div><h2 class="fw-bold mb-1"><i class="fas fa-bars-staggered me-2 text-primary"></i>Header & Navigation</h2><div class="text-muted">Shape the first thing visitors see and keep your menu easy to understand.</div></div>
  <div class="d-flex gap-2"><a href="/WebsitePages" class="btn btn-outline-secondary"><i class="fas fa-file-lines me-1"></i>Pages</a><a href="/Website" class="btn btn-outline-primary"><i class="fas fa-arrow-left me-1"></i>Website Settings</a></div>
</div>

<form method="post" action="/WebsitePages/SaveHeader" class="card border-0 shadow-sm mb-4">
  @Html.AntiForgeryToken()
  <div class="card-body p-4">
    <div class="mb-4"><h4 class="fw-bold mb-1">Header and Logo</h4><div class="text-muted small">Logo artwork is uploaded from Website Settings. These controls determine how it appears.</div></div>
    <div class="row g-3">
      <div class="col-md-4"><label class="form-label fw-semibold">Header Style</label><select name="style" class="form-select"><option value="standard" selected="@(Model.Header.Style=="standard")">Standard</option><option value="compact" selected="@(Model.Header.Style=="compact")">Compact</option><option value="transparent" selected="@(Model.Header.Style=="transparent")">Transparent over banner</option></select></div>
      <div class="col-md-4"><label class="form-label fw-semibold">Logo Position</label><div class="btn-group w-100" role="group"><input type="radio" class="btn-check" name="logoPosition" id="logoLeft" value="left" checked="@(Model.Header.LogoPosition!="center")"><label class="btn btn-outline-secondary" for="logoLeft"><i class="fas fa-align-left me-1"></i>Left</label><input type="radio" class="btn-check" name="logoPosition" id="logoCenter" value="center" checked="@(Model.Header.LogoPosition=="center")"><label class="btn btn-outline-secondary" for="logoCenter"><i class="fas fa-align-center me-1"></i>Center</label></div></div>
      <div class="col-md-4"><label class="form-label fw-semibold">Logo Size</label><select name="logoSize" class="form-select"><option value="small" selected="@(Model.Header.LogoSize=="small")">Small</option><option value="medium" selected="@(Model.Header.LogoSize=="medium")">Medium</option><option value="large" selected="@(Model.Header.LogoSize=="large")">Large</option></select></div>
      <div class="col-md-4"><label class="form-label fw-semibold">Header Button</label><input name="buttonText" value="@Model.Header.ButtonText" class="form-control" placeholder="Book a Consultation" /></div>
      <div class="col-md-4"><label class="form-label fw-semibold">Button Link</label><input name="buttonUrl" value="@Model.Header.ButtonUrl" class="form-control" placeholder="/contact or https://..." /></div>
      <div class="col-md-4 d-flex flex-column justify-content-end gap-2 pb-1">
        <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="sticky" value="true" checked="@Model.Header.Sticky"><label class="form-check-label">Keep header visible while scrolling</label></div>
        <div class="d-flex gap-4"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="showPhone" value="true" checked="@Model.Header.ShowPhone"><label class="form-check-label">Phone</label></div><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="showEmail" value="true" checked="@Model.Header.ShowEmail"><label class="form-check-label">Email</label></div></div>
      </div>
    </div>
  </div>
  <div class="card-footer bg-white border-0 px-4 pb-4"><button class="btn btn-primary"><i class="fas fa-save me-1"></i>Save Header</button></div>
</form>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-4">
    <div class="d-flex justify-content-between gap-3 mb-3"><div><h4 class="fw-bold mb-1">Website Menu</h4><div class="text-muted small">Rename links, create one submenu level, hide items, and use the arrows to control order.</div></div><span class="badge bg-primary-subtle text-primary align-self-start">@Model.Pages.Count pages</span></div>
    <div class="navigation-list">
      @foreach (var menuPage in Model.Pages.OrderBy(p => p.ParentPageId.HasValue).ThenBy(p => p.SortOrder))
      {
        <form method="post" action="/WebsitePages/SaveNavigationItem" class="navigation-row @(menuPage.ParentPageId.HasValue ? "is-child" : "")">
          @Html.AntiForgeryToken()<input type="hidden" name="id" value="@menuPage.Id" />
          <div class="navigation-order"><button type="submit" formaction="/WebsitePages/MoveNavigationItem/@menuPage.Id" name="direction" value="up" class="btn btn-sm btn-outline-secondary" title="Move up"><i class="fas fa-arrow-up"></i></button><button type="submit" formaction="/WebsitePages/MoveNavigationItem/@menuPage.Id" name="direction" value="down" class="btn btn-sm btn-outline-secondary" title="Move down"><i class="fas fa-arrow-down"></i></button></div>
          <div><label class="form-label small text-muted mb-1">Menu label</label><input name="navigationLabel" value="@menuPage.NavigationLabel" class="form-control" /></div>
          <div><label class="form-label small text-muted mb-1">Placement</label><select name="parentPageId" class="form-select"><option value="">Top level</option>@foreach(var parent in topPages.Where(p=>p.Id!=menuPage.Id)){<option value="@parent.Id" selected="@(menuPage.ParentPageId==parent.Id)">Under @parent.NavigationLabel</option>}</select></div>
          <div class="navigation-meta"><span class="small text-muted">/@(menuPage.IsHomePage?"":menuPage.Slug)</span><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="showInNavigation" value="true" checked="@menuPage.ShowInNavigation"><label class="form-check-label small">Visible</label></div></div>
          <button class="btn btn-outline-primary"><i class="fas fa-check me-1"></i>Save</button>
        </form>
      }
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-4">
    <h4 class="fw-bold mb-1">External Links</h4><div class="text-muted small mb-3">Add a link to a booking system, partner site, or another trusted destination.</div>
    <form method="post" action="/WebsitePages/AddCustomLink" class="row g-2 align-items-end mb-3">@Html.AntiForgeryToken()<div class="col-md-4"><label class="form-label small fw-semibold">Label</label><input name="label" class="form-control" placeholder="Client Login" required /></div><div class="col-md-6"><label class="form-label small fw-semibold">Complete URL</label><input name="url" type="url" class="form-control" placeholder="https://example.com" required /></div><div class="col-md-2"><button class="btn btn-primary w-100"><i class="fas fa-plus me-1"></i>Add Link</button></div></form>
    @foreach(var link in Model.Header.CustomLinks.OrderBy(l=>l.SortOrder)){<div class="d-flex align-items-center justify-content-between gap-3 border-top py-3"><div><strong>@link.Label</strong><div class="small text-muted text-break">@link.Url</div></div><form method="post" action="/WebsitePages/DeleteCustomLink" onsubmit="return confirm('Remove this external link?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@link.Id" /><button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button></form></div>}
  </div>
</div>

<style>
.navigation-row{display:grid;grid-template-columns:auto minmax(180px,1fr) minmax(210px,.8fr) minmax(120px,.45fr) auto;gap:12px;align-items:end;padding:14px 0;border-top:1px solid #e2e8f0}.navigation-row.is-child{margin-left:40px;padding-left:16px;border-left:3px solid #d8e5fb}.navigation-order{display:flex;gap:4px;padding-bottom:1px}.navigation-meta{display:flex;flex-direction:column;gap:7px;padding-bottom:4px}@@media(max-width:900px){.navigation-row{grid-template-columns:auto 1fr}.navigation-row>*:not(.navigation-order){grid-column:2}.navigation-row.is-child{margin-left:16px}}
</style>
