@model IPRO.Web.Models.WebsitePageEditViewModel
@{
    var sitePage = Model.Page;
    var isNew = sitePage.Id == 0;
    ViewData["Title"] = isNew ? "Create Website Page" : $"Edit {sitePage.Title}";
}
@functions {
    private static string ImageKey(string? value)
    {
        var text = value?.Trim() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(text))
        {
            return string.Empty;
        }

        if (System.Uri.TryCreate(text, System.UriKind.Absolute, out var uri) &&
            (uri.Scheme == System.Uri.UriSchemeHttp || uri.Scheme == System.Uri.UriSchemeHttps))
        {
            return uri.GetLeftPart(System.UriPartial.Path).TrimEnd('/').ToLowerInvariant();
        }

        return text.TrimEnd('/').ToLowerInvariant();
    }

    private static bool SameImageUrl(string? left, string? right) =>
        !string.IsNullOrWhiteSpace(left) &&
        !string.IsNullOrWhiteSpace(right) &&
        ImageKey(left) == ImageKey(right);
}

<div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
  <div>
    <div class="small text-muted mb-1"><a href="/Website">My Website</a> / <a href="/WebsitePages">Pages</a> / @(isNew ? "Create" : "Edit")</div>
    <h2 class="fw-bold mb-1"><i class="fas fa-file-pen me-2 text-primary"></i>@ViewData["Title"]</h2>
    <div class="text-muted">Page settings control navigation and search details. Content blocks build the page itself.</div>
  </div>
  <a href="/WebsitePages" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>All Pages</a>
</div>

<form method="post" action="/WebsitePages/SavePage" class="card border-0 shadow-sm mb-4">
  @Html.AntiForgeryToken()
  <input type="hidden" name="id" value="@sitePage.Id" />
  <div class="card-body p-4">
    <h5 class="fw-bold mb-3">Page Settings</h5>
    <div class="row g-3">
      <div class="col-md-6"><label class="form-label fw-semibold">Page Title</label><input name="title" value="@sitePage.Title" class="form-control" required /></div>
      <div class="col-md-6"><label class="form-label fw-semibold">Page Address</label><div class="input-group"><span class="input-group-text">/</span><input name="slug" value="@sitePage.Slug" class="form-control" placeholder="services" /></div></div>
                <div class="col-md-6"><label class="form-label fw-semibold">Navigation Label</label><input name="navigationLabel" value="@sitePage.NavigationLabel" class="form-control" placeholder="Defaults to page title" /></div>
                <div class="col-md-6"><label class="form-label fw-semibold">Parent Menu</label><select name="parentPageId" class="form-select"><option value="">Top level</option>@foreach (var parent in Model.AvailableParents){<option value="@parent.Id" selected="@(sitePage.ParentPageId == parent.Id)">@parent.NavigationLabel</option>}</select></div>
                @if (isNew)
                {
                    <div class="col-12">
                        <label class="form-label fw-semibold" for="starterPreset">Start page with</label>
                        <select class="form-select" id="starterPreset" name="starterPreset">
                            @foreach (var preset in Model.StarterPresets)
                            {
                                <option value="@preset.Key">@preset.Name - @preset.Description</option>
                            }
                        </select>
                        <div class="form-text">This adds editable starter sections. You can change, reorder, or delete them afterwards.</div>
                    </div>
                }
      <div class="col-md-6"><label class="form-label fw-semibold">Browser/SEO Title</label><input name="metaTitle" value="@sitePage.MetaTitle" class="form-control" /></div>
      <div class="col-md-6"><label class="form-label fw-semibold">Search Description</label><input name="metaDescription" value="@sitePage.MetaDescription" maxlength="320" class="form-control" /></div>
      <div class="col-12 d-flex flex-wrap gap-4">
        <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="showInNavigation" value="true" checked="@sitePage.ShowInNavigation" /><label class="form-check-label fw-semibold">Show in navigation</label></div>
        <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="isPublished" value="true" checked="@sitePage.IsPublished" /><label class="form-check-label fw-semibold">Published</label></div>
        <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="isHomePage" value="true" checked="@sitePage.IsHomePage" /><label class="form-check-label fw-semibold">Use as home page</label></div>
      </div>
    </div>
  </div>
  <div class="card-footer bg-white border-0 px-4 pb-4"><button class="btn btn-primary"><i class="fas fa-save me-1"></i>Save Page Settings</button></div>
</form>

@if (!isNew)
{
  <form id="applyImageToBlockForm" method="post" action='@Url.Action("ApplyImageToBlock", "WebsitePages")' class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="pageId" value="@sitePage.Id" />
    <input type="hidden" name="blockId" value="" />
    <input type="hidden" name="imageUrl" value="" />
  </form>
  <section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div><h4 class="fw-bold mb-1"><i class="fas fa-images me-2 text-primary"></i>Image Library</h4><div class="text-muted small">Upload an image once, then select it in any content block.</div></div>
        <form method="post" action="/WebsitePages/UploadImage" enctype="multipart/form-data" class="d-flex flex-wrap align-items-end gap-2">
          @Html.AntiForgeryToken()
          <input type="hidden" name="pageId" value="@sitePage.Id" />
          <div><label class="form-label small fw-semibold mb-1">JPG, PNG, GIF, or WebP (maximum 8 MB)</label><input type="file" name="image" class="form-control" accept=".jpg,.jpeg,.png,.gif,.webp,image/jpeg,image/png,image/gif,image/webp" required /></div>
          <button class="btn btn-primary"><i class="fas fa-upload me-1"></i>Upload Image</button>
        </form>
      </div>
      @if (sitePage.Blocks.Any())
      {
        <div class="image-library-toolbar mb-3">
          <div>
            <label for="uploadedImageTarget" class="form-label small fw-semibold mb-1">Apply uploaded image to</label>
            <select id="uploadedImageTarget" class="form-select form-select-sm">
              @foreach (var targetBlock in sitePage.Blocks.OrderByDescending(b => b.BlockType == IPRO.Entities.WebsiteBlockTypes.Hero).ThenBy(b => b.SortOrder))
              {
                <option value="@targetBlock.Id">@IPRO.Entities.WebsiteBlockTypes.DisplayName(targetBlock.BlockType) - @(string.IsNullOrWhiteSpace(targetBlock.Heading) ? "Untitled block" : targetBlock.Heading)</option>
              }
            </select>
          </div>
          <div id="uploadedImageStatus" class="small text-muted" role="status">Choose a destination, then click <strong>Use this image</strong>. It saves to that block immediately.</div>
        </div>
      }
      @if (Model.MediaAssets.Any())
      {
        <div class="row g-3">
          @foreach (var asset in Model.MediaAssets)
          {
            <div class="col-6 col-md-4 col-xl-3">
              <div class="border rounded p-2 h-100">
                <img src="@asset.BlobUrl" alt="" class="w-100 rounded mb-2" style="aspect-ratio:16/10;object-fit:cover" />
              <div class="small text-truncate mb-2" title="@asset.OriginalFileName">@asset.OriginalFileName</div>
                @if (sitePage.Blocks.Any())
                {
                  <button type="button" class="btn btn-sm btn-outline-primary w-100 mb-2 uploaded-image-choice" data-image-url="@asset.BlobUrl" data-image-name="@asset.OriginalFileName"><i class="fas fa-check me-1"></i>Use this image</button>
                }
                <form method="post" action="/WebsitePages/DeleteImage/@asset.Id" onsubmit="return confirm('Remove this image from the library and any content blocks using it?');">
                  @Html.AntiForgeryToken()<input type="hidden" name="pageId" value="@sitePage.Id" /><button class="btn btn-sm btn-outline-danger w-100"><i class="fas fa-trash me-1"></i>Remove</button>
                </form>
              </div>
            </div>
          }
        </div>
      }
      else
      {
        <div class="border rounded p-4 text-center text-muted"><i class="fas fa-image me-2"></i>No website images uploaded yet.</div>
      }
      <details class="starter-banner-library mt-4">
        <summary><i class="fas fa-wand-magic-sparkles me-2 text-primary"></i><strong>Browse shared starter banners</strong><span class="text-muted ms-2">@Model.StarterBanners.Count reusable images</span></summary>
        @if (sitePage.Blocks.Any())
        {
          <div class="starter-banner-toolbar mt-3">
            <div>
              <label for="starterBannerTarget" class="form-label small fw-semibold mb-1">Apply selected banner to</label>
              <select id="starterBannerTarget" class="form-select form-select-sm">
                @foreach (var targetBlock in sitePage.Blocks.OrderByDescending(b => b.BlockType == IPRO.Entities.WebsiteBlockTypes.Hero).ThenBy(b => b.SortOrder))
                {
                  <option value="@targetBlock.Id">@IPRO.Entities.WebsiteBlockTypes.DisplayName(targetBlock.BlockType) - @(string.IsNullOrWhiteSpace(targetBlock.Heading) ? "Untitled block" : targetBlock.Heading)</option>
                }
              </select>
            </div>
            <div id="starterBannerStatus" class="small text-muted" role="status">Choose a destination, then click a banner below. It saves to that block immediately.</div>
          </div>
        }
        else
        {
          <div class="alert alert-info mt-3 mb-0">Add a content block first, then you can apply a starter banner to it.</div>
        }
        <div class="starter-banner-grid mt-3">
          @foreach (var banner in Model.StarterBanners)
          {
            <button type="button" class="starter-banner-choice" data-banner-url="@banner.Url" data-banner-name="@banner.Name" disabled="@(!sitePage.Blocks.Any())">
              <img src="@banner.Url" alt="@banner.Name" loading="lazy" />
              <span class="starter-banner-caption"><strong>@banner.Name</strong><span>@banner.Category</span></span>
              <span class="starter-banner-use"><i class="fas fa-check me-1"></i>Use this banner</span>
            </button>
          }
        </div>
      </details>
    </div>
  </section>

  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
    <div><h4 class="fw-bold mb-1">Content Blocks</h4><div class="text-muted small">Blocks appear from top to bottom in this order.</div></div>
    <form method="post" action="/WebsitePages/AddBlock" class="d-flex gap-2">
      @Html.AntiForgeryToken()<input type="hidden" name="pageId" value="@sitePage.Id" />
      <select name="blockType" class="form-select">
        @foreach (var type in Model.BlockTypes){<option value="@type">@IPRO.Entities.WebsiteBlockTypes.DisplayName(type)</option>}
      </select>
      <button class="btn btn-primary text-nowrap"><i class="fas fa-plus me-1"></i>Add Block</button>
    </form>
  </div>

  @foreach (var block in sitePage.Blocks.OrderBy(b => b.SortOrder))
  {
    var heroSettings = IPRO.Entities.WebsiteHeroSettings.FromJson(block.SettingsJson);
    <section class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white d-flex justify-content-between align-items-center gap-3 py-3">
        <div><span class="badge bg-primary-subtle text-primary me-2">@IPRO.Entities.WebsiteBlockTypes.DisplayName(block.BlockType)</span><span class="fw-bold">@(string.IsNullOrWhiteSpace(block.Heading) ? "Untitled block" : block.Heading)</span></div>
        <div class="d-flex gap-1">
          <form method="post" action="/WebsitePages/MoveBlock/@block.Id"><input type="hidden" name="direction" value="up" />@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-secondary" title="Move up"><i class="fas fa-arrow-up"></i></button></form>
          <form method="post" action="/WebsitePages/MoveBlock/@block.Id"><input type="hidden" name="direction" value="down" />@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-secondary" title="Move down"><i class="fas fa-arrow-down"></i></button></form>
          <form method="post" action="/WebsitePages/DeleteBlock/@block.Id" onsubmit="return confirm('Remove this content block?');">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger" title="Remove"><i class="fas fa-trash"></i></button></form>
        </div>
      </div>
      <form method="post" action="/WebsitePages/UpdateBlock" class="card-body p-4">
        @Html.AntiForgeryToken()<input type="hidden" name="id" value="@block.Id" />
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label fw-semibold">Heading</label><input name="heading" value="@block.Heading" class="form-control" /></div>
          <div class="col-md-6"><label class="form-label fw-semibold">Supporting Line</label><input name="subheading" value="@block.Subheading" class="form-control" /></div>
          <div class="col-12"><label class="form-label fw-semibold">@(block.BlockType is IPRO.Entities.WebsiteBlockTypes.Services ? "Items (one per line)" : "Body")</label><textarea name="body" class="form-control" rows="4">@block.Body</textarea></div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Image <span class="text-muted fw-normal">(optional)</span></label>
            <select name="imageUrl" class="form-select" data-block-id="@block.Id">
              <option value="" selected="@(string.IsNullOrWhiteSpace(block.ImageUrl) ? "selected" : null)">No image</option>
              @if (!string.IsNullOrWhiteSpace(block.ImageUrl) && !Model.MediaAssets.Any(a => SameImageUrl(a.BlobUrl, block.ImageUrl)) && !Model.StarterBanners.Any(a => SameImageUrl(a.Url, block.ImageUrl)))
              {
                <option value="@block.ImageUrl" selected>Current external image</option>
              }
              @foreach (var category in Model.StarterBanners.GroupBy(b => b.Category))
              {
                <optgroup label="Starter: @category.Key">
                  @foreach (var banner in category)
                  {
                    <option value="@banner.Url" selected="@(SameImageUrl(banner.Url, block.ImageUrl) ? "selected" : null)">@banner.Name</option>
                  }
                </optgroup>
              }
              @if (Model.MediaAssets.Any())
              {
                <optgroup label="My uploaded images">
                  @foreach (var asset in Model.MediaAssets)
                  {
                    <option value="@asset.BlobUrl" selected="@(SameImageUrl(asset.BlobUrl, block.ImageUrl) ? "selected" : null)">@asset.OriginalFileName</option>
                  }
                </optgroup>
              }
            </select>
            <img src="@block.ImageUrl" alt="" class="rounded mt-2 block-image-preview @(string.IsNullOrWhiteSpace(block.ImageUrl) ? "d-none" : "")" style="width:180px;height:74px;object-fit:cover" />
          </div>
          <div class="col-md-3"><label class="form-label fw-semibold">Button Text</label><input name="buttonText" value="@block.ButtonText" class="form-control" /></div>
          <div class="col-md-3"><label class="form-label fw-semibold">Button Link</label><input name="buttonUrl" value="@block.ButtonUrl" class="form-control" placeholder="/contact" /></div>
          @if (block.BlockType is IPRO.Entities.WebsiteBlockTypes.Services or IPRO.Entities.WebsiteBlockTypes.CallToAction or IPRO.Entities.WebsiteBlockTypes.Text or IPRO.Entities.WebsiteBlockTypes.Reviews or IPRO.Entities.WebsiteBlockTypes.TestimonialForm)
          {
            <div class="col-md-4">
              <label class="form-label fw-semibold">Layout</label>
              <select name="layoutVariant" class="form-select">
                <option value="" selected="@(string.IsNullOrEmpty(block.LayoutVariant) ? "selected" : null)">Match template default</option>
                @if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.Services)
                {
                  <option value="cards" selected="@(block.LayoutVariant == "cards" ? "selected" : null)">Cards</option>
                  <option value="list" selected="@(block.LayoutVariant == "list" ? "selected" : null)">List</option>
                  <option value="icons" selected="@(block.LayoutVariant == "icons" ? "selected" : null)">Icons</option>
                }
                else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.CallToAction)
                {
                  <option value="banner" selected="@(block.LayoutVariant == "banner" ? "selected" : null)">Banner</option>
                  <option value="card" selected="@(block.LayoutVariant == "card" ? "selected" : null)">Card</option>
                  <option value="split" selected="@(block.LayoutVariant == "split" ? "selected" : null)">Split</option>
                }
                else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.Text)
                {
                  <option value="image-left" selected="@(block.LayoutVariant == "image-left" ? "selected" : null)">Image on the left</option>
                  <option value="image-right" selected="@(block.LayoutVariant == "image-right" ? "selected" : null)">Image on the right</option>
                }
                else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.Reviews)
                {
                  <option value="badge" selected="@(block.LayoutVariant == "badge" ? "selected" : null)">Badge (centered card)</option>
                  <option value="banner" selected="@(block.LayoutVariant == "banner" ? "selected" : null)">Banner (full-width, colored)</option>
                }
                else if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.TestimonialForm)
                {
                  <option value="list" selected="@(block.LayoutVariant == "list" ? "selected" : null)">List</option>
                  <option value="grid" selected="@(block.LayoutVariant == "grid" ? "selected" : null)">Grid</option>
                }
              </select>
              <div class="form-text">Changes how this block's items are arranged. Leave as default to match your template's usual style.@(block.BlockType == IPRO.Entities.WebsiteBlockTypes.Text ? " Only affects blocks with an image selected." : "")@(block.BlockType == IPRO.Entities.WebsiteBlockTypes.TestimonialForm ? " Only affects approved testimonials shown below the form." : "")</div>
            </div>
          }
          @if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.Hero)
          {
            <div class="col-12"><div class="banner-controls"><div class="d-flex align-items-center gap-2 mb-3"><i class="fas fa-panorama text-primary"></i><strong>Banner Presentation</strong><span class="small text-muted">Changes layout only; your content stays intact.</span></div><div class="row g-3">
              <div class="col-md-3"><label class="form-label fw-semibold">Layout</label><select name="heroLayout" class="form-select"><option value="split" selected="@(heroSettings.Layout=="split")">Text left, image right</option><option value="image-left" selected="@(heroSettings.Layout=="image-left")">Image left, text right</option><option value="centered" selected="@(heroSettings.Layout=="centered")">Centered</option><option value="full-image" selected="@(heroSettings.Layout=="full-image")">Full background image</option><option value="compact" selected="@(heroSettings.Layout=="compact")">No Banner</option></select></div>
              <div class="col-md-3"><label class="form-label fw-semibold">Banner Height</label><select name="bannerHeight" class="form-select"><option value="compact" selected="@(heroSettings.Height=="compact")">Compact</option><option value="standard" selected="@(heroSettings.Height=="standard")">Standard</option><option value="tall" selected="@(heroSettings.Height=="tall")">Tall</option></select></div>
              <div class="col-md-3"><label class="form-label fw-semibold">Text Alignment</label><select name="textAlignment" class="form-select"><option value="left" selected="@(heroSettings.TextAlignment=="left")">Left</option><option value="center" selected="@(heroSettings.TextAlignment=="center")">Center</option></select></div>
              <div class="col-md-3"><label class="form-label fw-semibold">Image Focus</label><select name="imagePosition" class="form-select"><option value="center" selected="@(heroSettings.ImagePosition=="center")">Center</option><option value="left" selected="@(heroSettings.ImagePosition=="left")">Left</option><option value="right" selected="@(heroSettings.ImagePosition=="right")">Right</option><option value="top" selected="@(heroSettings.ImagePosition=="top")">Top</option><option value="bottom" selected="@(heroSettings.ImagePosition=="bottom")">Bottom</option></select></div>
              <div class="col-md-6"><label class="form-label fw-semibold">Text readability over image</label><select name="overlayStrength" class="form-select"><option value="0" selected="@(heroSettings.OverlayStrength <= 0)">None</option><option value="25" selected="@(heroSettings.OverlayStrength > 0 && heroSettings.OverlayStrength <= 35)">Light</option><option value="50" selected="@(heroSettings.OverlayStrength > 35 && heroSettings.OverlayStrength < 70)">Medium</option><option value="80" selected="@(heroSettings.OverlayStrength >= 70)">Strong</option></select><div class="form-text">Adds shading behind banner text so it stays readable on photos.</div></div>
            </div></div></div>
          }
          @if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.PollResults)
          {
            var pollSettings = IPRO.Entities.WebsitePollResultsSettings.FromJson(block.SettingsJson);
            <div class="col-12">
              <label class="form-label fw-semibold">Which poll?</label>
              @if (Model.AvailableSentPolls.Any())
              {
                <select name="pollSurveyId" class="form-select">
                  <option value="0">Choose a poll...</option>
                  @foreach (var poll in Model.AvailableSentPolls)
                  {
                    <option value="@poll.Id" selected="@(pollSettings.PollSurveyId == poll.Id ? "selected" : null)">@poll.Title (@poll.TotalResponded response@(poll.TotalResponded == 1 ? "" : "s"))</option>
                  }
                </select>
                <div class="form-text">Hidden on your live site until the chosen poll has at least 10 responses, to keep answers anonymous.</div>
              }
              else
              {
                <div class="alert alert-info mb-0">Send a poll first, then come back here to display its results.</div>
              }
            </div>
          }
          @if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.LeadMagnet)
          {
            var leadMagnetSettings = IPRO.Entities.WebsiteLeadMagnetSettings.FromJson(block.SettingsJson);
            <div class="col-12">
              <label class="form-label fw-semibold">Which file?</label>
              @if (Model.AvailableAgentDocuments.Any())
              {
                <select name="agentDocumentId" class="form-select">
                  <option value="0">Choose a file...</option>
                  @foreach (var doc in Model.AvailableAgentDocuments)
                  {
                    <option value="@doc.Id" selected="@(leadMagnetSettings.AgentDocumentId == doc.Id ? "selected" : null)">@doc.FileName (uploaded @doc.UploadedAt.ToString("MMM d, yyyy"))</option>
                  }
                </select>
                <div class="form-text">Visitors must submit the form below to unlock the download link.</div>
              }
              else
              {
                <div class="alert alert-info mb-0">Upload a document first from <a href="/Documents">Documents</a>, then come back here to attach it.</div>
              }
            </div>
          }
          @if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.Reviews)
          {
            var reviewSettings = IPRO.Entities.WebsiteReviewSettings.FromJson(block.SettingsJson);
            <div class="col-md-3">
              <label class="form-label fw-semibold">Platform</label>
              <select name="reviewPlatform" class="form-select">
                <option value="Google" selected="@(reviewSettings.Platform == "Google")">Google</option>
                <option value="Facebook" selected="@(reviewSettings.Platform == "Facebook")">Facebook</option>
              </select>
            </div>
            <div class="col-md-9">
              <label class="form-label fw-semibold">Review page URL</label>
              <input type="text" name="reviewUrl" class="form-control" value="@reviewSettings.ReviewUrl" placeholder="https://g.page/r/your-business/review" />
              <div class="form-text">Where the "Read Reviews" button sends visitors — your Google Business Profile or Facebook Page reviews tab.</div>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold">Rating</label>
              <input type="number" name="reviewRating" class="form-control" value="@reviewSettings.Rating" step="0.1" min="0" max="5" />
            </div>
            <div class="col-md-3">
              <label class="form-label fw-semibold">Review count</label>
              <input type="number" name="reviewCount" class="form-control" value="@reviewSettings.ReviewCount" min="0" />
              <div class="form-text">Enter your current rating and count from @reviewSettings.Platform — update here whenever they change.</div>
            </div>
          }
          @if (block.BlockType == IPRO.Entities.WebsiteBlockTypes.AgentInfo)
          {
            var agentInfoSettings = IPRO.Entities.WebsiteAgentInfoSettings.FromJson(block.SettingsJson);
            <div class="col-12">
              <label class="form-label fw-semibold d-block">What to show</label>
              <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="showAgentPhoto_@block.Id" name="showAgentPhoto" value="true" checked="@agentInfoSettings.ShowPhoto" /><label class="form-check-label" for="showAgentPhoto_@block.Id">Photo</label></div>
              <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="showAgentDesignation_@block.Id" name="showAgentDesignation" value="true" checked="@agentInfoSettings.ShowDesignation" /><label class="form-check-label" for="showAgentDesignation_@block.Id">Designation / Company</label></div>
              <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="showAgentAddress_@block.Id" name="showAgentAddress" value="true" checked="@agentInfoSettings.ShowAddress" /><label class="form-check-label" for="showAgentAddress_@block.Id">Full Address</label></div>
              <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="showAgentPhone_@block.Id" name="showAgentPhone" value="true" checked="@agentInfoSettings.ShowPhone" /><label class="form-check-label" for="showAgentPhone_@block.Id">Phone</label></div>
              <div class="form-check form-check-inline"><input class="form-check-input" type="checkbox" id="showAgentEmail_@block.Id" name="showAgentEmail" value="true" checked="@agentInfoSettings.ShowEmail" /><label class="form-check-label" for="showAgentEmail_@block.Id">Email</label></div>
              <div class="form-text">Pulled from your Profile — update your photo, address, or phone there. Heading/subheading/body above are optional supporting text for this card.</div>
            </div>
          }
          <div class="col-12 d-flex justify-content-between align-items-center"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="isVisible" value="true" checked="@block.IsVisible" /><label class="form-check-label">Visible</label></div><button class="btn btn-outline-primary"><i class="fas fa-save me-1"></i>Save Block</button></div>
        </div>
      </form>
    </section>
  }
}
<style>
.banner-controls{padding:18px;border:1px solid #d8e3f0;border-radius:8px;background:#f7faff}
.image-library-toolbar{display:grid;grid-template-columns:minmax(260px,430px) 1fr;gap:18px;align-items:end;padding:14px;border:1px solid #d8e3f0;border-radius:7px;background:#f7faff}
.starter-banner-library summary{cursor:pointer;list-style:none}
.starter-banner-library summary::-webkit-details-marker{display:none}
.starter-banner-toolbar{display:grid;grid-template-columns:minmax(260px,430px) 1fr;gap:18px;align-items:end;padding:14px;border:1px solid #d8e3f0;border-radius:7px;background:#f7faff}
.starter-banner-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.starter-banner-choice{position:relative;overflow:hidden;margin:0;padding:0;border:2px solid transparent;border-radius:7px;background:#fff;text-align:left;box-shadow:0 4px 14px rgba(27,45,75,.08);transition:border-color .15s ease,transform .15s ease,box-shadow .15s ease}
.starter-banner-choice:not(:disabled):hover,.starter-banner-choice:focus-visible{border-color:#0d6efd;transform:translateY(-1px);box-shadow:0 8px 22px rgba(13,110,253,.16);outline:0}
.starter-banner-choice.is-selected{border-color:#198754;box-shadow:0 0 0 3px rgba(25,135,84,.14)}
.starter-banner-choice:disabled{opacity:.55}
.starter-banner-choice img{display:block;width:100%;aspect-ratio:3.6/1;object-fit:cover}
.starter-banner-caption{display:flex;justify-content:space-between;gap:8px;padding:9px 10px 30px;font-size:12px}
.starter-banner-caption span{color:#64748b}
.starter-banner-use{position:absolute;right:8px;bottom:7px;color:#0d6efd;font-size:11px;font-weight:700}
.starter-banner-choice.is-selected .starter-banner-use{color:#198754}
@@media(max-width:800px){.image-library-toolbar,.starter-banner-toolbar{grid-template-columns:1fr}.starter-banner-grid{grid-template-columns:1fr}.starter-banner-caption{font-size:11px}}
</style>
<script>
document.querySelectorAll('select[name="imageUrl"]').forEach(select => {
  select.addEventListener('change', () => {
    const preview = select.parentElement.querySelector('.block-image-preview');
    if (!preview) return;
    preview.src = select.value;
    preview.classList.toggle('d-none', !select.value);
  });
});

function chooseBlockImage(select, url, label) {
  if (!select) return false;

  const normalized = (url || '').trim();
  if (normalized && !Array.from(select.options).some(option => option.value === normalized)) {
    select.add(new Option(label || 'Selected image', normalized, true, true));
  }

  Array.from(select.options).forEach(option => {
    option.selected = option.value === normalized;
  });
  select.value = normalized;
  select.dispatchEvent(new Event('change', { bubbles: true }));
  return true;
}

async function submitBlockImage(targetPickerId, imageUrl, button) {
  const targetPicker = document.getElementById(targetPickerId);
  const form = document.getElementById('applyImageToBlockForm');
  const status = document.getElementById(targetPickerId === 'starterBannerTarget' ? 'starterBannerStatus' : 'uploadedImageStatus');
  if (!targetPicker || !form) return false;

  if (!targetPicker.value) {
    alert('Choose a destination block first.');
    return false;
  }

  const selectedImageUrl = (imageUrl || '').trim();
  if (!selectedImageUrl) {
    alert('Choose an image first.');
    return false;
  }

  const imageSelect = document.querySelector(`select[name="imageUrl"][data-block-id="${targetPicker.value}"]`);
  const label = button?.dataset.bannerName || button?.dataset.imageName || 'Selected image';
  const previousValue = imageSelect ? imageSelect.value : '';
  chooseBlockImage(imageSelect, selectedImageUrl, label);

  const pageId = form.querySelector('input[name="pageId"]')?.value || '';
  const blockId = targetPicker.value;
  const token = form.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
  const body = new URLSearchParams();
  body.set('pageId', pageId);
  body.set('blockId', blockId);
  body.set('imageUrl', selectedImageUrl);
  body.set('__RequestVerificationToken', token);

  const originalHtml = button?.innerHTML || '';
  if (button) {
    button.disabled = true;
    button.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Saving...';
  }

  try {
    const response = await fetch(form.action, {
      method: 'POST',
      body,
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
        'RequestVerificationToken': token
      }
    });

    if (response.ok) {
      if (status) {
        status.innerHTML = `<strong>${label}</strong> saved to this block.`;
      }
      if (button) {
        button.disabled = false;
        button.innerHTML = originalHtml;
      }
      return true;
    }
  } catch (error) {
    console.error('Image apply failed', error);
  }

  // The save failed: roll back the optimistic selection so the UI matches what's actually persisted.
  chooseBlockImage(imageSelect, previousValue, 'Previous image');
  if (status) {
    status.textContent = 'The image could not be saved. Refresh this page and try again.';
  }
  if (button) {
    button.disabled = false;
    button.innerHTML = originalHtml;
  }
  return false;
}

document.querySelectorAll('.starter-banner-choice').forEach(button => {
  button.addEventListener('click', event => {
    event.preventDefault();
    event.stopPropagation();
    const targetPicker = document.getElementById('starterBannerTarget');
    const status = document.getElementById('starterBannerStatus');
    if (!targetPicker) return;

    const imageSelect = document.querySelector(`select[name="imageUrl"][data-block-id="${targetPicker.value}"]`);
    if (!imageSelect) {
      if (status) status.textContent = 'That destination block could not be found. Refresh this page and try again.';
      return;
    }

    chooseBlockImage(imageSelect, button.dataset.bannerUrl || '', button.dataset.bannerName || 'Selected starter banner');
    document.querySelectorAll('.starter-banner-choice').forEach(choice => choice.classList.remove('is-selected'));
    button.classList.add('is-selected');

    if (status) status.innerHTML = `<strong>${button.dataset.bannerName}</strong> is being saved to the selected block.`;
    void submitBlockImage('starterBannerTarget', button.dataset.bannerUrl || '', button);
  });
});

document.querySelectorAll('.uploaded-image-choice').forEach(button => {
  button.addEventListener('click', event => {
    event.preventDefault();
    event.stopPropagation();
    const targetPicker = document.getElementById('uploadedImageTarget');
    const status = document.getElementById('uploadedImageStatus');
    if (!targetPicker) return;

    const imageSelect = document.querySelector(`select[name="imageUrl"][data-block-id="${targetPicker.value}"]`);
    if (!imageSelect) {
      if (status) status.textContent = 'That destination block could not be found. Refresh this page and try again.';
      return;
    }

    chooseBlockImage(imageSelect, button.dataset.imageUrl || '', button.dataset.imageName || 'Selected image');
    document.querySelectorAll('.uploaded-image-choice').forEach(choice => {
      choice.classList.remove('btn-primary');
      choice.classList.add('btn-outline-primary');
    });
    button.classList.remove('btn-outline-primary');
    button.classList.add('btn-primary');

    if (status) status.innerHTML = `<strong>${button.dataset.imageName}</strong> is being saved to the selected block.`;
    void submitBlockImage('uploadedImageTarget', button.dataset.imageUrl || '', button);
  });
});
</script>
