<!DOCTYPE html>
@inject IPRO.Business.Interfaces.IPackageEntitlementService PackageEntitlements
@{
    var navAccess = new Dictionary<string, IPRO.Business.Interfaces.PackageFeatureAccess>();
    if (User.Identity?.IsAuthenticated == true &&
        int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var layoutAgentId))
    {
        foreach (var featureCode in new[]
        {
            IPRO.Entities.PackageFeatureCodes.CalendarScheduler,
            IPRO.Entities.PackageFeatureCodes.Newsletters,
            IPRO.Entities.PackageFeatureCodes.MarketingCampaign,
            IPRO.Entities.PackageFeatureCodes.InstantWebsite,
            IPRO.Entities.PackageFeatureCodes.VisitorTracking,
            IPRO.Entities.PackageFeatureCodes.TestimonialManager
        })
        {
            navAccess[featureCode] = await PackageEntitlements.GetAccessAsync(layoutAgentId, featureCode);
        }
    }

    string LockedNavAttributes(string featureCode)
    {
        if (!navAccess.TryGetValue(featureCode, out var access) || access.IsIncluded)
        {
            return "";
        }

        return $"data-upgrade-lock=\"true\" data-upgrade-title=\"{access.FeatureName}\" data-upgrade-message=\"{access.UpgradeMessage}\"";
    }

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavActive(params string[] controllers) => controllers.Contains(currentController, StringComparer.OrdinalIgnoreCase) ? "active" : "";
    var clientsMainActive = currentController == "Clients" && currentAction != "FollowUpQueue" && currentAction != "FollowUps" && currentAction != "Calendar" ? "active" : "";
    string ClientsSubActive(string action) => currentController == "Clients" && currentAction == action ? "active" : "";

    var portalAccentColor = User.FindFirst("PortalAccentColor")?.Value ?? "";
    var effectiveAccent = string.IsNullOrEmpty(portalAccentColor) ? "#1457d9" : portalAccentColor;
    var portalColorSwatches = new (string Hex, string Name)[]
    {
        ("#1457d9", "Ocean Blue"),
        ("#d9541f", "Sunset Orange"),
        ("#1f7a4d", "Forest Green"),
        ("#4b5563", "Slate Gray"),
        ("#7a1f3d", "Burgundy"),
        ("#5b2f9e", "Royal Purple")
    };
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IPRO Agent Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        :root { --portal-accent: @effectiveAccent; }

        /* App-wide accent unification: every semantic Bootstrap color (primary/success/danger/warning/info)
           maps to the agent's chosen portal color instead of Bootstrap's defaults, so the whole app feels
           personalized rather than just the sidebar. Alerts are deliberately excluded since they're transient
           system feedback (success/error/warning), not persistent brand chrome. */
        .btn-primary, .btn-success, .btn-danger, .btn-warning, .btn-info {
            --bs-btn-color:#fff; --bs-btn-bg:var(--portal-accent); --bs-btn-border-color:var(--portal-accent);
            --bs-btn-hover-color:#fff; --bs-btn-hover-bg:color-mix(in srgb, var(--portal-accent) 85%, black); --bs-btn-hover-border-color:color-mix(in srgb, var(--portal-accent) 80%, black);
            --bs-btn-active-color:#fff; --bs-btn-active-bg:color-mix(in srgb, var(--portal-accent) 80%, black); --bs-btn-active-border-color:color-mix(in srgb, var(--portal-accent) 75%, black);
            --bs-btn-disabled-bg:var(--portal-accent); --bs-btn-disabled-border-color:var(--portal-accent);
        }
        .btn-outline-primary, .btn-outline-success, .btn-outline-danger, .btn-outline-warning, .btn-outline-info {
            --bs-btn-color:var(--portal-accent); --bs-btn-border-color:var(--portal-accent);
            --bs-btn-hover-color:#fff; --bs-btn-hover-bg:var(--portal-accent); --bs-btn-hover-border-color:var(--portal-accent);
            --bs-btn-active-color:#fff; --bs-btn-active-bg:var(--portal-accent); --bs-btn-active-border-color:var(--portal-accent);
            --bs-btn-disabled-color:var(--portal-accent); --bs-btn-disabled-border-color:var(--portal-accent);
        }
        .text-primary, .text-success, .text-danger, .text-warning, .text-info { color:var(--portal-accent) !important; }
        .bg-primary, .bg-success, .bg-danger, .bg-warning, .bg-info { background-color:var(--portal-accent) !important; }
        .border-primary, .border-success, .border-danger, .border-warning, .border-info { border-color:var(--portal-accent) !important; }
        .bg-primary-subtle, .bg-success-subtle, .bg-danger-subtle, .bg-warning-subtle, .bg-info-subtle {
            background-color:color-mix(in srgb, var(--portal-accent) 15%, white) !important;
        }
        .text-primary-emphasis, .text-success-emphasis, .text-danger-emphasis, .text-warning-emphasis, .text-info-emphasis {
            color:color-mix(in srgb, var(--portal-accent) 70%, black) !important;
        }
        .form-control:focus, .form-select:focus {
            border-color:var(--portal-accent);
            box-shadow:0 0 0 0.25rem color-mix(in srgb, var(--portal-accent) 25%, transparent);
        }
        .form-check-input:focus { border-color:var(--portal-accent); box-shadow:0 0 0 0.25rem color-mix(in srgb, var(--portal-accent) 25%, transparent); }
        .form-check-input:checked { background-color:var(--portal-accent); border-color:var(--portal-accent); }
        a:not(.btn):not(.nav-link):not(.dropdown-item):not(.page-link) { color:var(--portal-accent); }
        a:not(.btn):not(.nav-link):not(.dropdown-item):not(.page-link):hover { color:color-mix(in srgb, var(--portal-accent) 85%, black); }
        .page-link { color:var(--portal-accent); }
        .page-item.active .page-link { background-color:var(--portal-accent); border-color:var(--portal-accent); }
        .dropdown-item.active, .dropdown-item:active { background-color:var(--portal-accent) !important; }

        .agent-sidebar { width:250px; height:100vh; background:linear-gradient(180deg,#0f172a 0%,#1e3a5f 100%); position:fixed; top:0; left:0; z-index:1040; display:flex; flex-direction:column; }
        .agent-sidebar .brand { flex-shrink:0; padding:1.25rem 1.25rem 1rem; border-bottom:1px solid rgba(255,255,255,0.1); }
        .agent-sidebar .brand a { color:#fff; font-weight:700; text-decoration:none; font-size:1.05rem; }
        .agent-sidebar .brand i { color:var(--portal-accent); }
        .agent-sidebar-nav { flex:1 1 auto; min-height:0; overflow-y:auto; padding-bottom:.5rem; }
        .agent-sidebar-nav::-webkit-scrollbar { width:6px; }
        .agent-sidebar-nav::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.15); border-radius:3px; }
        .agent-sidebar .nav-section { color:rgba(255,255,255,0.35); font-size:.7rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em; padding:.9rem 1.25rem .25rem; }
        .agent-sidebar .nav-link { color:rgba(255,255,255,0.75); padding:.6rem 1.25rem; border-radius:8px; margin:.05rem .75rem; transition:background .15s, color .15s; }
        .agent-sidebar .nav-link:hover { background:color-mix(in srgb, var(--portal-accent) 25%, transparent); color:#fff; }
        .agent-sidebar .nav-link.active { background:var(--portal-accent); color:#fff; }
        .agent-sidebar .nav-link i { width:20px; margin-right:.6rem; text-align:center; }

        .agent-sidebar-footer { flex-shrink:0; border-top:1px solid rgba(255,255,255,0.1); padding:.75rem 0; }
        .portal-color-row { display:flex; gap:.4rem; padding:.25rem 1.25rem .75rem; }
        .portal-color-swatch { width:20px; height:20px; border-radius:50%; border:2px solid transparent; padding:0; cursor:pointer; }
        .portal-color-swatch.is-active { border-color:#fff; box-shadow:0 0 0 2px var(--portal-accent); }
        .agent-sidebar-footer .nav-link { font-size:.9rem; }

        .agent-topbar { margin-left:250px; background:#fff; border-bottom:1px solid #e5e7eb; padding:.65rem 1.5rem; display:flex; justify-content:space-between; align-items:center; position:sticky; top:0; z-index:1030; }
        .agent-content { margin-left:250px; padding:1.25rem 1.5rem; }
        .sidebar-toggle-btn { display:none; background:none; border:1px solid #d1d5db; border-radius:6px; padding:.3rem .6rem; }

        @@media (max-width: 991.98px) {
            .agent-sidebar { transform:translateX(-100%); transition:transform .2s ease; }
            .agent-sidebar.show { transform:translateX(0); }
            .agent-topbar, .agent-content { margin-left:0; }
            .sidebar-toggle-btn { display:inline-block; }
        }
    </style>
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
<aside class="agent-sidebar" id="agentSidebar">
    <div class="brand">
        <a href="/"><i class="fas fa-shield-alt me-2"></i>IPRO Agent Portal</a>
    </div>
    <nav class="agent-sidebar-nav">
        <div class="nav-section">Overview</div>
        <a class="nav-link @NavActive("Dashboard")" href="/Dashboard"><i class="fas fa-home"></i>Dashboard</a>

        <div class="nav-section">Clients</div>
        <a class="nav-link @clientsMainActive" href="/Clients"><i class="fas fa-users"></i>Clients</a>
        <a class="nav-link @(currentController == "Clients" && (currentAction == "FollowUpQueue" || currentAction == "FollowUps") ? "active" : "")" href="/Clients/FollowUps?status=open"><i class="fas fa-list-check"></i>Follow-ups</a>
        <a class="nav-link @ClientsSubActive("Calendar")" href="/Clients/Calendar" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.CalendarScheduler))><i class="fas fa-calendar-alt"></i>Calendar</a>

        <div class="nav-section">Marketing</div>
        <a class="nav-link @NavActive("Newsletter")" href="/Newsletter" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.Newsletters))><i class="fas fa-envelope"></i>Newsletter</a>
        <a class="nav-link @NavActive("Campaigns")" href="/Campaigns" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.MarketingCampaign))><i class="fas fa-bullhorn"></i>Campaigns</a>
        <a class="nav-link @NavActive("SocialPosts")" href="/SocialPosts"><i class="fas fa-share-nodes"></i>Social Posts</a>

        <div class="nav-section">Website</div>
        <a class="nav-link @NavActive("Website", "WebsitePages")" href="/Website" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.InstantWebsite))><i class="fas fa-globe"></i>My Website</a>
        <a class="nav-link @NavActive("WebsiteLeads")" href="/WebsiteLeads"><i class="fas fa-inbox"></i>Website Leads</a>
        <a class="nav-link @NavActive("WebsiteAnalytics")" href="/WebsiteAnalytics" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.VisitorTracking))><i class="fas fa-chart-line"></i>Analytics</a>
        <a class="nav-link @NavActive("Testimonials")" href="/Testimonials" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.TestimonialManager))><i class="fas fa-quote-left"></i>Testimonials</a>

        <div class="nav-section">Billing</div>
        <a class="nav-link @NavActive("Billing")" href="/Billing"><i class="fas fa-credit-card"></i>Billing</a>
        <a class="nav-link @NavActive("ClientInvoices", "RecurringInvoices")" href="/ClientInvoices"><i class="fas fa-file-invoice-dollar"></i>Client Invoices</a>

        <div class="nav-section">Client Portal</div>
        <a class="nav-link @NavActive("PortalMessages")" href="/PortalMessages"><i class="fas fa-comments"></i>Portal Messages</a>
        <a class="nav-link @NavActive("PortalRequests")" href="/PortalRequests"><i class="fas fa-calendar-check"></i>Portal Requests</a>

        <div class="nav-section">Tools</div>
        <a class="nav-link @NavActive("Documents")" href="/Documents"><i class="fas fa-folder-open"></i>Documents</a>

        <div class="nav-section">Support</div>
        <a class="nav-link @NavActive("Support")" href="/Support"><i class="fas fa-life-ring"></i>Support</a>
    </nav>
    <div class="agent-sidebar-footer">
        <div class="portal-color-row">
            @foreach (var swatch in portalColorSwatches)
            {
                <form asp-controller="Account" asp-action="SetPortalAccentColor" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="color" value="@swatch.Hex" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" class="portal-color-swatch @(portalAccentColor == swatch.Hex ? "is-active" : "")" style="background-color:@swatch.Hex;" title="@swatch.Name" aria-label="@swatch.Name"></button>
                </form>
            }
        </div>
        <a class="nav-link" href="/Account/Profile"><i class="fas fa-id-card"></i>@User.FindFirst("FullName")?.Value</a>
        <a class="nav-link" href="/Account/ChangePassword"><i class="fas fa-key"></i>Change Password</a>
        <a class="nav-link text-danger" href="/Account/Logout"><i class="fas fa-sign-out-alt"></i>Logout</a>
    </div>
</aside>

<div class="agent-topbar">
    <div class="d-flex align-items-center gap-2">
        <button type="button" class="sidebar-toggle-btn" id="sidebarToggle"><i class="fas fa-bars"></i></button>
        <span class="fw-semibold text-muted">@ViewData["Title"]</span>
    </div>
</div>
}
<div class="@(User.Identity?.IsAuthenticated == true ? "agent-content" : "")">
    @if (TempData["Success"] != null)
    { <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Error"] != null)
    { <div class="alert alert-danger alert-dismissible fade show"><i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Warning"] != null)
    { <div class="alert alert-warning alert-dismissible fade show"><i class="fas fa-exclamation-triangle me-2"></i>@TempData["Warning"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Component.InvokeAsync("BillingIssue")
    }
    @RenderBody()
</div>
@if (User.Identity?.IsAuthenticated == true)
{
<div class="modal fade" id="upgradeRequiredModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="upgradeRequiredTitle">Upgrade required</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="upgradeRequiredMessage" class="mb-0">This function requires a package upgrade.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Not now</button>
                <a href="/Billing" class="btn btn-primary">View Packages</a>
            </div>
        </div>
    </div>
</div>
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
<script>
document.querySelectorAll('[data-upgrade-lock="true"]').forEach(link => {
    link.addEventListener('click', event => {
        event.preventDefault();
        document.getElementById('upgradeRequiredTitle').textContent = link.dataset.upgradeTitle || 'Upgrade required';
        document.getElementById('upgradeRequiredMessage').textContent = link.dataset.upgradeMessage || 'This function requires a package upgrade.';
        bootstrap.Modal.getOrCreateInstance(document.getElementById('upgradeRequiredModal')).show();
    });
});
const sidebarToggle = document.getElementById('sidebarToggle');
if (sidebarToggle) {
    sidebarToggle.addEventListener('click', () => {
        document.getElementById('agentSidebar')?.classList.toggle('show');
    });
}
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
