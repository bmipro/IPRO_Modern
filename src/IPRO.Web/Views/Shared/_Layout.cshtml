<!DOCTYPE html>
@inject IPRO.Business.Interfaces.IPackageEntitlementService PackageEntitlements
@{
    var navAccess = new Dictionary<string, IPRO.Business.Interfaces.PackageFeatureAccess>();
    if (User.Identity?.IsAuthenticated == true &&
        int.TryParse(User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var layoutAgentId))
    {
        foreach (var featureCode in new[]
        {
            IPRO.Entities.PackageFeatureCodes.CalendarScheduler,
            IPRO.Entities.PackageFeatureCodes.Newsletters,
            IPRO.Entities.PackageFeatureCodes.MarketingCampaign,
            IPRO.Entities.PackageFeatureCodes.InstantWebsite
        })
        {
            navAccess[featureCode] = await PackageEntitlements.GetAccessAsync(layoutAgentId, featureCode);
        }
    }

    string LockedNavAttributes(string featureCode)
    {
        if (!navAccess.TryGetValue(featureCode, out var access) || access.IsIncluded)
        {
            return "";
        }

        return $"data-upgrade-lock=\"true\" data-upgrade-title=\"{access.FeatureName}\" data-upgrade-message=\"{access.UpgradeMessage}\"";
    }
}
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - IPRO Agent Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
@if (User.Identity?.IsAuthenticated == true)
{
<nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/"><i class="fas fa-shield-alt me-2"></i>IPRO Agent Portal</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navMain">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="/Dashboard"><i class="fas fa-home me-1"></i>Dashboard</a></li>
                <li class="nav-item"><a class="nav-link" href="/Clients"><i class="fas fa-users me-1"></i>Clients</a></li>
                <li class="nav-item"><a class="nav-link" href="/Clients/FollowUps?status=open"><i class="fas fa-list-check me-1"></i>Follow-ups</a></li>
                <li class="nav-item"><a class="nav-link" href="/Clients/Calendar" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.CalendarScheduler))><i class="fas fa-calendar-alt me-1"></i>Calendar</a></li>
                <li class="nav-item"><a class="nav-link" href="/Newsletter" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.Newsletters))><i class="fas fa-envelope me-1"></i>Newsletter</a></li>
                <li class="nav-item"><a class="nav-link" href="/Campaigns" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.MarketingCampaign))><i class="fas fa-bullhorn me-1"></i>Campaigns</a></li>
                <li class="nav-item"><a class="nav-link" href="/Website" @Html.Raw(LockedNavAttributes(IPRO.Entities.PackageFeatureCodes.InstantWebsite))><i class="fas fa-globe me-1"></i>My Website</a></li>
                <li class="nav-item"><a class="nav-link" href="/Billing"><i class="fas fa-credit-card me-1"></i>Billing</a></li>
            </ul>
            <ul class="navbar-nav">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="fas fa-user-circle me-1"></i>@User.FindFirst("FullName")?.Value
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/Account/Profile"><i class="fas fa-id-card me-2"></i>My Profile</a></li>
                        <li><a class="dropdown-item" href="/Account/ChangePassword"><i class="fas fa-key me-2"></i>Change Password</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="/Account/Logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                    </ul>
                </li>
            </ul>
        </div>
    </div>
</nav>
}
<div class="@(User.Identity?.IsAuthenticated == true ? "container-fluid mt-3" : "")">
    @if (TempData["Success"] != null)
    { <div class="alert alert-success alert-dismissible fade show"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Error"] != null)
    { <div class="alert alert-danger alert-dismissible fade show"><i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Warning"] != null)
    { <div class="alert alert-warning alert-dismissible fade show"><i class="fas fa-exclamation-triangle me-2"></i>@TempData["Warning"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Component.InvokeAsync("BillingIssue")
    }
    @RenderBody()
</div>
@if (User.Identity?.IsAuthenticated == true)
{
<div class="modal fade" id="upgradeRequiredModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title fw-bold" id="upgradeRequiredTitle">Upgrade required</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p id="upgradeRequiredMessage" class="mb-0">This function requires a package upgrade.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Not now</button>
                <a href="/Billing" class="btn btn-primary">View Packages</a>
            </div>
        </div>
    </div>
</div>
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
<script>
document.querySelectorAll('[data-upgrade-lock="true"]').forEach(link => {
    link.addEventListener('click', event => {
        event.preventDefault();
        document.getElementById('upgradeRequiredTitle').textContent = link.dataset.upgradeTitle || 'Upgrade required';
        document.getElementById('upgradeRequiredMessage').textContent = link.dataset.upgradeMessage || 'This function requires a package upgrade.';
        bootstrap.Modal.getOrCreateInstance(document.getElementById('upgradeRequiredModal')).show();
    });
});
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
