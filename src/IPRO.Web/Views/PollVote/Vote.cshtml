@{
    Layout = null;
    var state = ViewBag.State as string ?? "invalid";
    var survey = ViewBag.Survey as IPRO.Entities.PollSurvey;
    var questions = (ViewBag.Questions as IEnumerable<IPRO.Entities.PollQuestion>)?.ToList() ?? new List<IPRO.Entities.PollQuestion>();
    var optionsByQuestion = ViewBag.OptionsByQuestion as Dictionary<int, List<IPRO.Entities.PollOption>> ?? new Dictionary<int, List<IPRO.Entities.PollOption>>();
    var token = ViewBag.Token as string ?? "";
    var error = ViewBag.Error as string;
    var agentSiteUrl = ViewBag.AgentSiteUrl as string;
    var redirectSeconds = 6;
}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>@(survey?.Title ?? "Poll") - IPRO Advisers</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
  <style>
    body {
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, #eef4ff, #ffffff);
      color: #172033;
      padding: 24px 0;
    }
    .poll-card {
      width: min(640px, calc(100vw - 32px));
      border: 0;
      border-radius: 18px;
      box-shadow: 0 24px 60px rgba(15, 23, 42, .12);
    }
    .poll-question { border: 1px solid #dbe5f2; border-radius: 12px; padding: 16px 18px; margin-bottom: 16px; }
    .poll-option { display: flex; align-items: center; gap: 10px; padding: 8px 0; }
  </style>
</head>
<body>
  <main class="card poll-card">
    <div class="card-body p-5">
      @if (state == "invalid")
      {
        <div class="text-center">
          <div class="display-6 text-warning mb-3"><i class="fas fa-triangle-exclamation"></i></div>
          <h1 class="h3 fw-bold">This poll link is not valid</h1>
          <p class="text-muted mb-0">The link may have been copied incorrectly or may no longer exist.</p>
        </div>
      }
      else if (state == "already-voted")
      {
        <div class="text-center">
          <div class="display-6 text-primary mb-3"><i class="fas fa-circle-check"></i></div>
          <h1 class="h3 fw-bold">You've already responded</h1>
          <p class="text-muted mb-0">Thanks again for sharing your answers to this poll.</p>
          @if (!string.IsNullOrWhiteSpace(agentSiteUrl))
          {
            <p class="text-muted small mt-3 mb-0">Taking you back in <span id="redirect-countdown">@redirectSeconds</span>s, or <a href="@agentSiteUrl">go now</a>.</p>
          }
        </div>
      }
      else if (state == "submitted")
      {
        <div class="text-center">
          <div class="display-6 text-success mb-3"><i class="fas fa-circle-check"></i></div>
          <h1 class="h3 fw-bold">Thank you!</h1>
          <p class="text-muted mb-0">Your responses have been recorded.</p>
          @if (!string.IsNullOrWhiteSpace(agentSiteUrl))
          {
            <p class="text-muted small mt-3 mb-0">Taking you back in <span id="redirect-countdown">@redirectSeconds</span>s, or <a href="@agentSiteUrl">go now</a>.</p>
          }
        </div>
      }
      else
      {
        <h1 class="h3 fw-bold mb-1">@survey!.Title</h1>
        @if (!string.IsNullOrWhiteSpace(survey.IntroText))
        {
          <p class="text-muted">@survey.IntroText</p>
        }
        @if (!string.IsNullOrWhiteSpace(error))
        {
          <div class="alert alert-danger">@error</div>
        }
        <form method="post" action="/Poll/Vote">
          @Html.AntiForgeryToken()
          <input type="hidden" name="Token" value="@token" />
          @for (var i = 0; i < questions.Count; i++)
          {
            var question = questions[i];
            var options = optionsByQuestion.GetValueOrDefault(question.Id, new List<IPRO.Entities.PollOption>());
            <div class="poll-question">
              <input type="hidden" name="Answers[@i].QuestionId" value="@question.Id" />
              <div class="fw-semibold mb-2">@question.Text</div>
              @foreach (var option in options)
              {
                <label class="poll-option">
                  <input type="radio" name="Answers[@i].OptionId" value="@option.Id" required />
                  <span>@option.Text</span>
                </label>
              }
            </div>
          }
          <button type="submit" class="btn btn-primary w-100 mt-2"><i class="fas fa-paper-plane me-2"></i>Submit</button>
        </form>
      }
    </div>
  </main>
  @if (!string.IsNullOrWhiteSpace(agentSiteUrl) && (state == "submitted" || state == "already-voted"))
  {
    <script>
      (function () {
        var seconds = @redirectSeconds;
        var el = document.getElementById('redirect-countdown');
        var timer = setInterval(function () {
          seconds -= 1;
          if (el) el.textContent = seconds;
          if (seconds <= 0) {
            clearInterval(timer);
            window.location.href = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(agentSiteUrl));
          }
        }, 1000);
      })();
    </script>
  }
</body>
</html>
