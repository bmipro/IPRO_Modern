@{ ViewData["Title"] = "Client Portal Login"; Layout = null; }
<!DOCTYPE html>
<html><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Client Portal Login</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<style>
body{background:linear-gradient(135deg,#0f3d2e 0%,#0f7a52 100%);min-height:100vh;display:flex;align-items:center;}
.card{border:none;border-radius:16px;box-shadow:0 20px 60px rgba(0,0,0,0.3);}
.brand-icon{font-size:3rem;color:#0f7a52;}
</style></head>
<body>
<div class="container">
<div class="row justify-content-center">
<div class="col-md-5">
<div class="card">
<div class="card-body p-5">
  <div class="text-center mb-4">
    <i class="fas fa-user-shield brand-icon"></i>
    <h3 class="fw-bold mt-2">Client Portal</h3>
    <p class="text-muted">Sign in to view your messages, documents, and invoices</p>
  </div>
  @if (!ViewData.ModelState.IsValid)
  { <div class="alert alert-danger">@Html.ValidationSummary()</div> }
  <form asp-action="Login" method="post">
    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
    <div class="mb-3">
      <label class="form-label fw-semibold">Email</label>
      <input type="email" name="email" class="form-control form-control-lg" placeholder="you@example.com" required/>
    </div>
    <div class="mb-4">
      <label class="form-label fw-semibold">Password</label>
      <input type="password" name="password" class="form-control form-control-lg" placeholder="Enter your password" required/>
    </div>
    <button type="submit" class="btn btn-success btn-lg w-100">Sign In</button>
  </form>
</div></div></div></div></div>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
