@model IPRO.Entities.PollSurvey
@{
    ViewData["Title"] = "Poll Results";
    var questions = (ViewBag.Questions as IEnumerable<IPRO.Entities.PollQuestion>)?.ToList() ?? new List<IPRO.Entities.PollQuestion>();
    var optionsByQuestion = ViewBag.OptionsByQuestion as Dictionary<int, List<IPRO.Entities.PollOption>> ?? new Dictionary<int, List<IPRO.Entities.PollOption>>();
    var answerCounts = ViewBag.AnswerCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var responseRate = Model.TotalSent > 0 ? Math.Round(100.0 * Model.TotalResponded / Model.TotalSent, 1) : 0;
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <div class="small text-muted mb-1"><a href="/Polls">Polls</a> / <a href="/Polls/Preview/@Model.Id">Preview</a> / Results</div>
    <h2 class="fw-bold mb-1"><i class="fas fa-chart-column me-2 text-primary"></i>@Model.Title</h2>
    <div class="text-muted">Sent to @Model.TotalSent &middot; @Model.TotalResponded responded (@responseRate%)</div>
  </div>
  <a href="/Polls/Preview/@Model.Id" class="btn btn-outline-secondary">Back to Preview</a>
</div>

@foreach (var question in questions)
{
  var options = optionsByQuestion.GetValueOrDefault(question.Id, new List<IPRO.Entities.PollOption>());
  var totalAnswers = options.Sum(o => answerCounts.GetValueOrDefault(o.Id, 0));
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 pt-4 px-4"><h5 class="fw-bold mb-0">@question.Text</h5></div>
    <div class="card-body p-4">
      @if (totalAnswers == 0)
      {
        <p class="text-muted small mb-0">No responses yet for this question.</p>
      }
      else
      {
        @foreach (var option in options)
        {
          var count = answerCounts.GetValueOrDefault(option.Id, 0);
          var pct = totalAnswers > 0 ? Math.Round(100.0 * count / totalAnswers, 1) : 0;
          <div class="mb-3">
            <div class="d-flex justify-content-between small mb-1">
              <span class="fw-semibold">@option.Text</span>
              <span class="text-muted">@count vote@(count == 1 ? "" : "s") (@pct%)</span>
            </div>
            <div class="progress" style="height:10px">
              <div class="progress-bar" role="progressbar" style="width:@pct%"></div>
            </div>
          </div>
        }
      }
    </div>
  </div>
}
