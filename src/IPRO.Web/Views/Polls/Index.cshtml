@model IReadOnlyCollection<IPRO.Entities.PollSurvey>
@{
    ViewData["Title"] = "Polls";
    string StatusBadge(IPRO.Entities.PollSurveyStatus s) => s switch
    {
        IPRO.Entities.PollSurveyStatus.Sent => "bg-success-subtle text-success",
        IPRO.Entities.PollSurveyStatus.Scheduled => "bg-warning-subtle text-warning",
        IPRO.Entities.PollSurveyStatus.Sending => "bg-info-subtle text-info",
        _ => "bg-secondary-subtle text-secondary"
    };
}

<div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-4">
  <div>
    <h2 class="fw-bold mb-1"><i class="fas fa-square-poll-vertical me-2 text-primary"></i>Polls</h2>
    <div class="text-muted">Build a short poll, send it to your client list, and see the results roll in.</div>
  </div>
  <a class="btn btn-primary" href="/Polls/Create"><i class="fas fa-plus me-1"></i>New Poll</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-3">
    @if (!Model.Any())
    {
      <p class="text-muted small mb-0">No polls yet. Click <strong>New Poll</strong> to build one.</p>
    }
    else
    {
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr class="text-muted small text-uppercase">
              <th>Title</th>
              <th>Status</th>
              <th>Sent / Responded</th>
              <th>Updated</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var poll in Model)
            {
              <tr>
                <td>@poll.Title</td>
                <td><span class="badge rounded-pill @StatusBadge(poll.Status)">@poll.Status</span></td>
                <td class="small text-muted">@poll.TotalSent / @poll.TotalResponded</td>
                <td class="small text-muted">@poll.UpdatedAt.ToString("MMM d, yyyy")</td>
                <td class="text-end">
                  <a class="btn btn-sm btn-outline-secondary" href="/Polls/Preview/@poll.Id">View</a>
                  @if (poll.Status == IPRO.Entities.PollSurveyStatus.Draft)
                  {
                    <form asp-action="Delete" asp-route-id="@poll.Id" method="post" class="d-inline">
                      @Html.AntiForgeryToken()
                      <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Delete this poll?"><i class="fas fa-trash"></i></button>
                    </form>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>
