@model IPRO.Entities.PollSurvey
@{
    ViewData["Title"] = "Poll Preview";
    var questions = (ViewBag.Questions as IEnumerable<IPRO.Entities.PollQuestion>)?.ToList() ?? new List<IPRO.Entities.PollQuestion>();
    var optionsByQuestion = ViewBag.OptionsByQuestion as Dictionary<int, List<IPRO.Entities.PollOption>> ?? new Dictionary<int, List<IPRO.Entities.PollOption>>();
    var sends = (ViewBag.Sends as IEnumerable<IPRO.Entities.PollSend>)?.ToList() ?? new List<IPRO.Entities.PollSend>();
    string StatusBadge(IPRO.Entities.PollSendStatus s) => s switch
    {
        IPRO.Entities.PollSendStatus.Sent => "bg-success-subtle text-success",
        IPRO.Entities.PollSendStatus.Scheduled => "bg-warning-subtle text-warning",
        IPRO.Entities.PollSendStatus.Cancelled => "bg-secondary-subtle text-secondary",
        IPRO.Entities.PollSendStatus.Failed => "bg-danger-subtle text-danger",
        _ => "bg-info-subtle text-info"
    };
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <div class="small text-muted mb-1"><a href="/Polls">Polls</a> / Preview</div>
    <h2 class="fw-bold mb-1"><i class="fas fa-square-poll-vertical me-2 text-primary"></i>@Model.Title</h2>
    <span class="badge rounded-pill bg-secondary-subtle text-secondary">@Model.Status</span>
  </div>
  <div class="d-flex gap-2">
    @if (Model.Status == IPRO.Entities.PollSurveyStatus.Draft)
    {
      <a href="/Polls/Edit/@Model.Id" class="btn btn-outline-secondary"><i class="fas fa-edit me-1"></i>Edit</a>
      <a href="/Polls/Send/@Model.Id" class="btn btn-primary"><i class="fas fa-paper-plane me-1"></i>Send</a>
    }
    @if (sends.Any())
    {
      <a href="/Polls/Results/@Model.Id" class="btn btn-outline-primary"><i class="fas fa-chart-column me-1"></i>Results</a>
    }
  </div>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-4">
    <div class="small text-muted mb-3">Email subject: <strong>@Model.Subject</strong></div>
    <p class="text-muted">@Model.IntroText</p>
    @foreach (var question in questions)
    {
      <div class="mb-3">
        <div class="fw-semibold mb-1">@question.Text</div>
        <ul class="mb-0">
          @foreach (var option in optionsByQuestion.GetValueOrDefault(question.Id, new List<IPRO.Entities.PollOption>()))
          {
            <li class="text-muted">@option.Text</li>
          }
        </ul>
      </div>
    }
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white border-0 pt-4 px-4"><h5 class="fw-bold mb-0">Send History</h5></div>
  <div class="card-body p-4">
    @if (!sends.Any())
    {
      <p class="text-muted small mb-0">This poll hasn't been sent yet.</p>
    }
    else
    {
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr class="text-muted small text-uppercase">
              <th>Audience</th>
              <th>Status</th>
              <th>Scheduled</th>
              <th>Sent / Failed / Responded</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var send in sends)
            {
              <tr>
                <td>@send.AudienceLabel</td>
                <td><span class="badge rounded-pill @StatusBadge(send.Status)">@send.Status</span></td>
                <td class="small text-muted">@send.ScheduledAt.ToString("MMM d, yyyy h:mm tt")</td>
                <td class="small text-muted">@send.TotalSent / @send.TotalFailed / @send.TotalResponded</td>
                <td class="text-end">
                  @if (send.Status == IPRO.Entities.PollSendStatus.Scheduled)
                  {
                    <form asp-action="CancelSend" asp-route-sendId="@send.Id" asp-route-pollSurveyId="@Model.Id" method="post" class="d-inline">
                      @Html.AntiForgeryToken()
                      <button type="submit" class="btn btn-sm btn-outline-danger">Cancel</button>
                    </form>
                  }
                </td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    }
  </div>
</div>
