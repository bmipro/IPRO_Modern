@model IPRO.Entities.Client
@{
    ViewData["Title"] = $"{Model.FirstName} {Model.LastName}";
    var comments = ViewBag.Comments as IEnumerable<IPRO.Entities.ClientComment>;
    var recentComments = (comments ?? Enumerable.Empty<IPRO.Entities.ClientComment>())
        .OrderByDescending(c => c.CreatedAt)
        .Take(5)
        .ToList();
    var timeline = (ViewBag.Timeline as IEnumerable<IPRO.Web.Models.ClientTimelineItem>) ?? Enumerable.Empty<IPRO.Web.Models.ClientTimelineItem>();
    var addressParts = new[] { Model.Address, Model.UnitNumber, Model.City, Model.Province, Model.PostalCode, Model.Country }
        .Where(x => !string.IsNullOrWhiteSpace(x));
    var fullAddress = string.Join(", ", addressParts);
    var allOpenFollowUps = Model.FollowUps.Where(f => !f.IsCompleted).OrderBy(f => f.DueAt).ToList();
    var openFollowUps = allOpenFollowUps.Take(5).ToList();
    var completedFollowUps = Model.FollowUps.Where(f => f.IsCompleted).OrderByDescending(f => f.CompletedAt ?? f.DueAt).Take(5).ToList();
    var totalFollowUps = Model.FollowUps.Count;
    string Display(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value;
    string DueBadgeClass(DateTime dueAt) => dueAt.Date < DateTime.Today ? "bg-danger-subtle text-danger" : dueAt.Date == DateTime.Today ? "bg-warning-subtle text-warning" : "bg-primary-subtle text-primary";
    string DueLabel(DateTime dueAt) => dueAt.Date < DateTime.Today ? "Overdue" : dueAt.Date == DateTime.Today ? "Today" : dueAt.ToString("MMM d, yyyy");
}

<div class="row mb-4">
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Clients">Clients</a></li><li class="breadcrumb-item active">@Model.FirstName @Model.LastName</li></ol>
    </nav>
    <div class="d-flex justify-content-between align-items-center">
      <h2 class="fw-bold mb-0">@Model.FirstName @Model.LastName</h2>
      <div class="d-flex gap-2">
        <a href="/Clients/Edit/@Model.Id" class="btn btn-outline-primary"><i class="fas fa-edit me-1"></i>Edit</a>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
          @Html.AntiForgeryToken()
          <button type="submit" class="btn btn-outline-danger" data-confirm="Delete @Model.FirstName @Model.LastName permanently?"><i class="fas fa-trash me-1"></i>Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4">
        <div class="text-center mb-3">
          <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-2" style="width:72px;height:72px;">
            <span class="fw-bold text-primary fs-3">@Model.FirstName[0]@Model.LastName[0]</span>
          </div>
          <h5 class="fw-bold mb-0">@Model.FirstName @Model.LastName</h5>
          @if (Model.IsNewsletterSubscribed)
          { <span class="badge bg-success-subtle text-success mt-1"><i class="fas fa-envelope me-1"></i>Newsletter subscriber</span> }
          @if (Model.Categories.Any())
          {
            <div class="d-flex flex-wrap justify-content-center gap-1 mt-2">
              @foreach (var category in Model.Categories.OrderBy(c => c.Name))
              {
                <span class="badge bg-primary-subtle text-primary rounded-pill">@category.Name</span>
              }
            </div>
          }
        </div>
        <hr/>
        <dl class="row mb-0 client-details-list" style="font-size:.9rem">
          <dt class="col-5 text-muted">Company</dt>
          <dd class="col-7">@Display(Model.CompanyName)</dd>
          <dt class="col-5 text-muted">Email</dt>
          <dd class="col-7"><a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a></dd>
          <dt class="col-5 text-muted">Email 2</dt>
          <dd class="col-7">
            @if (!string.IsNullOrWhiteSpace(Model.Email2))
            {
              <a href="mailto:@Model.Email2" class="text-decoration-none">@Model.Email2</a>
            }
            else
            {
              <span>-</span>
            }
          </dd>
          <dt class="col-5 text-muted">Date of Birth</dt>
          <dd class="col-7">@(Model.DateOfBirth?.ToString("MMM d, yyyy") ?? "-")</dd>
          <dt class="col-5 text-muted">Home 1</dt>
          <dd class="col-7">@Display(Model.Phone)</dd>
          <dt class="col-5 text-muted">Home 2</dt>
          <dd class="col-7">@Display(Model.HomePhone2)</dd>
          <dt class="col-5 text-muted">Business 1</dt>
          <dd class="col-7">@Display(Model.BusinessPhone)</dd>
          <dt class="col-5 text-muted">Business 2</dt>
          <dd class="col-7">@Display(Model.BusinessPhone2)</dd>
          <dt class="col-5 text-muted">Cell 1</dt>
          <dd class="col-7">@Display(Model.CellPhone)</dd>
          <dt class="col-5 text-muted">Cell 2</dt>
          <dd class="col-7">@Display(Model.CellPhone2)</dd>
          <dt class="col-5 text-muted">Fax 1</dt>
          <dd class="col-7">@Display(Model.Fax)</dd>
          <dt class="col-5 text-muted">Fax 2</dt>
          <dd class="col-7">@Display(Model.Fax2)</dd>
          <dt class="col-5 text-muted">Address</dt>
          <dd class="col-7">@(string.IsNullOrWhiteSpace(fullAddress) ? "-" : fullAddress)</dd>
          <dt class="col-5 text-muted">Added</dt>
          <dd class="col-7">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
          <dt class="col-5 text-muted">Updated</dt>
          <dd class="col-7">@Model.UpdatedAt.ToString("MMM d, yyyy")</dd>
        </dl>
      </div>
    </div>
    @if (!string.IsNullOrEmpty(Model.Notes))
    {
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-4">
          <h6 class="fw-bold mb-2"><i class="fas fa-sticky-note me-2 text-warning"></i>Notes</h6>
          <p class="text-muted mb-0 small">@Model.Notes</p>
        </div>
      </div>
    }

    @{
      var portalAccess = ViewBag.PortalAccess as IPRO.Business.Interfaces.PackageFeatureAccess;
      var portalDocuments = (ViewBag.PortalDocuments as List<IPRO.Entities.PortalDocument>) ?? new List<IPRO.Entities.PortalDocument>();
    }
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="fas fa-user-shield me-2 text-success"></i>Client Portal</h6>
        @if (portalAccess?.IsIncluded != true)
        {
          <p class="text-muted small mb-0">@portalAccess?.UpgradeMessage</p>
        }
        else if (Model.PortalActivatedAt.HasValue)
        {
          <div class="small text-success mb-2"><i class="fas fa-circle-check me-1"></i>Active since @Model.PortalActivatedAt.Value.ToString("MMM d, yyyy")</div>
          <form asp-action="RevokePortal" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Revoke portal access for @Model.FirstName?">Revoke Access</button>
          </form>
        }
        else if (!string.IsNullOrWhiteSpace(Model.PortalInviteToken))
        {
          var activateUrl = Url.Action("Activate", "ClientPortalAccount", new { token = Model.PortalInviteToken }, Context.Request.Scheme);
          <div class="small text-warning mb-2"><i class="fas fa-clock me-1"></i>Invited, pending activation</div>
          <div class="small text-muted mb-2">Activation link: <a href="@activateUrl" target="_blank">@activateUrl</a></div>
          <form asp-action="InvitePortal" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-success">Resend Invite</button>
          </form>
        }
        else
        {
          <p class="text-muted small">Give @Model.FirstName secure access to message you, view invoices/documents, and request appointments.</p>
          <form asp-action="InvitePortal" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-paper-plane me-1"></i>Invite to Portal</button>
          </form>
        }
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h6 class="fw-bold mb-3"><i class="fas fa-folder me-2 text-primary"></i>Portal Documents</h6>
        @if (!portalDocuments.Any())
        {
          <p class="text-muted small mb-0">No documents shared yet.</p>
        }
        else
        {
          <ul class="list-unstyled small">
            @foreach (var doc in portalDocuments)
            {
              <li class="mb-2 d-flex justify-content-between align-items-center">
                <span><i class="fas fa-file me-1 text-muted"></i>@doc.FileName <span class="text-muted">(@(doc.UploadedByClient ? "Client" : "You"))</span></span>
                <span class="d-flex gap-1">
                  <a class="btn btn-sm btn-outline-secondary" href="/Clients/DownloadPortalDocument/@doc.Id">Download</a>
                  <form asp-action="DeletePortalDocument" asp-route-id="@doc.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Delete @doc.FileName?"><i class="fas fa-trash"></i></button>
                  </form>
                </span>
              </li>
            }
          </ul>
        }
        @if (portalAccess?.IsIncluded == true)
        {
          <form asp-action="UploadPortalDocument" method="post" enctype="multipart/form-data" class="d-flex gap-2 mt-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="clientId" value="@Model.Id" />
            <input type="file" name="file" class="form-control form-control-sm" required />
            <button type="submit" class="btn btn-sm btn-primary">Upload</button>
          </form>
        }
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white border-0 pt-4 px-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h5 class="fw-bold mb-0"><i class="fas fa-calendar-check me-2 text-primary"></i>Follow-ups</h5>
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-light text-muted">@allOpenFollowUps.Count open</span>
            <a href="/Clients/FollowUps/@Model.Id" class="btn btn-sm btn-outline-primary">View all</a>
          </div>
        </div>
      </div>
      <div class="card-body px-4 pb-4">
        <form asp-action="AddFollowUp" method="post" class="row g-2 align-items-end mb-3">
          @Html.AntiForgeryToken()
          <input type="hidden" name="clientId" value="@Model.Id"/>
          <div class="col-lg-5">
            <label class="form-label small fw-semibold text-muted">What to do</label>
            <input type="text" name="title" class="form-control" maxlength="160" placeholder="Call about policy renewal" required/>
          </div>
          <div class="col-lg-3">
            <label class="form-label small fw-semibold text-muted">Due date</label>
            <input type="date" name="dueAt" class="form-control" required/>
          </div>
          <div class="col-lg-3">
            <label class="form-label small fw-semibold text-muted">Notes</label>
            <input type="text" name="notes" class="form-control" maxlength="1000" placeholder="Optional"/>
          </div>
          <div class="col-lg-1 d-grid">
            <button type="submit" class="btn btn-primary" title="Add follow-up"><i class="fas fa-plus"></i></button>
          </div>
        </form>

        @if (openFollowUps.Any())
        {
          <div class="vstack gap-2">
            @foreach (var followUp in openFollowUps)
            {
              <div class="follow-up-item d-flex justify-content-between align-items-start gap-3 border rounded-3 p-3">
                <div>
                  <div class="d-flex align-items-center gap-2 flex-wrap">
                    <strong>@followUp.Title</strong>
                    <span class="badge rounded-pill @DueBadgeClass(followUp.DueAt)">@DueLabel(followUp.DueAt)</span>
                  </div>
                  @if (!string.IsNullOrWhiteSpace(followUp.Notes))
                  {
                    <div class="text-muted small mt-1">@followUp.Notes</div>
                  }
                </div>
                <div class="d-flex gap-1">
                  <form asp-action="CompleteFollowUp" asp-route-id="@followUp.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-success" title="Mark complete"><i class="fas fa-check"></i></button>
                  </form>
                  <form asp-action="DeleteFollowUp" asp-route-id="@followUp.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" data-confirm="Delete this follow-up?"><i class="fas fa-trash"></i></button>
                  </form>
                </div>
              </div>
            }
          </div>
          @if (allOpenFollowUps.Count > openFollowUps.Count)
          {
            <div class="text-end mt-3">
              <a href="/Clients/FollowUps/@Model.Id" class="small fw-semibold text-decoration-none">View @(allOpenFollowUps.Count - openFollowUps.Count) more open follow-ups</a>
            </div>
          }
        }
        else
        {
          <div class="text-muted small py-3">No open follow-ups. Add the next action above.</div>
        }

        @if (completedFollowUps.Any())
        {
          <hr/>
          <h6 class="fw-bold text-muted text-uppercase mb-2" style="font-size:.75rem;letter-spacing:.08em">Recently completed</h6>
          <div class="vstack gap-2">
          @foreach (var followUp in completedFollowUps)
          {
            <div class="small text-muted d-flex justify-content-between border-bottom pb-2">
              <span><i class="fas fa-check-circle text-success me-1"></i>@followUp.Title</span>
              <span>@((followUp.CompletedAt ?? followUp.DueAt).ToString("MMM d, yyyy"))</span>
            </div>
          }
          </div>
        }
        @if (totalFollowUps > openFollowUps.Count + completedFollowUps.Count)
        {
          <div class="text-end mt-3">
            <a href="/Clients/FollowUps/@Model.Id?status=all" class="small fw-semibold text-decoration-none">Open full follow-up history</a>
          </div>
        }
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
          <h5 class="fw-bold mb-0"><i class="fas fa-stream me-2 text-primary"></i>Client Timeline</h5>
          <span class="badge bg-light text-muted">@timeline.Count() events</span>
        </div>
      </div>
      <div class="card-body px-4 pb-2">
        @if (timeline.Any())
        {
          <div class="client-timeline">
          @foreach (var item in timeline)
          {
            <div class="timeline-row d-flex gap-3 pb-3">
              <div class="timeline-marker rounded-circle @item.ColorClass d-flex align-items-center justify-content-center flex-shrink-0">
                <i class="fas @item.Icon"></i>
              </div>
              <div class="timeline-content border-bottom pb-3 flex-grow-1">
                <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
                  <div>
                    <div class="fw-semibold">@item.Title</div>
                    @if (!string.IsNullOrWhiteSpace(item.Details))
                    {
                      <div class="text-muted small mt-1">@item.Details</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(item.Url))
                    {
                      <a href="@item.Url" class="small fw-semibold text-decoration-none">Open related item</a>
                    }
                  </div>
                  <span class="small text-muted">@item.OccurredAt.ToString("MMM d, yyyy h:mm tt")</span>
                </div>
              </div>
            </div>
          }
          </div>
        }
        else
        { <p class="text-muted py-3">No timeline activity yet.</p> }
      </div>
      <div class="card-footer bg-white border-0 px-4 pb-4">
        <div class="mb-4">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="fw-bold mb-0"><i class="fas fa-comments me-2 text-primary"></i>Recent Notes</h6>
            <span class="badge bg-light text-muted">@((comments ?? Enumerable.Empty<IPRO.Entities.ClientComment>()).Count()) total</span>
          </div>
          @if (recentComments.Any())
          {
            <div class="vstack gap-2">
            @foreach (var note in recentComments)
            {
              <div class="client-note rounded-3 border p-3">
                <div class="d-flex justify-content-between gap-2 flex-wrap mb-1">
                  <span class="fw-semibold small text-muted">Note</span>
                  <span class="small text-muted">@note.CreatedAt.ToString("MMM d, yyyy h:mm tt")</span>
                </div>
                <div>@note.Comment</div>
              </div>
            }
            </div>
          }
          else
          {
            <div class="text-muted small border rounded-3 p-3 bg-light">No notes yet. Add the first note below.</div>
          }
        </div>
        <h6 class="fw-bold mb-2"><i class="fas fa-comment me-2 text-secondary"></i>Add note</h6>
        <form asp-action="AddComment" method="post">
          @Html.AntiForgeryToken()
          <input type="hidden" name="clientId" value="@Model.Id"/>
          <div class="d-flex gap-2">
            <input type="text" name="comment" class="form-control" placeholder="Add a note or comment..." required/>
            <button type="submit" class="btn btn-primary px-4"><i class="fas fa-plus"></i></button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .client-details-list dt,
  .client-details-list dd{padding:.25rem 0;word-break:break-word;}
  .client-details-list dd{margin-bottom:0;}
  .follow-up-item{background:#f8fafc;}
  .client-note{background:#f8fafc;}
  .timeline-marker{width:36px;height:36px;font-size:.8rem;}
  .timeline-row:last-child .timeline-content{border-bottom:0!important;}
</style>
