@{
    ViewData["Title"] = "Account Types";
    var accountTypes = (ViewBag.AccountTypes as IEnumerable<IPRO.Entities.ClientCategory>) ?? Enumerable.Empty<IPRO.Entities.ClientCategory>();
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1"><li class="breadcrumb-item"><a href="/Clients">Clients</a></li><li class="breadcrumb-item active">Account Types</li></ol>
    </nav>
    <h2 class="fw-bold mb-0"><i class="fas fa-tags me-2 text-primary"></i>Account Types</h2>
    <small class="text-muted">Create groupings like seminar attendees, life insurance prospects, or mailing groups.</small>
  </div>
  <a href="/Clients/Create" class="btn btn-primary"><i class="fas fa-user-plus me-1"></i>Add Client</a>
</div>

<div class="row g-4">
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h5 class="fw-bold mb-3">New Account Type</h5>
        <form asp-action="CreateAccountType" method="post">
          @Html.AntiForgeryToken()
          <div class="mb-3">
            <label class="form-label fw-semibold">Name</label>
            <input name="name" class="form-control" maxlength="120" placeholder="Met in 2026 Seminar" required/>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Description</label>
            <textarea name="description" class="form-control" rows="3" maxlength="250" placeholder="Optional note for this grouping"></textarea>
          </div>
          <button type="submit" class="btn btn-primary w-100"><i class="fas fa-plus me-1"></i>Add Account Type</button>
        </form>
      </div>
    </div>
  </div>
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pt-4 px-4">
        <h5 class="fw-bold mb-0">Existing Account Types</h5>
      </div>
      <div class="card-body p-4">
        @if (accountTypes.Any())
        {
          <div class="vstack gap-3">
          @foreach (var type in accountTypes)
          {
            <div class="account-type-row border rounded-3 p-3">
              <form asp-action="UpdateAccountType" asp-route-id="@type.Id" method="post" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                  <label class="form-label small fw-semibold text-muted">Name</label>
                  <input name="name" class="form-control" maxlength="120" value="@type.Name" required/>
                </div>
                <div class="col-md-6">
                  <label class="form-label small fw-semibold text-muted">Description</label>
                  <input name="description" class="form-control" maxlength="250" value="@type.Description"/>
                </div>
                <div class="col-md-2 d-grid">
                  <button type="submit" class="btn btn-outline-primary"><i class="fas fa-save me-1"></i>Save</button>
                </div>
              </form>
              <form asp-action="DeleteAccountType" asp-route-id="@type.Id" method="post" class="mt-2 text-end">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-danger" data-confirm="Delete this account type? Existing clients will be ungrouped from it.">
                  <i class="fas fa-trash me-1"></i>Delete
                </button>
              </form>
            </div>
          }
          </div>
        }
        else
        {
          <div class="text-center py-5 text-muted">No account types yet. Add your first grouping.</div>
        }
      </div>
    </div>
  </div>
</div>

<style>
  .account-type-row{background:#f8fafc;}
</style>
