@model IPRO.Entities.Client
@{
    ViewData["Title"] = "Edit Client";
    var accountTypes = (ViewBag.AccountTypes as IEnumerable<IPRO.Entities.ClientCategory>) ?? Enumerable.Empty<IPRO.Entities.ClientCategory>();
    var selectedCategoryIds = (ViewBag.SelectedCategoryIds as HashSet<int>) ?? new HashSet<int>();
}

<div class="row mb-4">
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Clients">Clients</a></li><li class="breadcrumb-item"><a href="/Clients/Details/@Model.Id">@Model.FirstName @Model.LastName</a></li><li class="breadcrumb-item active">Edit</li></ol>
    </nav>
    <h2 class="fw-bold"><i class="fas fa-edit me-2 text-primary"></i>Edit Client</h2>
  </div>
</div>

<div class="row">
<div class="col-lg-8">
<div class="card border-0 shadow-sm">
<div class="card-body p-4">
<form asp-action="Edit" method="post">
  @Html.AntiForgeryToken()
  <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
  <input type="hidden" asp-for="Id"/>
  <input type="hidden" asp-for="AgentUserId"/>
  <input type="hidden" asp-for="CreatedAt"/>

  <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size:.75rem;letter-spacing:.08em">Personal Information</h6>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <label class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
      <input asp-for="FirstName" class="form-control" required/>
      <span asp-validation-for="FirstName" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
      <input asp-for="LastName" class="form-control" required/>
      <span asp-validation-for="LastName" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
      <input asp-for="Email" type="email" class="form-control" required/>
      <span asp-validation-for="Email" class="text-danger small"></span>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold">Email 2</label>
      <input asp-for="Email2" type="email" class="form-control"/>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold">Date of Birth</label>
      <input asp-for="DateOfBirth" type="date" class="form-control"/>
    </div>
    <div class="col-md-6">
      <label class="form-label fw-semibold">Company Name</label>
      <input asp-for="CompanyName" class="form-control"/>
    </div>
  </div>

  <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size:.75rem;letter-spacing:.08em">Contact Information</h6>
  <div class="row g-3 mb-4">
    <div class="col-md-6">
      <label class="form-label fw-semibold">Home Number 1</label>
      <input asp-for="Phone" class="form-control"/>
    </div>
    <div class="col-md-6"><label class="form-label fw-semibold">Home Number 2</label><input asp-for="HomePhone2" class="form-control"/></div>
    <div class="col-md-6"><label class="form-label fw-semibold">Business Number 1</label><input asp-for="BusinessPhone" class="form-control"/></div>
    <div class="col-md-6"><label class="form-label fw-semibold">Business Number 2</label><input asp-for="BusinessPhone2" class="form-control"/></div>
    <div class="col-md-6"><label class="form-label fw-semibold">Cell Number 1</label><input asp-for="CellPhone" class="form-control"/></div>
    <div class="col-md-6"><label class="form-label fw-semibold">Cell Number 2</label><input asp-for="CellPhone2" class="form-control"/></div>
    <div class="col-md-6"><label class="form-label fw-semibold">Fax Number 1</label><input asp-for="Fax" class="form-control"/></div>
    <div class="col-md-6"><label class="form-label fw-semibold">Fax Number 2</label><input asp-for="Fax2" class="form-control"/></div>
  </div>

  <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size:.75rem;letter-spacing:.08em">Address</h6>
  <div class="row g-3 mb-4">
    <div class="col-md-8"><label class="form-label fw-semibold">Street Name</label><input asp-for="Address" class="form-control"/></div>
    <div class="col-md-4"><label class="form-label fw-semibold">Unit #</label><input asp-for="UnitNumber" class="form-control"/></div>
    <div class="col-md-5"><label class="form-label fw-semibold">City</label><input asp-for="City" class="form-control"/></div>
    <div class="col-md-3">
      <label class="form-label fw-semibold">Province</label>
      <select asp-for="Province" class="form-select">
        <option value="">Select...</option>
        <option>AB</option><option>BC</option><option>MB</option><option>NB</option>
        <option>NL</option><option>NS</option><option>ON</option><option>PE</option>
        <option>QC</option><option>SK</option>
      </select>
    </div>
    <div class="col-md-4"><label class="form-label fw-semibold">Postal Code</label><input asp-for="PostalCode" class="form-control"/></div>
    <div class="col-md-4"><label class="form-label fw-semibold">Country</label><input asp-for="Country" class="form-control"/></div>
  </div>

  <h6 class="fw-bold text-muted text-uppercase mb-3" style="font-size:.75rem;letter-spacing:.08em">Preferences</h6>
  <div class="row g-3 mb-4">
    <div class="col-12">
      <div class="form-check form-switch">
        <input asp-for="IsNewsletterSubscribed" class="form-check-input" type="checkbox"/>
        <label class="form-check-label fw-semibold">Newsletter subscribed</label>
      </div>
    </div>
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <label class="form-label fw-semibold mb-0">Account Type</label>
        <a href="/Clients/AccountTypes" class="small fw-semibold text-decoration-none"><i class="fas fa-tags me-1"></i>Manage account types</a>
      </div>
      @if (accountTypes.Any())
      {
        <div class="account-type-grid">
          @foreach (var type in accountTypes)
          {
            <label class="account-type-option">
              <input type="checkbox" name="categoryIds" value="@type.Id" @(selectedCategoryIds.Contains(type.Id) ? "checked" : "")/>
              <span>
                <strong>@type.Name</strong>
                @if (!string.IsNullOrWhiteSpace(type.Description))
                {
                  <small>@type.Description</small>
                }
              </span>
            </label>
          }
        </div>
      }
      else
      {
        <div class="alert alert-light border mb-0">
          No account types yet. <a href="/Clients/AccountTypes">Create account types</a> to group clients.
        </div>
      }
    </div>
    <div class="col-12"><label class="form-label fw-semibold">Notes</label><textarea asp-for="Notes" class="form-control" rows="3"></textarea></div>
  </div>

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary btn-lg px-4"><i class="fas fa-save me-2"></i>Save Changes</button>
    <a href="/Clients/Details/@Model.Id" class="btn btn-outline-secondary btn-lg">Cancel</a>
  </div>
</form>
</div>
</div>
</div>
</div>

<style>
  .account-type-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:.75rem;}
  .account-type-option{display:flex;align-items:flex-start;gap:.65rem;border:1px solid #dbe3ef;border-radius:.75rem;padding:.75rem;background:#f8fafc;cursor:pointer;}
  .account-type-option input{margin-top:.2rem;accent-color:#0d6efd;}
  .account-type-option span{display:flex;flex-direction:column;line-height:1.2;}
  .account-type-option small{color:#64748b;margin-top:.25rem;}
</style>
