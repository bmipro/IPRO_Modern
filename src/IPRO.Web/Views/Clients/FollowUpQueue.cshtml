@model IEnumerable<IPRO.Entities.ClientFollowUp>
@{
    ViewData["Title"] = "Follow-up Queue";
    var status = (ViewBag.Status as string) ?? "open";
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalCount = (int)(ViewBag.TotalCount ?? 0);

    string StatusUrl(string selectedStatus, int selectedPage = 1) => $"/Clients/FollowUps?status={selectedStatus}&page={selectedPage}";
    string ActiveClass(string selectedStatus) => string.Equals(status, selectedStatus, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    string DueBadgeClass(DateTime dueAt) => dueAt.Date < DateTime.Today ? "bg-danger-subtle text-danger" : dueAt.Date == DateTime.Today ? "bg-warning-subtle text-warning" : "bg-primary-subtle text-primary";
    string DueLabel(DateTime dueAt) => dueAt.Date < DateTime.Today ? "Overdue" : dueAt.Date == DateTime.Today ? "Today" : dueAt.ToString("MMM d, yyyy");
    string Heading = status switch
    {
        "overdue" => "Overdue Follow-ups",
        "today" => "Due Today",
        "upcoming" => "Upcoming Follow-ups",
        "completed" => "Completed Follow-ups",
        "all" => "All Follow-ups",
        _ => "Open Follow-ups"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
  <div>
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1">
        <li class="breadcrumb-item"><a href="/Dashboard">Dashboard</a></li>
        <li class="breadcrumb-item"><a href="/Clients">Clients</a></li>
        <li class="breadcrumb-item active">Follow-ups</li>
      </ol>
    </nav>
    <h2 class="fw-bold mb-0"><i class="fas fa-list-check me-2 text-primary"></i>@Heading</h2>
    <small class="text-muted">@totalCount item@(totalCount == 1 ? "" : "s") in this view</small>
  </div>
  <div class="d-flex gap-2">
    <a href="/Clients/Calendar" class="btn btn-outline-primary"><i class="fas fa-calendar-alt me-1"></i>Calendar</a>
    <a href="/Dashboard" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i>Dashboard</a>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body p-3">
    <div class="btn-group flex-wrap" role="group" aria-label="Follow-up filters">
      <a class="btn btn-outline-primary @ActiveClass("open")" href="@StatusUrl("open")">Open</a>
      <a class="btn btn-outline-danger @ActiveClass("overdue")" href="@StatusUrl("overdue")">Overdue</a>
      <a class="btn btn-outline-warning @ActiveClass("today")" href="@StatusUrl("today")">Today</a>
      <a class="btn btn-outline-info @ActiveClass("upcoming")" href="@StatusUrl("upcoming")">Upcoming</a>
      <a class="btn btn-outline-success @ActiveClass("completed")" href="@StatusUrl("completed")">Completed</a>
      <a class="btn btn-outline-secondary @ActiveClass("all")" href="@StatusUrl("all")">All</a>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead>
        <tr>
          <th>Follow-up</th>
          <th>Client</th>
          <th>Due</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
      @foreach (var followUp in Model)
      {
        <tr>
          <td>
            <div class="fw-semibold">@followUp.Title</div>
            @if (!string.IsNullOrWhiteSpace(followUp.Notes))
            {
              <small class="text-muted">@followUp.Notes</small>
            }
          </td>
          <td>
            <a href="/Clients/Details/@followUp.ClientId" class="fw-semibold text-decoration-none">@followUp.Client.FirstName @followUp.Client.LastName</a>
            @if (!string.IsNullOrWhiteSpace(followUp.Client.CompanyName))
            {
              <div class="small text-muted">@followUp.Client.CompanyName</div>
            }
          </td>
          <td><span class="badge rounded-pill @DueBadgeClass(followUp.DueAt)">@DueLabel(followUp.DueAt)</span></td>
          <td>
            @if (followUp.IsCompleted)
            {
              <span class="badge bg-success-subtle text-success rounded-pill">Completed</span>
            }
            else
            {
              <span class="badge bg-light text-muted rounded-pill">Open</span>
            }
          </td>
          <td>
            <div class="d-flex gap-1 justify-content-end">
              <a href="/Clients/FollowUps/@followUp.ClientId" class="btn btn-sm btn-outline-primary" title="Client follow-ups"><i class="fas fa-list"></i></a>
              @if (!followUp.IsCompleted)
              {
                <form asp-action="CompleteFollowUp" asp-route-id="@followUp.Id" method="post">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString"/>
                  <button type="submit" class="btn btn-sm btn-outline-success" title="Mark complete"><i class="fas fa-check"></i></button>
                </form>
              }
              <form asp-action="DeleteFollowUp" asp-route-id="@followUp.Id" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString"/>
                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" data-confirm="Delete this follow-up?"><i class="fas fa-trash"></i></button>
              </form>
            </div>
          </td>
        </tr>
      }
      @if (!Model.Any())
      {
        <tr>
          <td colspan="5" class="text-center py-5 text-muted">
            <i class="fas fa-calendar-check fa-3x d-block mb-3 opacity-25"></i>
            No follow-ups found for this filter.
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>

@if (totalPages > 1)
{
  <nav class="mt-3" aria-label="Follow-up pages">
    <ul class="pagination justify-content-end">
      <li class="page-item @(page <= 1 ? "disabled" : "")">
        <a class="page-link" href="@StatusUrl(status, page - 1)">Previous</a>
      </li>
      @for (var i = 1; i <= totalPages; i++)
      {
        <li class="page-item @(i == page ? "active" : "")">
          <a class="page-link" href="@StatusUrl(status, i)">@i</a>
        </li>
      }
      <li class="page-item @(page >= totalPages ? "disabled" : "")">
        <a class="page-link" href="@StatusUrl(status, page + 1)">Next</a>
      </li>
    </ul>
  </nav>
}
