@model List<IPRO.Entities.PortalAppointmentRequest>
@{
    ViewData["Title"] = "Portal Requests";
    var status = (string)(ViewBag.Status ?? "pending");
    string FilterClass(string value) => status == value ? "btn-primary" : "btn-outline-secondary";
}

<div class="mb-4">
  <h2 class="fw-bold mb-1"><i class="fas fa-calendar-check me-2 text-primary"></i>Portal Requests</h2>
  <div class="text-muted">Appointment requests submitted by clients through your client portal.</div>
</div>

<div class="btn-group mb-3" role="group">
  <a class="btn @FilterClass("pending")" href="/PortalRequests?status=pending">Pending</a>
  <a class="btn @FilterClass("scheduled")" href="/PortalRequests?status=scheduled">Scheduled</a>
  <a class="btn @FilterClass("declined")" href="/PortalRequests?status=declined">Declined</a>
  <a class="btn @FilterClass("all")" href="/PortalRequests?status=all">All</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="list-group list-group-flush">
    @if (!Model.Any())
    {
      <div class="text-center text-muted py-4">No requests here.</div>
    }
    @foreach (var request in Model)
    {
      <div class="list-group-item d-flex justify-content-between align-items-center">
        <div>
          <div class="fw-bold">@request.Client.FirstName @request.Client.LastName</div>
          <div class="small text-muted">@request.Notes</div>
          <div class="small text-muted">
            Requested @request.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")
            @(request.PreferredDate.HasValue ? $"— preferred {request.PreferredDate.Value:MMM d, yyyy}" : "")
          </div>
        </div>
        @if (request.Status == IPRO.Entities.PortalAppointmentRequestStatus.Pending)
        {
          <div class="d-flex gap-2">
            <form asp-action="SetStatus" method="post">
              @Html.AntiForgeryToken()
              <input type="hidden" name="id" value="@request.Id" />
              <input type="hidden" name="status" value="Declined" />
              <button type="submit" class="btn btn-sm btn-outline-danger">Decline</button>
            </form>
            <form asp-action="SetStatus" method="post">
              @Html.AntiForgeryToken()
              <input type="hidden" name="id" value="@request.Id" />
              <input type="hidden" name="status" value="Scheduled" />
              <button type="submit" class="btn btn-sm btn-success">Mark Scheduled</button>
            </form>
          </div>
        }
        else
        {
          <span class="badge @(request.Status == IPRO.Entities.PortalAppointmentRequestStatus.Scheduled ? "bg-success-subtle text-success" : "bg-danger-subtle text-danger")">@request.Status</span>
        }
      </div>
    }
  </div>
</div>
