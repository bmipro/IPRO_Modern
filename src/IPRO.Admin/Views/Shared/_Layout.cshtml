<!DOCTYPE html>
@{
    var adminPortalAccentColor = User.FindFirst("PortalAccentColor")?.Value ?? "";
    var adminEffectiveAccent = string.IsNullOrEmpty(adminPortalAccentColor) ? "#1457d9" : adminPortalAccentColor;
    var adminColorSwatches = new (string Hex, string Name)[]
    {
        ("#1457d9", "Ocean Blue"),
        ("#d9541f", "Sunset Orange"),
        ("#1f7a4d", "Forest Green"),
        ("#4b5563", "Slate Gray"),
        ("#7a1f3d", "Burgundy"),
        ("#5b2f9e", "Royal Purple")
    };
}
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] — IPRO Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <style>
        :root { --portal-accent: @adminEffectiveAccent; }

        /* Mirrors the agent portal's accent theming: every semantic Bootstrap color maps to the
           admin's chosen accent so the whole app feels personalized. Alerts are excluded since
           they're transient system feedback, not persistent brand chrome. */
        .btn-primary, .btn-success, .btn-danger, .btn-warning, .btn-info {
            --bs-btn-color:#fff; --bs-btn-bg:var(--portal-accent); --bs-btn-border-color:var(--portal-accent);
            --bs-btn-hover-color:#fff; --bs-btn-hover-bg:color-mix(in srgb, var(--portal-accent) 85%, black); --bs-btn-hover-border-color:color-mix(in srgb, var(--portal-accent) 80%, black);
            --bs-btn-active-color:#fff; --bs-btn-active-bg:color-mix(in srgb, var(--portal-accent) 80%, black); --bs-btn-active-border-color:color-mix(in srgb, var(--portal-accent) 75%, black);
            --bs-btn-disabled-bg:var(--portal-accent); --bs-btn-disabled-border-color:var(--portal-accent);
        }
        .btn-outline-primary, .btn-outline-success, .btn-outline-danger, .btn-outline-warning, .btn-outline-info {
            --bs-btn-color:var(--portal-accent); --bs-btn-border-color:var(--portal-accent);
            --bs-btn-hover-color:#fff; --bs-btn-hover-bg:var(--portal-accent); --bs-btn-hover-border-color:var(--portal-accent);
            --bs-btn-active-color:#fff; --bs-btn-active-bg:var(--portal-accent); --bs-btn-active-border-color:var(--portal-accent);
            --bs-btn-disabled-color:var(--portal-accent); --bs-btn-disabled-border-color:var(--portal-accent);
        }
        .text-primary, .text-success, .text-danger, .text-warning, .text-info { color:var(--portal-accent) !important; }
        .bg-primary, .bg-success, .bg-danger, .bg-warning, .bg-info { background-color:var(--portal-accent) !important; }
        .border-primary, .border-success, .border-danger, .border-warning, .border-info { border-color:var(--portal-accent) !important; }
        .bg-primary-subtle, .bg-success-subtle, .bg-danger-subtle, .bg-warning-subtle, .bg-info-subtle {
            background-color:color-mix(in srgb, var(--portal-accent) 15%, white) !important;
        }
        .text-primary-emphasis, .text-success-emphasis, .text-danger-emphasis, .text-warning-emphasis, .text-info-emphasis {
            color:color-mix(in srgb, var(--portal-accent) 70%, black) !important;
        }
        .form-control:focus, .form-select:focus {
            border-color:var(--portal-accent);
            box-shadow:0 0 0 0.25rem color-mix(in srgb, var(--portal-accent) 25%, transparent);
        }
        .form-check-input:focus { border-color:var(--portal-accent); box-shadow:0 0 0 0.25rem color-mix(in srgb, var(--portal-accent) 25%, transparent); }
        .form-check-input:checked { background-color:var(--portal-accent); border-color:var(--portal-accent); }
        a:not(.btn):not(.nav-link):not(.dropdown-item):not(.page-link) { color:var(--portal-accent); }
        a:not(.btn):not(.nav-link):not(.dropdown-item):not(.page-link):hover { color:color-mix(in srgb, var(--portal-accent) 85%, black); }
        .page-link { color:var(--portal-accent); }
        .page-item.active .page-link { background-color:var(--portal-accent); border-color:var(--portal-accent); }
        .dropdown-item.active, .dropdown-item:active { background-color:var(--portal-accent) !important; }

        body { background:#f1f5f9; font-family:'Segoe UI',system-ui,sans-serif; }
        .admin-sidebar { width:250px; height:100vh; background:linear-gradient(180deg,#0f172a 0%,#1e3a5f 100%); position:fixed; top:0; left:0; z-index:100; display:flex; flex-direction:column; }
        .admin-sidebar .brand { flex-shrink:0; padding:1.5rem 1.25rem; border-bottom:1px solid rgba(255,255,255,0.1); }
        .admin-sidebar .brand h5 { color:#fff; font-weight:700; margin:0; }
        .admin-sidebar .brand small { color:rgba(255,255,255,0.5); font-size:.75rem; }
        .admin-sidebar-nav { flex:1 1 auto; min-height:0; overflow-y:auto; }
        .admin-sidebar-nav::-webkit-scrollbar { width:6px; }
        .admin-sidebar-nav::-webkit-scrollbar-thumb { background:rgba(255,255,255,0.15); border-radius:3px; }
        .admin-sidebar-footer { flex-shrink:0; border-top:1px solid rgba(255,255,255,0.1); padding:.5rem 0; }
        .admin-sidebar .nav-link { color:rgba(255,255,255,0.7); padding:.65rem 1.25rem; border-radius:8px; margin:.1rem .75rem; transition:all .15s; }
        .admin-sidebar .nav-link:hover { background:color-mix(in srgb, var(--portal-accent) 25%, transparent); color:#fff; }
        .admin-sidebar .nav-link.active { background:var(--portal-accent); color:#fff; }
        .admin-sidebar .nav-link i { width:20px; margin-right:.6rem; }
        .admin-sidebar .nav-section { color:rgba(255,255,255,0.35); font-size:.7rem; font-weight:600; text-transform:uppercase; letter-spacing:.08em; padding:.75rem 1.25rem .25rem; }
        .portal-color-row { display:flex; gap:.4rem; padding:.25rem 1.25rem .75rem; }
        .portal-color-swatch { width:20px; height:20px; border-radius:50%; border:2px solid transparent; padding:0; cursor:pointer; }
        .portal-color-swatch.is-active { border-color:#fff; box-shadow:0 0 0 2px var(--portal-accent); }
        .admin-topbar { margin-left:250px; background:#fff; border-bottom:1px solid #e5e7eb; padding:.75rem 1.5rem; display:flex; justify-content:space-between; align-items:center; position:sticky; top:0; z-index:99; }
        .admin-content { margin-left:250px; padding:1.5rem; }
        .stat-card { border:none; border-radius:14px; box-shadow:0 2px 8px rgba(0,0,0,0.07); }
        .stat-card .icon-box { width:52px; height:52px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.4rem; }
        .table th { font-weight:600; font-size:.8rem; text-transform:uppercase; letter-spacing:.05em; color:#6b7280; background:#f9fafb; border-top:none; }
        .badge-status-active   { background:#dcfce7; color:#16a34a; }
        .badge-status-inactive { background:#fee2e2; color:#dc2626; }
        .badge-status-pending  { background:#fef9c3; color:#ca8a04; }
    </style>
</head>
<body>

<!-- Sidebar -->
<aside class="admin-sidebar">
    <div class="brand">
        <h5><i class="fas fa-shield-alt me-2 text-warning"></i>IPRO Admin</h5>
        <small>Super Admin Panel</small>
    </div>
    <nav class="admin-sidebar-nav mt-2 pb-2">
        <div class="nav-section">Overview</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminDashboard" ? "active" : "")" href="/AdminDashboard">
            <i class="fas fa-chart-line"></i>Dashboard
        </a>
        <div class="nav-section">Agents</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Agents" ? "active" : "")" href="/Agents">
            <i class="fas fa-users"></i>All Agents
        </a>
        <div class="nav-section">Websites</div>
        @if (User.HasClaim("Role", IPRO.Entities.AdminRoles.SuperAdmin))
        {
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WebsiteTemplates" ? "active" : "")" href="/WebsiteTemplates">
              <i class="fas fa-layer-group"></i>Templates
          </a>
        }
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "StarterContent" ? "active" : "")" href="/StarterContent">
            <i class="fas fa-wand-magic-sparkles"></i>Starter Content
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Domains" ? "active" : "")" href="/Domains">
            <i class="fas fa-network-wired"></i>Domains
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "WebsiteLeads" ? "active" : "")" href="/WebsiteLeads">
            <i class="fas fa-inbox"></i>Website Leads
        </a>
        <div class="nav-section">Support</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SupportTickets" ? "active" : "")" href="/SupportTickets">
            <i class="fas fa-headset"></i>Support Tickets
        </a>
        <div class="nav-section">Newsletters</div>
        @if (User.HasClaim("Role", IPRO.Entities.AdminRoles.SuperAdmin))
        {
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "NewsletterTemplates" ? "active" : "")" href="/NewsletterTemplates">
              <i class="fas fa-envelope-open-text"></i>Newsletter Templates
          </a>
        }
        @if (User.HasClaim("Role", IPRO.Entities.AdminRoles.SuperAdmin))
        {
          <div class="nav-section">Billing</div>
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Packages" ? "active" : "")" href="/Packages">
              <i class="fas fa-box"></i>Packages
          </a>
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "TaxRates" ? "active" : "")" href="/TaxRates">
              <i class="fas fa-percent"></i>Tax Rates
          </a>
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PayPalSetup" ? "active" : "")" href="/PayPalSetup">
              <i class="fab fa-paypal"></i>PayPal Setup
          </a>
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "PromotionCodes" ? "active" : "")" href="/PromotionCodes">
              <i class="fas fa-tags"></i>Promotion Codes
          </a>
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "EmailSetup" ? "active" : "")" href="/EmailSetup">
              <i class="fas fa-envelope-circle-check"></i>Email Setup
          </a>
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AiUsage" ? "active" : "")" href="/AiUsage">
              <i class="fas fa-robot"></i>AI Usage
          </a>
        }
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Revenue" ? "active" : "")" href="/Reports/Revenue">
            <i class="fas fa-dollar-sign"></i>Revenue
        </a>
        <div class="nav-section">Reports</div>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Agents" ? "active" : "")" href="/Reports/Agents">
            <i class="fas fa-chart-column"></i>Agent Stats
        </a>
        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" && ViewContext.RouteData.Values["action"]?.ToString() == "Subscriptions" ? "active" : "")" href="/Reports/Subscriptions">
            <i class="fas fa-credit-card"></i>Subscriptions
        </a>
    </nav>
    <div class="admin-sidebar-footer">
        <div class="portal-color-row">
            @foreach (var swatch in adminColorSwatches)
            {
                <form asp-controller="Admin" asp-action="SetPortalAccentColor" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="color" value="@swatch.Hex" />
                    <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                    <button type="submit" class="portal-color-swatch @(adminPortalAccentColor == swatch.Hex ? "is-active" : "")" style="background-color:@swatch.Hex;" title="@swatch.Name" aria-label="@swatch.Name"></button>
                </form>
            }
        </div>
        <div class="nav-section">System</div>
        @if (User.HasClaim("Role", IPRO.Entities.AdminRoles.SuperAdmin))
        {
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUsers" && ViewContext.RouteData.Values["action"]?.ToString() != "AuditLog" ? "active" : "")" href="/AdminUsers">
              <i class="fas fa-user-shield"></i>Admin Users
          </a>
          <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AdminUsers" && ViewContext.RouteData.Values["action"]?.ToString() == "AuditLog" ? "active" : "")" href="/AdminUsers/AuditLog">
              <i class="fas fa-scroll"></i>Audit Log
          </a>
        }
        <a class="nav-link" href="/hangfire" target="_blank">
            <i class="fas fa-cogs"></i>Job Scheduler
        </a>
        <a class="nav-link text-danger" href="/Admin/Logout">
            <i class="fas fa-sign-out-alt"></i>Logout
        </a>
    </div>
</aside>

<!-- Top Bar -->
<div class="admin-topbar">
    <div class="fw-semibold text-muted">@ViewData["Title"]</div>
    <div class="d-flex align-items-center gap-3">
        <span class="text-muted small"><i class="fas fa-clock me-1"></i>@DateTime.Now.ToString("MMM d, yyyy h:mm tt")</span>
        <span class="badge bg-danger">Super Admin</span>
    </div>
</div>

<!-- Main Content -->
<main class="admin-content">
    @if (TempData["Success"] != null)
    { <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Warning"] != null)
    { <div class="alert alert-warning alert-dismissible fade show border-0 shadow-sm"><i class="fas fa-exclamation-triangle me-2"></i>@TempData["Warning"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Error"] != null)
    { <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm"><i class="fas fa-times-circle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div> }
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
