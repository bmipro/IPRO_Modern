@using IPRO.Utility
@model PagedResult<IPRO.Entities.AgentUser>
@{ ViewData["Title"] = "Agents"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="fas fa-users me-2 text-primary"></i>Agents <span class="text-muted fs-6 fw-normal">(@ViewBag.TotalCount total)</span></h4>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name, email or username..."/>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">All Status</option>
                    <option value="active" selected="@(ViewBag.Status == "active")">Active</option>
                    <option value="inactive" selected="@(ViewBag.Status == "inactive")">Inactive</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search me-1"></i>Search</button>
                <a href="/Agents" class="btn btn-outline-secondary"><i class="fas fa-times"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>Agent</th>
                    <th>Company</th>
                    <th>Domain</th>
                    <th>Package</th>
                    <th>Joined</th>
                    <th>Last Login</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var a in Model.Items)
            {
                <tr>
                    <td>
                        <div class="fw-semibold">@a.FirstName @a.LastName</div>
                        <small class="text-muted">@a.UserName - @a.Email</small>
                    </td>
                    <td>
                        <div class="small fw-semibold">@(string.IsNullOrWhiteSpace(a.CompanyName) ? "-" : a.CompanyName)</div>
                        <small class="text-muted">@(string.IsNullOrWhiteSpace(a.City) ? "" : a.City)@(string.IsNullOrWhiteSpace(a.Province) ? "" : $", {a.Province}")</small>
                    </td>
                    <td><small class="text-primary">@(string.IsNullOrWhiteSpace(a.DomainName) ? "-" : a.DomainName)</small></td>
                    <td><span class="badge bg-light text-dark">Package @a.PackageId</span></td>
                    <td><small>@a.CreatedAt.ToString("MMM d, yyyy")</small></td>
                    <td><small class="text-muted">@(a.LastLoginAt.HasValue ? a.LastLoginAt.Value.ToString("MMM d") : "Never")</small></td>
                    <td>
                        @if (a.IsActive)
                        { <span class="badge badge-status-active rounded-pill px-3">Active</span> }
                        else
                        { <span class="badge badge-status-inactive rounded-pill px-3">Inactive</span> }
                    </td>
                    <td><a href="/Agents/Details/@a.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                </tr>
            }
            @if (!Model.Items.Any())
            { <tr><td colspan="8" class="text-center text-muted py-5"><i class="fas fa-search fa-2x d-block mb-2 opacity-25"></i>No agents found</td></tr> }
            </tbody>
        </table>
    </div>
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <small class="text-muted">Page @Model.Page of @Model.TotalPages</small>
            <nav><ul class="pagination pagination-sm mb-0">
                @if (Model.HasPrevious)
                { <li class="page-item"><a class="page-link" href="?page=@(Model.Page-1)&search=@ViewBag.Search&status=@ViewBag.Status">&lt;</a></li> }
                @if (Model.HasNext)
                { <li class="page-item"><a class="page-link" href="?page=@(Model.Page+1)&search=@ViewBag.Search&status=@ViewBag.Status">&gt;</a></li> }
            </ul></nav>
        </div>
    }
</div>
