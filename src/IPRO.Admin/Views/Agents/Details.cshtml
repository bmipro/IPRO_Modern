@model IPRO.Entities.AgentUser
@{ ViewData["Title"] = $"Agent: {Model.UserName}"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb"><ol class="breadcrumb mb-1"><li class="breadcrumb-item"><a href="/Agents">Agents</a></li><li class="breadcrumb-item active">@Model.UserName</li></ol></nav>
        <h4 class="fw-bold mb-0">@Model.FirstName @Model.LastName
            @if (Model.IsActive) { <span class="badge badge-status-active ms-2">Active</span> }
            else { <span class="badge badge-status-inactive ms-2">Inactive</span> }
        </h4>
    </div>
    <div class="d-flex gap-2">
        <a href="/Agents/Edit/@Model.Id" class="btn btn-primary"><i class="fas fa-pen me-1"></i>Edit</a>
        <form asp-action="ResetPassword" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-dark" onclick="return confirm('Reset @Model.UserName password to their last name and force password change?')"><i class="fas fa-key me-1"></i>Reset Password</button>
        </form>
        @if (Model.IsActive)
        {
            <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-warning" onclick="return confirm('Deactivate this agent?')"><i class="fas fa-ban me-1"></i>Deactivate</button>
            </form>
        }
        else
        {
            <form asp-action="Activate" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success"><i class="fas fa-check me-1"></i>Activate</button>
            </form>
        }
        <form asp-action="ProvisionHosting" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary" onclick="return confirm('Provision Plesk hosting for this agent?')"><i class="fas fa-server me-1"></i>Provision Hosting</button>
        </form>
        <form asp-action="PleskLogin" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary"><i class="fas fa-external-link-alt me-1"></i>Plesk Login</button>
        </form>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Delete @Model.UserName permanently? This cannot be undone.')"><i class="fas fa-trash me-1"></i>Delete</button>
        </form>
    </div>
</div>

@{
    var detailsWarnings = ViewBag.DetailsWarnings as IEnumerable<string> ?? Enumerable.Empty<string>();
    var billings = (ViewBag.Billings as IEnumerable<IPRO.Entities.Billing> ?? Enumerable.Empty<IPRO.Entities.Billing>()).ToList();
    var subscriptionChanges = (ViewBag.SubscriptionChanges as IEnumerable<IPRO.Entities.SubscriptionChange> ?? Enumerable.Empty<IPRO.Entities.SubscriptionChange>()).ToList();
    var packageLookup = ViewBag.PackageLookup as IDictionary<int, IPRO.Entities.BillingRule> ?? new Dictionary<int, IPRO.Entities.BillingRule>();
}
@if (detailsWarnings.Any())
{
    <div class="alert alert-warning border-0 shadow-sm">
        <div class="fw-semibold mb-1"><i class="fas fa-triangle-exclamation me-1"></i>Some related data could not be loaded.</div>
        @foreach (var warning in detailsWarnings)
        {
            <div class="small">@warning</div>
        }
    </div>
}

<div class="row g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3 text-muted text-uppercase" style="font-size:.75rem;letter-spacing:.08em">Profile</h6>
                <dl class="row mb-0" style="font-size:.9rem">
                    <dt class="col-5 text-muted">Username</dt><dd class="col-7">@Model.UserName</dd>
                    <dt class="col-5 text-muted">Email</dt><dd class="col-7">@Model.Email</dd>
                    <dt class="col-5 text-muted">Name</dt><dd class="col-7">@Model.FirstName @Model.LastName</dd>
                    <dt class="col-5 text-muted">Designation</dt><dd class="col-7">@(string.IsNullOrWhiteSpace(Model.Designation) ? "-" : Model.Designation)</dd>
                    <dt class="col-5 text-muted">Domain</dt><dd class="col-7"><span class="text-primary">@(string.IsNullOrWhiteSpace(Model.DomainName) ? "-" : Model.DomainName)</span></dd>
                    <dt class="col-5 text-muted">Package</dt><dd class="col-7">Package @Model.PackageId</dd>
                    <dt class="col-5 text-muted">Password Change</dt><dd class="col-7">@(Model.MustChangePassword ? "Required" : "Not required")</dd>
                    <dt class="col-5 text-muted">Promotion</dt><dd class="col-7">@(string.IsNullOrWhiteSpace(Model.PromotionCode) ? "-" : Model.PromotionCode)</dd>
                    <dt class="col-5 text-muted">Joined</dt><dd class="col-7">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                    <dt class="col-5 text-muted">Last Login</dt><dd class="col-7">@(Model.LastLoginAt.HasValue ? Model.LastLoginAt.Value.ToString("MMM d, yyyy") : "Never")</dd>
                </dl>
            </div>
        </div>
        <div class="row g-2">
            <div class="col-6"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-3 fw-bold text-info">@ViewBag.ClientCount</div><div class="text-muted small">Clients</div></div></div>
            <div class="col-6"><div class="card border-0 shadow-sm text-center p-3"><div class="fs-3 fw-bold @(ViewBag.Subscription != null ? "text-success" : "text-danger")"><i class="fas @(ViewBag.Subscription != null ? "fa-check-circle" : "fa-times-circle")"></i></div><div class="text-muted small">Subscription</div></div></div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                @{
                    var activeBilling = ViewBag.Subscription as IPRO.Entities.Billing;
                    var activePackage = activeBilling != null && packageLookup.TryGetValue(activeBilling.BillingRuleId, out var activePkg) ? activePkg : null;
                    var recentInvoicesForFailures = ViewBag.Invoices as IEnumerable<IPRO.Entities.Invoice> ?? Enumerable.Empty<IPRO.Entities.Invoice>();
                    var failedPayments = recentInvoicesForFailures
                        .Where(i => !i.IsPaid && (i.Billing?.Status == IPRO.Entities.BillingStatus.Failed || i.PayPalTransactionId.StartsWith("PAYPAL_FAILED:", StringComparison.OrdinalIgnoreCase)))
                        .ToList();
                }
                <h6 class="fw-bold mb-3"><i class="fas fa-credit-card me-2 text-primary"></i>Billing Status</h6>
                @if (activeBilling != null)
                {
                    <div class="alert alert-success border-0">
                        <div class="fw-bold">Current package: @(activePackage?.PackageName ?? $"Package {activeBilling.BillingRuleId}")</div>
                        <div class="small">Next billing: @(activeBilling.NextBillingDate?.ToString("MMM d, yyyy") ?? "-") - $@activeBilling.Amount.ToString("N2") @activeBilling.Currency / @activeBilling.Period</div>
                        @if (!string.IsNullOrWhiteSpace(activeBilling.PayPalSubscriptionId))
                        {
                            <div class="small font-monospace mt-1">PayPal subscription: @activeBilling.PayPalSubscriptionId</div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning border-0">No active subscription.</div>
                }
                @if (failedPayments.Any())
                {
                    <div class="alert alert-danger border-0">
                        <div class="fw-bold mb-1">Failed payment attention needed</div>
                        @foreach (var failed in failedPayments.Take(3))
                        {
                            <div class="small">@failed.InvoiceNumber - $@failed.Total.ToString("N2") @failed.Currency - @failed.IssuedAt.ToString("MMM d, yyyy")</div>
                        }
                    </div>
                }
                <h6 class="fw-bold mb-3"><i class="fas fa-address-card me-2 text-primary"></i>Registration Details</h6>
                <dl class="row mb-0" style="font-size:.9rem">
                    <dt class="col-md-3 text-muted">Company</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.CompanyName) ? "-" : Model.CompanyName)</dd>
                    <dt class="col-md-3 text-muted">Address</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.CompanyAddress) ? "-" : Model.CompanyAddress)</dd>
                    <dt class="col-md-3 text-muted">City</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.City) ? "-" : Model.City)</dd>
                    <dt class="col-md-3 text-muted">Province/State</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.Province) ? "-" : Model.Province)</dd>
                    <dt class="col-md-3 text-muted">Postal Code</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.PostalCode) ? "-" : Model.PostalCode)</dd>
                    <dt class="col-md-3 text-muted">Country</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.Country) ? "-" : Model.Country)</dd>
                    <dt class="col-md-3 text-muted">Time Zone</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.TimeZone) ? "-" : Model.TimeZone)</dd>
                    <dt class="col-md-3 text-muted">Business Type</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.BusinessType) ? "-" : Model.BusinessType)</dd>
                    <dt class="col-md-3 text-muted">Business Phone</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</dd>
                    <dt class="col-md-3 text-muted">Fax</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.BusinessFax) ? "-" : Model.BusinessFax)</dd>
                    <dt class="col-md-3 text-muted">Mobile Phone</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.CellPhone) ? "-" : Model.CellPhone)</dd>
                    <dt class="col-md-3 text-muted">Terms Accepted</dt><dd class="col-md-9">@(Model.TermsAcceptedAt.HasValue ? Model.TermsAcceptedAt.Value.ToString("MMM d, yyyy h:mm tt") : "-")</dd>
                    <dt class="col-md-3 text-muted">Registration IP</dt><dd class="col-md-9">@(string.IsNullOrWhiteSpace(Model.RegistrationIpAddress) ? "-" : Model.RegistrationIpAddress)</dd>
                </dl>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-receipt me-2 text-success"></i>Invoices</h6>
                @{ var invoices = ViewBag.Invoices as IEnumerable<IPRO.Entities.Invoice>; }
                @if (invoices != null && invoices.Any())
                {
                    <table class="table table-sm align-middle mb-0">
                        <thead><tr><th>Invoice #</th><th>Date</th><th>Amount</th><th>Status</th><th>PayPal</th></tr></thead>
                        <tbody>
                        @foreach (var inv in invoices)
                        {
                            <tr>
                                <td class="small">@inv.InvoiceNumber</td>
                                <td class="small text-muted">@inv.IssuedAt.ToString("MMM d, yyyy")</td>
                                <td class="fw-semibold text-success">$@inv.Total.ToString("N2")</td>
                                <td><span class="badge @(inv.IsPaid ? "bg-success" : inv.Billing?.Status == IPRO.Entities.BillingStatus.Failed ? "bg-danger" : "bg-warning text-dark")">@(inv.IsPaid ? "Paid" : inv.Billing?.Status == IPRO.Entities.BillingStatus.Failed ? "Failed" : "Unpaid")</span></td>
                                <td class="small font-monospace text-muted">@(string.IsNullOrWhiteSpace(inv.PayPalTransactionId) ? "-" : inv.PayPalTransactionId)</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                }
                else { <p class="text-muted mb-0">No invoices yet.</p> }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-rotate me-2 text-info"></i>Subscription History</h6>
                @if (billings.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Package</th><th>Status</th><th>Period</th><th>Amount</th><th>Started</th><th>Next/Cancelled</th><th>PayPal Subscription</th></tr></thead>
                            <tbody>
                            @foreach (var billing in billings)
                            {
                                var packageName = packageLookup.TryGetValue(billing.BillingRuleId, out var pkg) ? pkg.PackageName : $"Package {billing.BillingRuleId}";
                                <tr>
                                    <td class="fw-semibold">@packageName</td>
                                    <td><span class="badge @(billing.Status == IPRO.Entities.BillingStatus.Active ? "bg-success" : billing.Status == IPRO.Entities.BillingStatus.Pending ? "bg-warning text-dark" : billing.Status == IPRO.Entities.BillingStatus.Failed ? "bg-danger" : "bg-secondary")">@billing.Status</span></td>
                                    <td>@billing.Period</td>
                                    <td>$@billing.Amount.ToString("N2") @billing.Currency</td>
                                    <td class="small">@billing.StartDate.ToString("MMM d, yyyy")</td>
                                    <td class="small text-muted">@(billing.CancelledAt?.ToString("MMM d, yyyy") ?? billing.NextBillingDate?.ToString("MMM d, yyyy") ?? "-")</td>
                                    <td class="small font-monospace text-muted">@(string.IsNullOrWhiteSpace(billing.PayPalSubscriptionId) ? "-" : billing.PayPalSubscriptionId)</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else { <p class="text-muted mb-0">No billing history yet.</p> }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-clock-rotate-left me-2 text-warning"></i>Retry / Change History</h6>
                @if (subscriptionChanges.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Type</th><th>Status</th><th>Requested Package</th><th>Amount Due</th><th>Effective</th><th>Created</th></tr></thead>
                            <tbody>
                            @foreach (var change in subscriptionChanges)
                            {
                                var requestedName = packageLookup.TryGetValue(change.RequestedBillingRuleId, out var pkg) ? pkg.PackageName : $"Package {change.RequestedBillingRuleId}";
                                <tr>
                                    <td>@change.ChangeType</td>
                                    <td><span class="badge @(change.Status == IPRO.Entities.SubscriptionChangeStatus.Applied ? "bg-success" : change.Status == IPRO.Entities.SubscriptionChangeStatus.Pending ? "bg-warning text-dark" : "bg-secondary")">@change.Status</span></td>
                                    <td>@requestedName</td>
                                    <td>$@change.AmountDue.ToString("N2") @change.Currency</td>
                                    <td class="small">@change.EffectiveDate.ToString("MMM d, yyyy")</td>
                                    <td class="small text-muted">@change.CreatedAt.ToString("MMM d, yyyy h:mm tt")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
                else { <p class="text-muted mb-0">No subscription changes or retries yet.</p> }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-history me-2 text-secondary"></i>Activity Log</h6>
                @{ var logs = ViewBag.Logs as IEnumerable<IPRO.Entities.OperateLog>; }
                @if (logs != null && logs.Any())
                {
                    <div style="max-height:250px;overflow-y:auto;">
                    @foreach (var log in logs)
                    {
                        <div class="d-flex gap-3 py-2 border-bottom">
                            <div class="text-muted" style="font-size:.75rem;white-space:nowrap;min-width:80px;">@log.CreatedAt.ToString("MMM d HH:mm")</div>
                            <div>
                                <span class="badge bg-light text-dark me-1">@log.Module</span>
                                <span style="font-size:.85rem">@log.Description</span>
                            </div>
                        </div>
                    }
                    </div>
                }
                else { <p class="text-muted mb-0">No activity logged.</p> }
            </div>
        </div>
    </div>
</div>
