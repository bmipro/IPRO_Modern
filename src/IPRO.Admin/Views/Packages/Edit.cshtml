@model IPRO.Admin.Models.PackageEditViewModel
@{
  ViewData["Title"] = "Edit Package";
  var websiteTemplates = ViewBag.WebsiteTemplates as IEnumerable<IPRO.Entities.WebsiteTemplate> ?? Enumerable.Empty<IPRO.Entities.WebsiteTemplate>();
}

<div class="mb-4">
  <nav aria-label="breadcrumb"><ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Packages">Packages</a></li><li class="breadcrumb-item active">Edit</li></ol></nav>
  <h4 class="fw-bold">Edit Package: @Model.PackageName</h4>
</div>

<div class="row"><div class="col-12">
<div class="card border-0 shadow-sm">
<div class="card-body p-4">
<form asp-action="Edit" method="post">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="Id"/>
  <div asp-validation-summary="All" class="text-danger mb-3"></div>
  <div class="row g-3 mb-3">
    <div class="col-lg-6"><label class="form-label fw-semibold">Package Name <span class="text-danger">*</span></label><input asp-for="PackageName" class="form-control" required/></div>
    <div class="col-lg-6"><label class="form-label fw-semibold">Description</label><input asp-for="Description" class="form-control"/></div>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-md-4"><label class="form-label fw-semibold">Monthly Recurring ($)</label><input asp-for="MonthlyPrice" type="number" step="0.01" class="form-control" required/></div>
    <div class="col-md-4"><label class="form-label fw-semibold">Annual Recurring ($)</label><input asp-for="AnnualPrice" type="number" step="0.01" class="form-control"/></div>
    <div class="col-md-4"><label class="form-label fw-semibold">One-time Setup Fee ($)</label><input asp-for="SetupFee" type="number" step="0.01" class="form-control"/></div>
  </div>
  <input type="hidden" asp-for="QuarterlyPrice" value="0"/>
  <input type="hidden" asp-for="MaxClients"/>
  <div class="row g-3 mb-3">
    <div class="col-md-6"><label class="form-label fw-semibold">Max Newsletters/year</label><input asp-for="MaxNewsletters" type="number" class="form-control" placeholder="blank if not limited"/></div>
    <div class="col-md-6">
      <label class="form-label fw-semibold">Default Website Template</label>
      <select asp-for="DefaultWebsiteTemplateId" class="form-select">
        <option value="">Use global default template</option>
        @foreach (var template in websiteTemplates)
        {
          <option value="@template.Id">@template.Name@(template.IsDefault ? " (global default)" : "")</option>
        }
      </select>
      <div class="form-text">New agent websites on this package will start with this template.</div>
    </div>
  </div>
  <div class="row g-3 mb-3">
    <div class="col-md-6"><label class="form-label fw-semibold">PayPal Monthly Plan ID</label><input asp-for="PayPalMonthlyPlanId" class="form-control"/></div>
    <div class="col-md-6"><label class="form-label fw-semibold">PayPal Annual Plan ID</label><input asp-for="PayPalAnnualPlanId" class="form-control"/></div>
  </div>
  <div class="alert alert-light border d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
      <div class="fw-bold mb-1"><i class="fab fa-paypal me-2 text-primary"></i>PayPal recurring plans</div>
      <div class="small text-muted">Save package price changes first, then sync. Sync creates new PayPal plans and stores the returned plan IDs for future subscribers.</div>
      <div class="small mt-2">
        <span class="badge @(string.IsNullOrWhiteSpace(Model.PayPalMonthlyPlanId) ? "bg-secondary" : "bg-success") me-1">
          Monthly @(string.IsNullOrWhiteSpace(Model.PayPalMonthlyPlanId) ? "missing" : "connected")
        </span>
        <span class="badge @(string.IsNullOrWhiteSpace(Model.PayPalAnnualPlanId) ? "bg-secondary" : "bg-success")">
          Annual @(string.IsNullOrWhiteSpace(Model.PayPalAnnualPlanId) ? "missing" : "connected")
        </span>
      </div>
    </div>
    <button type="submit" form="sync-paypal-plans-form" class="btn btn-outline-primary">
      <i class="fas fa-sync-alt me-1"></i>Create / Replace PayPal Plans
    </button>
  </div>
  <div class="form-check form-switch mb-4">
    <input asp-for="IsActive" class="form-check-input" type="checkbox"/>
    <label asp-for="IsActive" class="form-check-label fw-semibold">Package is active</label>
  </div>

  @await Html.PartialAsync("_PackageFeaturesEditor", Model.Features)

  <div class="d-flex gap-2">
    <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i>Save Changes</button>
    <a href="/Packages" class="btn btn-outline-secondary">Cancel</a>
  </div>
</form>
<form id="sync-paypal-plans-form" asp-action="SyncPayPalPlans" asp-route-id="@Model.Id" method="post">
  @Html.AntiForgeryToken()
</form>
</div></div>
</div></div>
