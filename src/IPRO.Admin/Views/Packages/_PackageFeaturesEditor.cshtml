@model List<IPRO.Admin.Models.PackageFeatureEditViewModel>

<div class="border rounded-3 mb-4">
  <div class="d-flex justify-content-between align-items-center px-3 py-3 border-bottom bg-light">
    <div>
      <h5 class="mb-1 fw-bold">Package Functions</h5>
      <div class="text-muted small">Check a function to include it in this package. Use -1 for unlimited numeric limits.</div>
    </div>
    <span class="badge bg-primary-subtle text-primary">@Model.Count functions</span>
  </div>
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th style="width: 100px;">Included</th>
          <th>Function</th>
          <th style="width: 170px;">Limit Value</th>
          <th style="width: 220px;">Limit Label</th>
        </tr>
      </thead>
      <tbody>
      @for (var i = 0; i < Model.Count; i++)
      {
        <tr>
          <td>
            <input type="hidden" name="Features[@i].Id" value="@Model[i].Id"/>
            <input type="hidden" name="Features[@i].FeatureCode" value="@Model[i].FeatureCode"/>
            <input type="hidden" name="Features[@i].FeatureName" value="@Model[i].FeatureName"/>
            <input type="hidden" name="Features[@i].SortOrder" value="@Model[i].SortOrder"/>
            <input type="hidden" name="Features[@i].IsIncluded" value="false"/>
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" name="Features[@i].IsIncluded" value="true" @(Model[i].IsIncluded ? "checked" : "")/>
            </div>
          </td>
          <td>
            <div class="fw-semibold">@Model[i].FeatureName</div>
            <div class="text-muted small">@Model[i].FeatureCode</div>
          </td>
          <td>
            <input name="Features[@i].LimitValue" value="@Model[i].LimitValue" type="number" class="form-control form-control-sm" placeholder="blank"/>
          </td>
          <td>
            <input name="Features[@i].LimitLabel" value="@Model[i].LimitLabel" class="form-control form-control-sm" placeholder="Limited / Unlimited / 500"/>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
