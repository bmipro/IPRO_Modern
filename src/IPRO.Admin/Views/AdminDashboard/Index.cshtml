@{ ViewData["Title"] = "Dashboard"; }

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="icon-box bg-primary bg-opacity-10 text-primary"><i class="fas fa-users"></i></div>
                <div>
                    <div class="display-6 fw-bold lh-1">@ViewBag.TotalAgents</div>
                    <div class="text-muted small mt-1">Total Agents</div>
                    <div class="text-success small">@ViewBag.ActiveAgents active</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="icon-box bg-success bg-opacity-10 text-success"><i class="fas fa-credit-card"></i></div>
                <div>
                    <div class="display-6 fw-bold lh-1">@ViewBag.ActiveSubs</div>
                    <div class="text-muted small mt-1">Active Subscriptions</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="icon-box bg-warning bg-opacity-10 text-warning"><i class="fas fa-dollar-sign"></i></div>
                <div>
                    <div class="display-6 fw-bold lh-1">$@String.Format("{0:N0}", ViewBag.MonthRevenue)</div>
                    <div class="text-muted small mt-1">Revenue (30 days)</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="icon-box bg-info bg-opacity-10 text-info"><i class="fas fa-address-book"></i></div>
                <div>
                    <div class="display-6 fw-bold lh-1">@ViewBag.TotalClients</div>
                    <div class="text-muted small mt-1">Total Clients</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold mb-0"><i class="fas fa-users me-2 text-primary"></i>Recent Agents</h6>
                    <a href="/Agents" class="btn btn-sm btn-primary"><i class="fas fa-users me-1"></i>Manage All Agents</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead><tr><th>Agent</th><th>Domain</th><th>Joined</th><th>Status</th><th class="text-end">Actions</th></tr></thead>
                        <tbody>
                        @foreach (var a in (ViewBag.RecentAgents as IEnumerable<IPRO.Entities.AgentUser> ?? []))
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@a.FirstName @a.LastName</div>
                                    <small class="text-muted">@a.UserName - @a.Email</small>
                                </td>
                                <td><small class="text-muted">@(a.DomainName ?? "-")</small></td>
                                <td><small class="text-muted">@a.CreatedAt.ToString("MMM d, yyyy")</small></td>
                                <td>
                                    @if (a.IsActive)
                                    { <span class="badge badge-status-active rounded-pill">Active</span> }
                                    else
                                    { <span class="badge badge-status-inactive rounded-pill">Inactive</span> }
                                </td>
                                <td>
                                    <div class="d-flex gap-1 justify-content-end">
                                        <a href="/Agents/Details/@a.Id" class="btn btn-sm btn-outline-primary" title="View"><i class="fas fa-eye"></i></a>
                                        <a href="/Agents/Edit/@a.Id" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="fas fa-pen"></i></a>
                                        <form asp-controller="Agents" asp-action="Delete" asp-route-id="@a.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete" onclick="return confirm('Delete @a.UserName permanently? This cannot be undone.')"><i class="fas fa-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!((ViewBag.RecentAgents as IEnumerable<IPRO.Entities.AgentUser> ?? []).Any()))
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">No agents found</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-receipt me-2 text-success"></i>Recent Invoices</h6>
                @foreach (var inv in (ViewBag.RecentInvoices as IEnumerable<IPRO.Entities.Invoice> ?? []))
                {
                    <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                        <div>
                            <div class="small fw-semibold">@inv.InvoiceNumber</div>
                            <div class="text-muted" style="font-size:.75rem">@inv.IssuedAt.ToString("MMM d")</div>
                        </div>
                        <div class="fw-bold text-success">$@inv.Total.ToString("N2")</div>
                    </div>
                }
                <div class="mt-3"><a href="/Reports/Revenue" class="btn btn-sm btn-outline-success">Revenue Report</a></div>
            </div>
        </div>
    </div>
</div>
