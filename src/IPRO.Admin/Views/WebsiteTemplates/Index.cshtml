@model IEnumerable<IPRO.Entities.WebsiteTemplate>
@{
    ViewData["Title"] = "Website Templates";
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-1"><i class="fas fa-layer-group me-2 text-primary"></i>Website Templates</h4>
    <div class="text-muted">Manage selectable website designs and the default template for new agent sites.</div>
  </div>
  <a href="/WebsiteTemplates/Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>New Template</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Template</th>
          <th>Key</th>
          <th>Vertical</th>
          <th>Status</th>
          <th>Default</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
      @foreach (var template in Model)
      {
        <tr>
          <td>
            <div class="fw-bold">@template.Name</div>
            <div class="small text-muted">@template.Description</div>
          </td>
          <td><code>@template.TemplateKey</code></td>
          <td>@(string.IsNullOrWhiteSpace(template.BusinessType) ? "All" : template.BusinessType)</td>
          <td>
            <span class="badge @(template.IsActive ? "bg-success" : "bg-secondary")">@(template.IsActive ? "Active" : "Inactive")</span>
          </td>
          <td>
            @if (template.IsDefault)
            {
              <span class="badge bg-primary">Default</span>
            }
            else
            {
              <form method="post" action="/WebsiteTemplates/SetDefault/@template.Id" class="d-inline">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-primary" type="submit">Make default</button>
              </form>
            }
          </td>
          <td class="text-end">
            <a href="/WebsiteTemplates/Edit/@template.Id" class="btn btn-sm btn-outline-primary">Edit</a>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
