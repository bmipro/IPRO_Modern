@model IEnumerable<IPRO.Admin.Models.WebsiteTemplateUsageViewModel>
@{
    ViewData["Title"] = "Website Templates";
}

@if (TempData["Success"] != null)
{
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
}
@if (TempData["Error"] != null)
{
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
  </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-1"><i class="fas fa-layer-group me-2 text-primary"></i>Website Templates</h4>
    <div class="text-muted">Manage selectable website designs, package defaults, and current template usage.</div>
  </div>
  <a href="/WebsiteTemplates/Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>New Template</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Template</th>
          <th>Key</th>
          <th>Vertical</th>
          <th>Usage</th>
          <th>Status</th>
          <th>Default</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
      @foreach (var item in Model)
      {
        var template = item.Template;
        var design = IPRO.Entities.WebsiteTemplateDesign.FromTemplate(template);
        <tr>
          <td>
            <div class="d-flex align-items-start gap-2">
              @if (!string.IsNullOrWhiteSpace(template.PreviewImageUrl))
              {
                <img src="@template.PreviewImageUrl" alt="" style="width:72px;height:48px;object-fit:cover;border-radius:5px" />
              }
              <div><div class="fw-bold">@template.Name</div><div class="small text-muted">@template.Description</div></div>
            </div>
            @if (item.AgentNames.Any())
            {
              <div class="small text-muted mt-1">
                <i class="fas fa-user-friends me-1"></i>
                @string.Join(", ", item.AgentNames.Take(4))@(item.AgentNames.Count > 4 ? " ..." : "")
              </div>
            }
            @if (item.PackageNames.Any())
            {
              <div class="small text-muted mt-1">
                <i class="fas fa-box me-1"></i>
                Package default for @string.Join(", ", item.PackageNames.Take(3))@(item.PackageNames.Count > 3 ? " ..." : "")
              </div>
            }
          </td>
          <td><code>@template.TemplateKey</code><div class="small text-muted mt-1">@design.Renderer · v@design.Version</div></td>
          <td>@(string.IsNullOrWhiteSpace(template.BusinessType) ? "All" : template.BusinessType)</td>
          <td>
            <div class="fw-semibold">@item.WebsiteCount agent site@(item.WebsiteCount == 1 ? "" : "s")</div>
            <div class="small text-muted">@item.PublishedWebsiteCount published</div>
            <div class="small text-muted">@item.PackageDefaultCount package default@(item.PackageDefaultCount == 1 ? "" : "s")</div>
          </td>
          <td>
            <span class="badge @(template.IsActive ? "bg-success" : "bg-secondary")">@(template.IsActive ? "Active" : "Retired")</span>
          </td>
          <td>
            @if (template.IsDefault)
            {
              <span class="badge bg-primary">Default</span>
            }
            else if (template.IsActive)
            {
              <form method="post" action="/WebsiteTemplates/SetDefault/@template.Id" class="d-inline">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-primary" type="submit">Make default</button>
              </form>
            }
          </td>
          <td class="text-end">
            <a href="/WebsiteTemplates/Edit/@template.Id" class="btn btn-sm btn-outline-primary">Edit</a>
            <form method="post" action="/WebsiteTemplates/Duplicate/@template.Id" class="d-inline">
              @Html.AntiForgeryToken()
              <button class="btn btn-sm btn-outline-secondary" type="submit" title="Create a new editable version"><i class="fas fa-copy"></i></button>
            </form>
            @if (template.IsActive)
            {
              <form method="post" action="/WebsiteTemplates/Retire/@template.Id" class="d-inline" onsubmit="return confirm('Retire @template.Name? @item.WebsiteCount agent site(s) currently use it. Existing sites remain online and those agents will be prompted to choose another template.');">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-warning" type="submit" title="Retire template"><i class="fas fa-box-archive"></i></button>
              </form>
            }
            else
            {
              <form method="post" action="/WebsiteTemplates/Restore/@template.Id" class="d-inline">
                @Html.AntiForgeryToken()
                <button class="btn btn-sm btn-outline-success" type="submit" title="Restore template"><i class="fas fa-rotate-left"></i></button>
              </form>
            }
            <form method="post" action="/WebsiteTemplates/Delete/@template.Id" class="d-inline" onsubmit="return confirm('Delete this template? This is only allowed when no agents or packages use it.');">
              @Html.AntiForgeryToken()
              <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
