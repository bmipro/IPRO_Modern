@model IPRO.Entities.WebsiteTemplate
@{
    ViewData["Title"] = Model.Id == 0 ? "Create Website Template" : "Edit Website Template";
    var design = IPRO.Entities.WebsiteTemplateDesign.FromTemplate(Model);
}

<div class="mb-4">
  <nav aria-label="breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><a href="/WebsiteTemplates">Website Templates</a></li>
      <li class="breadcrumb-item active">@(Model.Id == 0 ? "Create" : "Edit")</li>
    </ol>
  </nav>
  <h4 class="fw-bold mb-1">@ViewData["Title"]</h4>
  <div class="text-muted">Create reusable website designs by choosing a renderer, palette, and font style.</div>
</div>

<form method="post" action="/WebsiteTemplates/Edit">
  @Html.AntiForgeryToken()
  <input type="hidden" asp-for="Id" />
  <input type="hidden" asp-for="CreatedAt" />

  @if (!ViewData.ModelState.IsValid)
  {
    <div class="alert alert-danger" asp-validation-summary="All"></div>
  }

  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <div class="row g-3">
        <div class="col-md-6">
          <label asp-for="Name" class="form-label fw-semibold">Template Name</label>
          <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-6">
          <label asp-for="TemplateKey" class="form-label fw-semibold">Template Key</label>
          <input asp-for="TemplateKey" class="form-control" placeholder="classic-sidebar" />
          <div class="form-text">Use a unique key for each design, such as modern-professional-blue or classic-sidebar-green.</div>
        </div>
        <div class="col-12">
          <label asp-for="Description" class="form-label fw-semibold">Description</label>
          <input asp-for="Description" class="form-control" />
        </div>
        <div class="col-md-6">
          <label asp-for="BusinessType" class="form-label fw-semibold">Vertical / Business Type</label>
          <input asp-for="BusinessType" class="form-control" placeholder="Insurance / Financial, Accountants, or blank for all" />
        </div>
        <div class="col-md-6">
          <label asp-for="PreviewImageUrl" class="form-label fw-semibold">Preview Image URL <span class="text-muted fw-normal">(optional)</span></label>
          <input asp-for="PreviewImageUrl" class="form-control" />
          <div class="form-text">Leave blank until we add template preview screenshots.</div>
        </div>
        <div class="col-12">
          <div class="border rounded-3 p-3 bg-light">
            <div class="fw-bold mb-3"><i class="fas fa-sliders me-2 text-primary"></i>Design Preset</div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Renderer</label>
                <select id="templateRenderer" class="form-select">
                  <option value="modern-professional" selected="@(design.Renderer == "modern-professional")">Modern Professional</option>
                  <option value="classic-sidebar" selected="@(design.Renderer == "classic-sidebar")">Classic Sidebar</option>
                  <option value="editorial-visual" selected="@(design.Renderer == "editorial-visual")">Editorial / Visual</option>
                </select>
                <div class="form-text">Renderer controls the broad page layout.</div>
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">Accent Color</label>
                <input id="accentColor" type="color" class="form-control form-control-color w-100" value="@design.AccentColor" />
              </div>
              <div class="col-md-3">
                <label class="form-label fw-semibold">Background</label>
                <input id="backgroundColor" type="color" class="form-control form-control-color w-100" value="@design.BackgroundColor" />
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Font</label>
                <select id="fontFamily" class="form-select">
                  <option value="Arial, Helvetica, sans-serif" selected="@(design.FontFamily.Contains("Arial"))">Clean Sans</option>
                  <option value="Georgia, 'Times New Roman', serif" selected="@(design.FontFamily.Contains("Georgia"))">Editorial Serif</option>
                  <option value="'Segoe UI', Arial, Helvetica, sans-serif" selected="@(design.FontFamily.Contains("Segoe"))">Modern UI</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Hero Style</label>
                <select id="heroStyle" class="form-select">
                  <option value="gradient" selected="@(design.HeroStyle == "gradient")">Gradient</option>
                  <option value="clean" selected="@(design.HeroStyle == "clean")">Clean</option>
                  <option value="classic" selected="@(design.HeroStyle == "classic")">Classic</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Header / Navigation</label>
                <select id="headerStyle" class="form-select">
                  <option value="light" selected="@(design.HeaderStyle == "light")">Light header</option>
                  <option value="dark" selected="@(design.HeaderStyle == "dark")">Dark header</option>
                  <option value="overlay" selected="@(design.HeaderStyle == "overlay")">Overlay header</option>
                  <option value="sidebar" selected="@(design.HeaderStyle == "sidebar")">Sidebar navigation</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Hero Layout</label>
                <select id="heroLayout" class="form-select">
                  <option value="split" selected="@(design.HeroLayout == "split")">Text left / image right</option>
                  <option value="image-left" selected="@(design.HeroLayout == "image-left")">Image left / text right</option>
                  <option value="centered" selected="@(design.HeroLayout == "centered")">Centered</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Section Spacing</label>
                <select id="sectionSpacing" class="form-select">
                  <option value="compact" selected="@(design.SectionSpacing == "compact")">Compact</option>
                  <option value="comfortable" selected="@(design.SectionSpacing == "comfortable")">Comfortable</option>
                  <option value="spacious" selected="@(design.SectionSpacing == "spacious")">Spacious</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Button Style</label>
                <select id="buttonStyle" class="form-select">
                  <option value="square" selected="@(design.ButtonStyle == "square")">Square</option>
                  <option value="soft" selected="@(design.ButtonStyle == "soft")">Soft corners</option>
                  <option value="pill" selected="@(design.ButtonStyle == "pill")">Pill</option>
                </select>
              </div>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-4 mb-2">
              <div class="fw-semibold">Responsive preview</div>
              <div class="btn-group btn-group-sm" role="group" aria-label="Preview viewport">
                <button type="button" class="btn btn-primary" id="previewDesktop"><i class="fas fa-desktop me-1"></i>Desktop</button>
                <button type="button" class="btn btn-outline-primary" id="previewMobile"><i class="fas fa-mobile-screen me-1"></i>Mobile</button>
              </div>
            </div>
            <div class="template-builder-preview mt-3 @(design.Renderer == "classic-sidebar" ? "is-classic" : "")" id="templateBuilderPreview"
                 style="--builder-accent:@design.AccentColor;--builder-bg:@design.BackgroundColor;--builder-font:@design.FontFamily">
              <div class="template-builder-preview__nav">
                <strong>Agent Business</strong>
                <span>Home</span><span>Services</span><span>About</span><span>Contact</span>
              </div>
              <div class="template-builder-preview__body">
                <aside>
                  <strong>Agent Business</strong>
                  <span>Home</span><span>Services</span><span>About</span><span>Contact</span>
                </aside>
                <section>
                  <small>TRUSTED LOCAL PROFESSIONAL</small>
                  <h3>A website designed around your business</h3>
                  <p>Clear services, helpful content, and a direct path for clients to connect.</p>
                  <b>Get started</b>
                </section>
              </div>
            </div>
            <div class="form-text mt-2">Live preview of the selected renderer, palette, font, and hero style.</div>
          </div>
        </div>
        <div class="col-12">
          <details class="border rounded-3 p-3">
            <summary class="fw-semibold">Advanced template metadata</summary>
            <label asp-for="LayoutJson" class="form-label fw-semibold mt-3">Layout JSON</label>
            <textarea asp-for="LayoutJson" id="LayoutJson" class="form-control font-monospace" rows="7" readonly></textarea>
            <div class="form-text">Generated automatically from the visual controls above.</div>
          </details>
        </div>
        <div class="col-md-6">
          <div class="form-check form-switch">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label fw-semibold">Template is active</label>
          </div>
        </div>
        <div class="col-md-6">
          <div class="form-check form-switch">
            <input asp-for="IsDefault" class="form-check-input" />
            <label asp-for="IsDefault" class="form-check-label fw-semibold">Use as default template</label>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between mt-4">
    <a href="/WebsiteTemplates" class="btn btn-outline-secondary">Cancel</a>
    <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i>Save Template</button>
  </div>
</form>

<style>
.template-builder-preview { overflow: hidden; min-height: 280px; border: 1px solid #d6deea; border-radius: 8px; background: var(--builder-bg); color: #182236; font-family: var(--builder-font); }
.template-builder-preview__nav { display: flex; align-items: center; gap: 20px; min-height: 52px; padding: 12px 20px; background: #fff; border-bottom: 1px solid #e5eaf1; font-size: 13px; }
.template-builder-preview__nav strong { margin-right: auto; color: var(--builder-accent); font-size: 16px; }
.template-builder-preview.header-dark .template-builder-preview__nav { background: #111827; color: #fff; }
.template-builder-preview.header-dark .template-builder-preview__nav strong { color: #fff; }
.template-builder-preview.header-overlay .template-builder-preview__nav { position: relative; z-index: 2; margin-bottom: -52px; background: rgba(255,255,255,.88); }
.template-builder-preview__body { min-height: 228px; }
.template-builder-preview__body aside { display: none; }
.template-builder-preview__body section { min-height: 228px; padding: 38px; background: linear-gradient(135deg, #fff, var(--builder-bg)); }
.template-builder-preview__body small { color: var(--builder-accent); font-weight: 700; }
.template-builder-preview__body h3 { max-width: 560px; margin: 8px 0; font-size: 29px; }
.template-builder-preview__body p { max-width: 600px; color: #58657b; }
.template-builder-preview__body b { display: inline-block; margin-top: 6px; padding: 8px 14px; border-radius: 5px; background: var(--builder-accent); color: #fff; font-size: 13px; }
.template-builder-preview.is-editorial .template-builder-preview__nav { background: rgba(255,255,255,.94); }
.template-builder-preview.is-editorial .template-builder-preview__body { display: grid; grid-template-columns: 1.05fr .95fr; }
.template-builder-preview.is-editorial .template-builder-preview__body section { order: 2; background: #fff; }
.template-builder-preview.is-editorial .template-builder-preview__body::before { content: ""; background: linear-gradient(145deg, #211d19, var(--builder-accent)); }
.template-builder-preview.is-centered .template-builder-preview__body section { text-align: center; }
.template-builder-preview.is-centered .template-builder-preview__body section > * { margin-left: auto; margin-right: auto; }
.template-builder-preview.is-image-left:not(.is-editorial) .template-builder-preview__body section { padding-left: 45%; }
.template-builder-preview.buttons-square .template-builder-preview__body b { border-radius: 2px; }
.template-builder-preview.buttons-pill .template-builder-preview__body b { border-radius: 999px; }
.template-builder-preview.spacing-compact .template-builder-preview__body section { padding-top: 24px; padding-bottom: 24px; }
.template-builder-preview.spacing-spacious .template-builder-preview__body section { padding-top: 50px; padding-bottom: 50px; }
.template-builder-preview.preview-mobile { width: 390px; max-width: 100%; margin-left: auto; margin-right: auto; }
.template-builder-preview.preview-mobile .template-builder-preview__nav span { display: none; }
.template-builder-preview.preview-mobile .template-builder-preview__body,
.template-builder-preview.preview-mobile.is-editorial .template-builder-preview__body { display: block; }
.template-builder-preview.preview-mobile .template-builder-preview__body::before { display: block; min-height: 120px; }
.template-builder-preview.preview-mobile .template-builder-preview__body section { padding: 24px; text-align: left; }
.template-builder-preview.is-classic .template-builder-preview__nav { display: none; }
.template-builder-preview.is-classic .template-builder-preview__body { display: grid; grid-template-columns: 175px 1fr; }
.template-builder-preview.is-classic .template-builder-preview__body aside { display: flex; flex-direction: column; gap: 15px; padding: 24px; background: var(--builder-accent); color: #fff; font-size: 13px; }
.template-builder-preview.is-classic .template-builder-preview__body aside strong { margin-bottom: 12px; font-size: 16px; }
.template-builder-preview.is-classic .template-builder-preview__body section { background: var(--builder-bg); }
@@media (max-width: 700px) {
  .template-builder-preview__nav span { display: none; }
  .template-builder-preview.is-classic .template-builder-preview__body { grid-template-columns: 110px 1fr; }
  .template-builder-preview__body section { padding: 24px; }
}
</style>

@section Scripts {
<script>
function updateTemplatePreview() {
  const preview = document.getElementById('templateBuilderPreview');
  if (!preview) return;
  const renderer = document.getElementById('templateRenderer')?.value || 'modern-professional';
  preview.classList.toggle('is-classic', renderer === 'classic-sidebar');
  preview.classList.toggle('is-editorial', renderer === 'editorial-visual');
  preview.classList.toggle('is-centered', document.getElementById('heroLayout')?.value === 'centered');
  preview.classList.toggle('is-image-left', document.getElementById('heroLayout')?.value === 'image-left');
  preview.classList.toggle('header-dark', document.getElementById('headerStyle')?.value === 'dark' || document.getElementById('headerStyle')?.value === 'sidebar');
  preview.classList.toggle('header-overlay', document.getElementById('headerStyle')?.value === 'overlay');
  preview.classList.toggle('buttons-square', document.getElementById('buttonStyle')?.value === 'square');
  preview.classList.toggle('buttons-pill', document.getElementById('buttonStyle')?.value === 'pill');
  preview.classList.toggle('spacing-compact', document.getElementById('sectionSpacing')?.value === 'compact');
  preview.classList.toggle('spacing-spacious', document.getElementById('sectionSpacing')?.value === 'spacious');
  preview.style.setProperty('--builder-accent', document.getElementById('accentColor')?.value || '#1457d9');
  preview.style.setProperty('--builder-bg', document.getElementById('backgroundColor')?.value || '#f4f7fb');
  preview.style.setProperty('--builder-font', document.getElementById('fontFamily')?.value || 'Arial, Helvetica, sans-serif');
}
function syncTemplateJson() {
  const payload = {
    renderer: document.getElementById('templateRenderer')?.value || 'modern-professional',
    accentColor: document.getElementById('accentColor')?.value || '#1457d9',
    backgroundColor: document.getElementById('backgroundColor')?.value || '#f4f7fb',
    fontFamily: document.getElementById('fontFamily')?.value || 'Arial, Helvetica, sans-serif',
    heroStyle: document.getElementById('heroStyle')?.value || 'gradient',
    headerStyle: document.getElementById('headerStyle')?.value || 'light',
    heroLayout: document.getElementById('heroLayout')?.value || 'split',
    sectionSpacing: document.getElementById('sectionSpacing')?.value || 'spacious',
    buttonStyle: document.getElementById('buttonStyle')?.value || 'soft',
    version: @design.Version
  };
  const target = document.getElementById('LayoutJson');
  if (target) {
    target.value = JSON.stringify(payload, null, 2);
  }
  updateTemplatePreview();
}

['templateRenderer', 'accentColor', 'backgroundColor', 'fontFamily', 'heroStyle', 'headerStyle', 'heroLayout', 'sectionSpacing', 'buttonStyle'].forEach(id => {
  document.getElementById(id)?.addEventListener('change', syncTemplateJson);
  document.getElementById(id)?.addEventListener('input', syncTemplateJson);
});

document.getElementById('previewDesktop')?.addEventListener('click', function () {
  document.getElementById('templateBuilderPreview')?.classList.remove('preview-mobile');
  this.className = 'btn btn-primary';
  document.getElementById('previewMobile').className = 'btn btn-outline-primary';
});
document.getElementById('previewMobile')?.addEventListener('click', function () {
  document.getElementById('templateBuilderPreview')?.classList.add('preview-mobile');
  this.className = 'btn btn-primary';
  document.getElementById('previewDesktop').className = 'btn btn-outline-primary';
});

document.querySelector('form[action="/WebsiteTemplates/Edit"]')?.addEventListener('submit', syncTemplateJson);
updateTemplatePreview();
</script>
}
