@model IEnumerable<IPRO.Entities.WebsiteStarterPage>
@{
  ViewData["Title"] = "Website Starter Content";
  var groups = Model.GroupBy(p => new { p.BusinessType, Package = p.BillingRule?.PackageName ?? "All packages" })
      .OrderBy(g => g.Key.BusinessType).ThenBy(g => g.Key.Package);
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
  <div><h3 class="fw-bold mb-1"><i class="fas fa-wand-magic-sparkles me-2 text-primary"></i>Website Starter Content</h3><div class="text-muted">Define the first pages agents receive by business type and, optionally, package.</div></div>
  <a href="/StarterContent/Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>New Starter Page</a>
</div>

<div class="alert alert-info border-0 shadow-sm">Starter content is copied only when an agent has no managed pages. Editing these records will not overwrite an agent's customized website.</div>

@foreach (var group in groups)
{
  <section class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white py-3"><strong>@group.Key.BusinessType</strong><span class="text-muted ms-2">@group.Key.Package</span></div>
    <div class="table-responsive"><table class="table align-middle mb-0"><thead><tr><th>Order</th><th>Page</th><th>URL</th><th>Blocks</th><th>Status</th><th class="text-end">Actions</th></tr></thead><tbody>
    @foreach (var starterPage in group.OrderBy(p => p.SortOrder))
    {
      <tr><td>@starterPage.SortOrder</td><td><strong>@starterPage.Title</strong>@if(starterPage.IsHomePage){<span class="badge bg-primary ms-2">Home</span>}</td><td><code>/@(starterPage.IsHomePage ? "" : starterPage.Slug)</code></td><td>@starterPage.Blocks.Count</td><td><span class="badge @(starterPage.IsActive ? "bg-success" : "bg-secondary")">@(starterPage.IsActive ? "Active" : "Inactive")</span></td><td class="text-end"><div class="d-flex justify-content-end gap-1"><a href="/StarterContent/Edit/@starterPage.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-pen me-1"></i>Edit</a><form method="post" action="/StarterContent/Delete/@starterPage.Id" onsubmit="return confirm('Delete this starter page? Existing agent pages will remain unchanged.');">@Html.AntiForgeryToken()<button class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i></button></form></div></td></tr>
    }
    </tbody></table></div>
  </section>
}
