@model IPRO.Entities.NewsLetterTemplate
@{
    ViewData["Title"] = Model.Id == 0 ? "New Newsletter Template" : "Edit Newsletter Template";
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/NewsletterTemplates">Newsletter Templates</a></li><li class="breadcrumb-item active">@(Model.Id == 0 ? "New" : "Edit")</li></ol>
</nav>

<div class="card border-0 shadow-sm">
  <div class="card-body p-4">
    <form method="post" action="/NewsletterTemplates/Edit">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />
      <input type="hidden" asp-for="CreatedAt" />
      <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

      <div class="row">
        <div class="col-md-8 mb-3">
          <label class="form-label fw-semibold">Template Name</label>
          <input asp-for="Name" class="form-control" placeholder="e.g. Simple Announcement" />
          <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="col-md-4 mb-3">
          <label class="form-label fw-semibold">Sort Order</label>
          <input asp-for="SortOrder" type="number" class="form-control" />
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Description</label>
        <input asp-for="Description" class="form-control" placeholder="Shown to agents when choosing a starting point" />
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">Default Subject Line</label>
        <input asp-for="Subject" class="form-control" />
        <span asp-validation-for="Subject" class="text-danger small"></span>
      </div>

      <div class="mb-3">
        <label class="form-label fw-semibold">HTML Body</label>
        @await Html.PartialAsync("_RichEditor", Model.HtmlBody ?? string.Empty, new ViewDataDictionary(ViewData) {
            { "EditorId", "templateBody" }, { "FieldName", "HtmlBody" }, { "Height", "400" }, { "Toolbar", "full" }
        })
      </div>

      <div class="mb-4">
        <label class="form-label fw-semibold">Plain Text Version</label>
        <textarea asp-for="TextBody" class="form-control" rows="4"></textarea>
      </div>

      <div class="form-check form-switch mb-4">
        <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
        <label asp-for="IsActive" class="form-check-label">Offer this template to agents</label>
      </div>

      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary px-4">Save Template</button>
        <a href="/NewsletterTemplates" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
