@model IPRO.Admin.Controllers.WebsiteLeadsAdminViewModel
@{
    ViewData["Title"] = "Website Leads";
    var tab = (string)(ViewBag.Tab ?? "leads");
    var search = ViewBag.Search as string;
    var reason = ViewBag.Reason as string;
    var failedOnly = (bool)(ViewBag.FailedOnly ?? false);
    var page = (int)(ViewBag.Page ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
    var totalLeads = (int)(ViewBag.TotalLeads ?? 0);
    var totalAttempts = (int)(ViewBag.TotalAttempts ?? 0);
    var failedNotificationCount = (int)(ViewBag.FailedNotificationCount ?? 0);
}

<div class="mb-4">
    <h4 class="fw-bold mb-1"><i class="fas fa-inbox me-2 text-primary"></i>Website Leads</h4>
    <div class="text-muted">Cross-agent visibility into public website leads, notification delivery, and blocked spam/bot attempts.</div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Total leads</div><div class="h3 fw-bold mb-0">@totalLeads</div></div></div></div>
    <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Notification not delivered</div><div class="h3 fw-bold text-warning mb-0">@failedNotificationCount</div></div></div></div>
    <div class="col-md-4"><div class="card border-0 shadow-sm"><div class="card-body"><div class="small text-muted">Blocked spam/bot attempts</div><div class="h3 fw-bold text-danger mb-0">@totalAttempts</div></div></div></div>
</div>

<ul class="nav nav-tabs mb-3">
    <li class="nav-item"><a class="nav-link @(tab == "leads" ? "active" : "")" href="/WebsiteLeads?tab=leads">Leads</a></li>
    <li class="nav-item"><a class="nav-link @(tab == "attempts" ? "active" : "")" href="/WebsiteLeads?tab=attempts">Blocked Attempts</a></li>
</ul>

@if (tab == "leads")
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
                <input type="hidden" name="tab" value="leads" />
                <input class="form-control" style="max-width:320px" type="search" name="search" value="@search" placeholder="Search agent, name, email, domain..." />
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="failedOnly" value="true" id="failedOnly" checked="@(failedOnly ? "checked" : null)" />
                    <label class="form-check-label" for="failedOnly">Notification not delivered only</label>
                </div>
                <button class="btn btn-primary"><i class="fas fa-search me-1"></i>Filter</button>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle bg-white">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Agent</th>
                    <th>Contact</th>
                    <th>Type</th>
                    <th>Source</th>
                    <th>Status</th>
                    <th>Notification</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lead in Model.Leads)
                {
                    <tr>
                        <td class="text-nowrap small">@lead.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                        <td>@($"{lead.AgentUser.FirstName} {lead.AgentUser.LastName}".Trim())<div class="small text-muted">@lead.AgentUser.Email</div></td>
                        <td>@lead.FirstName @lead.LastName<div class="small text-muted">@lead.Email</div></td>
                        <td><span class="badge bg-info-subtle text-info-emphasis">@(lead.SubmissionType == IPRO.Entities.WebsiteLeadTypes.Newsletter ? "Newsletter" : "Contact")</span></td>
                        <td class="small">@lead.SourceDomain</td>
                        <td><span class="badge bg-secondary-subtle text-secondary-emphasis">@lead.Status</span></td>
                        <td>
                            @if (lead.NotificationSent)
                            {
                                <span class="badge bg-success-subtle text-success-emphasis"><i class="fas fa-check me-1"></i>Sent</span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning-emphasis" title="@lead.NotificationError"><i class="fas fa-triangle-exclamation me-1"></i>Failed</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Leads.Any())
        {
            <div class="text-center text-muted py-5"><i class="fas fa-inbox fa-3x opacity-25 d-block mb-3"></i>No website leads match this view.</div>
        }
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body p-3">
            <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
                <input type="hidden" name="tab" value="attempts" />
                <select name="reason" class="form-select" style="max-width:220px">
                    <option value="">All reasons</option>
                    <option value="@IPRO.Entities.WebsiteSpamAttemptReasons.Honeypot" selected="@(reason == IPRO.Entities.WebsiteSpamAttemptReasons.Honeypot ? "selected" : null)">Honeypot</option>
                    <option value="@IPRO.Entities.WebsiteSpamAttemptReasons.Timing" selected="@(reason == IPRO.Entities.WebsiteSpamAttemptReasons.Timing ? "selected" : null)">Timing</option>
                    <option value="@IPRO.Entities.WebsiteSpamAttemptReasons.Captcha" selected="@(reason == IPRO.Entities.WebsiteSpamAttemptReasons.Captcha ? "selected" : null)">Captcha</option>
                </select>
                <input class="form-control" style="max-width:280px" type="search" name="search" value="@search" placeholder="Search domain or IP..." />
                <button class="btn btn-primary"><i class="fas fa-search me-1"></i>Filter</button>
            </form>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle bg-white">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Agent</th>
                    <th>Reason</th>
                    <th>Domain</th>
                    <th>Page</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var attempt in Model.Attempts)
                {
                    <tr>
                        <td class="text-nowrap small">@attempt.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</td>
                        <td>@($"{attempt.AgentUser.FirstName} {attempt.AgentUser.LastName}".Trim())</td>
                        <td><span class="badge bg-danger-subtle text-danger-emphasis">@attempt.Reason</span></td>
                        <td class="small">@attempt.SourceDomain</td>
                        <td class="small text-truncate" style="max-width:220px">@attempt.SourcePage</td>
                        <td class="small">@attempt.IpAddress</td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Attempts.Any())
        {
            <div class="text-center text-muted py-5"><i class="fas fa-shield-halved fa-3x opacity-25 d-block mb-3"></i>No blocked attempts match this view.</div>
        }
    </div>
}

@if (totalPages > 1)
{
    <nav class="mt-4"><ul class="pagination justify-content-center">
        @for (var i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == page ? "active" : "")"><a class="page-link" href="?tab=@tab&search=@Uri.EscapeDataString(search ?? "")&reason=@Uri.EscapeDataString(reason ?? "")&failedOnly=@failedOnly&page=@i">@i</a></li>
        }
    </ul></nav>
}
