@model IPRO.Admin.Models.TaxRateEditViewModel
@{ ViewData["Title"] = "Tax Rates"; }

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
  <div>
    <h4 class="fw-bold mb-1"><i class="fas fa-percent me-2 text-primary"></i>Canadian Tax Rates</h4>
    <p class="text-muted mb-0">These rates are used when billing Canadian agents. US agents are charged no tax.</p>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-body p-4">
    <form asp-action="Index" method="post">
      @Html.AntiForgeryToken()
      <div asp-validation-summary="All" class="text-danger mb-3"></div>
      <div class="table-responsive">
        <table class="table align-middle">
          <thead>
            <tr>
              <th style="width:90px;">Code</th>
              <th>Province</th>
              <th>Tax Label</th>
              <th style="width:160px;">Rate %</th>
              <th style="width:120px;">Active</th>
            </tr>
          </thead>
          <tbody>
          @for (var i = 0; i < Model.Rates.Count; i++)
          {
            <tr>
              <td>
                <input type="hidden" asp-for="Rates[i].Id"/>
                <input asp-for="Rates[i].ProvinceCode" class="form-control form-control-sm text-uppercase" maxlength="10"/>
              </td>
              <td><input asp-for="Rates[i].ProvinceName" class="form-control form-control-sm"/></td>
              <td><input asp-for="Rates[i].TaxLabel" class="form-control form-control-sm" placeholder="13% HST"/></td>
              <td>
                <div class="input-group input-group-sm">
                  <input asp-for="Rates[i].RatePercent" type="number" step="0.001" min="0" max="100" class="form-control"/>
                  <span class="input-group-text">%</span>
                </div>
              </td>
              <td>
                <div class="form-check form-switch">
                  <input asp-for="Rates[i].IsActive" class="form-check-input" type="checkbox"/>
                </div>
              </td>
            </tr>
          }
          </tbody>
        </table>
      </div>
      <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-save me-1"></i>Save Tax Rates</button>
      </div>
    </form>
  </div>
</div>
