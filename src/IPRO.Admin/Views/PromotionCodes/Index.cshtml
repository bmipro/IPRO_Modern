@model IEnumerable<IPRO.Entities.PromotionCode>
@{
    ViewData["Title"] = "Promotion Codes";
    var packageNames = (ViewBag.PackageNames as Dictionary<int, string>) ?? new Dictionary<int, string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 class="fw-bold mb-1"><i class="fas fa-tags me-2 text-primary"></i>Promotion Codes</h4>
    <div class="text-muted">Discount codes agents can enter at signup. All tested against PayPal Sandbox before going live.</div>
  </div>
  <a href="/PromotionCodes/Create" class="btn btn-primary"><i class="fas fa-plus me-1"></i>New Code</a>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Code</th>
          <th>Discount</th>
          <th>Package</th>
          <th>Redemptions</th>
          <th>Expires</th>
          <th>Status</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
      @foreach (var code in Model)
      {
        <tr>
          <td><code>@code.Code</code><div class="small text-muted">@code.Description</div></td>
          <td>
            @if (code.RecurringDiscountType != IPRO.Entities.PromoDiscountType.None)
            {
              <div>
                @(code.RecurringDiscountType == IPRO.Entities.PromoDiscountType.PercentOff ? $"{code.RecurringDiscountValue}% off" : $"${code.RecurringDiscountValue} off") recurring
                &mdash; @(code.RecurringDurationCycles == null ? "forever" : code.RecurringDurationCycles == 1 ? "first cycle only" : $"{code.RecurringDurationCycles} cycles")
              </div>
            }
            @if (code.SetupFeeDiscountType != IPRO.Entities.PromoDiscountType.None)
            {
              <div class="small text-muted">
                @(code.SetupFeeDiscountType == IPRO.Entities.PromoDiscountType.PercentOff ? $"{code.SetupFeeDiscountValue}% off" : $"${code.SetupFeeDiscountValue} off") setup fee
              </div>
            }
          </td>
          <td>@(code.RestrictedBillingRuleId.HasValue && packageNames.TryGetValue(code.RestrictedBillingRuleId.Value, out var name) ? name : "Any package")</td>
          <td>
            <a href="/PromotionCodes/Redemptions/@code.Id">@code.RedemptionCount@(code.MaxRedemptions.HasValue ? $" / {code.MaxRedemptions}" : "")</a>
          </td>
          <td class="small text-muted">@(code.ExpiresAt?.ToString("MMM d, yyyy") ?? "Never")</td>
          <td><span class="badge @(code.IsActive ? "bg-success" : "bg-secondary")">@(code.IsActive ? "Active" : "Inactive")</span></td>
          <td class="text-end"><a href="/PromotionCodes/Edit/@code.Id" class="btn btn-sm btn-outline-primary">Edit</a></td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
