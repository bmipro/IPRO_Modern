@model IPRO.Entities.PromotionCode
@{
    ViewData["Title"] = Model.Id == 0 ? "New Promotion Code" : "Edit Promotion Code";
    var packages = (ViewBag.Packages as IEnumerable<IPRO.Entities.BillingRule>) ?? Enumerable.Empty<IPRO.Entities.BillingRule>();
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/PromotionCodes">Promotion Codes</a></li><li class="breadcrumb-item active">@(Model.Id == 0 ? "New" : Model.Code)</li></ol>
</nav>

<div class="card border-0 shadow-sm" style="max-width:820px">
  <div class="card-body p-4">
    <form method="post" action="/PromotionCodes/Edit">
      @Html.AntiForgeryToken()
      <input type="hidden" asp-for="Id" />
      <input type="hidden" asp-for="CreatedAt" />
      <input type="hidden" asp-for="RedemptionCount" />
      <input type="hidden" asp-for="PayPalPromoPlanIdMonthly" />
      <input type="hidden" asp-for="PayPalPromoPlanIdAnnual" />
      <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-semibold">Code</label>
          <input asp-for="Code" class="form-control text-uppercase" placeholder="SAVE20" />
          <span asp-validation-for="Code" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
          <label class="form-label fw-semibold">Description</label>
          <input asp-for="Description" class="form-control" placeholder="For internal reference" />
        </div>

        <div class="col-md-4">
          <div class="form-check form-switch mt-4">
            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
            <label asp-for="IsActive" class="form-check-label">Active</label>
          </div>
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Expires</label>
          <input asp-for="ExpiresAt" type="date" class="form-control" />
        </div>
        <div class="col-md-4">
          <label class="form-label fw-semibold">Max Redemptions</label>
          <input asp-for="MaxRedemptions" type="number" class="form-control" placeholder="Blank = unlimited" />
        </div>

        <div class="col-12">
          <div class="border rounded-3 p-3 bg-light">
            <div class="fw-bold mb-3"><i class="fas fa-percent me-2 text-primary"></i>Recurring Price Discount</div>
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label fw-semibold">Type</label>
                <select asp-for="RecurringDiscountType" class="form-select">
                  <option value="@IPRO.Entities.PromoDiscountType.None">None</option>
                  <option value="@IPRO.Entities.PromoDiscountType.PercentOff">Percent off</option>
                  <option value="@IPRO.Entities.PromoDiscountType.FlatAmountOff">Flat amount off</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-semibold">Value</label>
                <input asp-for="RecurringDiscountValue" type="number" step="0.01" class="form-control" />
              </div>
              <div class="col-md-4">
                <label class="form-label fw-semibold">Duration (cycles)</label>
                <input asp-for="RecurringDurationCycles" type="number" min="1" class="form-control" placeholder="Blank = forever" />
                <div class="form-text">1 = first billing cycle only, then full price. Blank = permanent discount.</div>
              </div>
              <div class="col-12">
                <label class="form-label fw-semibold">Restricted Package</label>
                <select asp-for="RestrictedBillingRuleId" class="form-select">
                  <option value="">Any package (only valid if no recurring discount is set)</option>
                  @foreach (var package in packages)
                  {
                    <option value="@package.Id">@package.PackageName</option>
                  }
                </select>
                <span asp-validation-for="RestrictedBillingRuleId" class="text-danger small"></span>
                <div class="form-text">Required whenever a recurring discount is set &mdash; PayPal plans are package-specific.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-12">
          <div class="border rounded-3 p-3 bg-light">
            <div class="fw-bold mb-3"><i class="fas fa-receipt me-2 text-primary"></i>Setup Fee Discount</div>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-semibold">Type</label>
                <select asp-for="SetupFeeDiscountType" class="form-select">
                  <option value="@IPRO.Entities.PromoDiscountType.None">None</option>
                  <option value="@IPRO.Entities.PromoDiscountType.PercentOff">Percent off</option>
                  <option value="@IPRO.Entities.PromoDiscountType.FlatAmountOff">Flat amount off</option>
                </select>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-semibold">Value</label>
                <input asp-for="SetupFeeDiscountValue" type="number" step="0.01" class="form-control" />
                <div class="form-text">Use Percent off = 100 to fully waive the setup fee.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex gap-2 mt-4">
        <button type="submit" class="btn btn-primary px-4">Save Code</button>
        <a href="/PromotionCodes" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>
  </div>
</div>
