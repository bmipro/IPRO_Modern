@model IEnumerable<IPRO.Entities.PromotionCodeRedemption>
@{
    var code = (IPRO.Entities.PromotionCode)ViewBag.Code;
    ViewData["Title"] = $"Redemptions - {code.Code}";
    var agents = (ViewBag.Agents as Dictionary<int, IPRO.Entities.AgentUser>) ?? new Dictionary<int, IPRO.Entities.AgentUser>();
    var packageNames = (ViewBag.PackageNames as Dictionary<int, string>) ?? new Dictionary<int, string>();
}

<nav aria-label="breadcrumb">
  <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/PromotionCodes">Promotion Codes</a></li><li class="breadcrumb-item active">@code.Code Redemptions</li></ol>
</nav>

<div class="mb-4">
  <h4 class="fw-bold mb-1"><i class="fas fa-receipt me-2 text-primary"></i>@code.Code Redemptions</h4>
  <div class="text-muted">@code.RedemptionCount total@(code.MaxRedemptions.HasValue ? $" of {code.MaxRedemptions} allowed" : "")</div>
</div>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead><tr><th>Agent</th><th>Package</th><th>Period</th><th>Recurring</th><th>Setup Fee</th><th>Redeemed</th></tr></thead>
      <tbody>
      @if (!Model.Any())
      {
        <tr><td colspan="6" class="text-muted p-3">No redemptions yet.</td></tr>
      }
      @foreach (var r in Model)
      {
        var agent = agents.TryGetValue(r.AgentUserId, out var a) ? a : null;
        var agentName = agent == null ? $"Agent #{r.AgentUserId}" : $"{agent.FirstName} {agent.LastName}";
        var packageName = packageNames.TryGetValue(r.BillingRuleId, out var pkgName) ? pkgName : $"Package #{r.BillingRuleId}";
        var recurringOriginal = "$" + r.OriginalRecurringAmount.ToString("0.00");
        var recurringDiscounted = "$" + r.DiscountedRecurringAmount.ToString("0.00");
        var setupOriginal = "$" + r.OriginalSetupFee.ToString("0.00");
        var setupDiscounted = "$" + r.DiscountedSetupFee.ToString("0.00");
        var recurringChanged = r.DiscountedRecurringAmount != r.OriginalRecurringAmount;
        var setupChanged = r.DiscountedSetupFee != r.OriginalSetupFee;
        <tr>
          <td>@agentName</td>
          <td>@packageName</td>
          <td>@r.Period</td>
          <td>
            @if (recurringChanged)
            {
              <span class="text-decoration-line-through text-muted">@recurringOriginal</span> @recurringDiscounted
            }
            else
            {
              @recurringOriginal
            }
          </td>
          <td>
            @if (setupChanged)
            {
              <span class="text-decoration-line-through text-muted">@setupOriginal</span> @setupDiscounted
            }
            else
            {
              @setupOriginal
            }
          </td>
          <td class="small text-muted">@r.RedeemedAt.ToString("MMM d, yyyy h:mm tt")</td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</div>
