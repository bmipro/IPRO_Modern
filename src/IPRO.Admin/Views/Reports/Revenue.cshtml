@{ ViewData["Title"] = "Revenue Report"; var invoices = ViewBag.Invoices as IEnumerable<dynamic>; }

<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="fw-bold mb-0"><i class="fas fa-dollar-sign me-2 text-success"></i>Revenue Report</h4>
  <div class="d-flex gap-2">
    @foreach (var m in new[]{3,6,12})
    { <a href="/Reports/Revenue?months=@m" class="btn btn-sm @(ViewBag.Months == m ? "btn-primary" : "btn-outline-secondary")">@m months</a> }
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-md-4">
    <div class="card border-0 shadow-sm text-center p-4">
      <div class="display-5 fw-bold text-success">$@String.Format("{0:N2}", ViewBag.GrandTotal)</div>
      <div class="text-muted">Total Revenue (@ViewBag.Months months)</div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm mb-4">
  <div class="card-body p-4">
    <h6 class="fw-bold mb-3">Revenue by Month</h6>
    <canvas id="revenueChart" height="100"></canvas>
  </div>
</div>

@section Scripts {
<script>
const labels = [@Html.Raw(string.Join(",", (ViewBag.Invoices as IEnumerable<dynamic> ?? []).Select(i => $"'{i.Label}'")))];
const data   = [@Html.Raw(string.Join(",", (ViewBag.Invoices as IEnumerable<dynamic> ?? []).Select(i => i.Total)))];
new Chart(document.getElementById('revenueChart'), {
  type: 'bar',
  data: {
    labels,
    datasets: [{ label: 'Revenue (CAD)', data, backgroundColor: 'rgba(37,99,235,0.7)', borderRadius: 6 }]
  },
  options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { callback: v => '$' + v.toLocaleString() } } } }
});
</script>
}
