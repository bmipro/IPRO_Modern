{
  "ConnectionStrings": {
    "DefaultConnection": "server=YOUR_DB_HOST;port=3306;database=ipro_crm;user=ipro_user;password=YOUR_DB_PASSWORD;SslMode=Required;"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "GeneralRules": [
      { "Endpoint": "POST:/Admin/Login", "Period": "5m", "Limit": 10 },
      { "Endpoint": "*",                 "Period": "1m", "Limit": 120 }
    ]
  },
  "Logging": { "LogLevel": { "Default": "Information" } },
  "AdminPreview": {
    "SharedSecret": "CHANGE_THIS_SHARED_SECRET"
  },
  "AzureDomainAutomation": {
    "Enabled": false,
    "TenantId": "YOUR_AZURE_TENANT_ID",
    "ClientId": "YOUR_AZURE_APP_CLIENT_ID",
    "ClientSecret": "YOUR_AZURE_APP_CLIENT_SECRET",
    "SubscriptionId": "YOUR_AZURE_SUBSCRIPTION_ID",
    "ResourceGroup": "YOUR_RESOURCE_GROUP",
    "WebAppName": "ipro-prod-web",
    "AppServicePlanResourceId": "/subscriptions/YOUR_AZURE_SUBSCRIPTION_ID/resourceGroups/YOUR_RESOURCE_GROUP/providers/Microsoft.Web/serverfarms/YOUR_APP_SERVICE_PLAN",
    "Location": "Canada East",
    "CreateManagedCertificate": true
  },
  "AllowedHosts": "*"
}
